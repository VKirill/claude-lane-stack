{
  "mcpServers": {
    "{{stdio_server_name}}": {
      "command": "{{executable}}",
      "args": ["{{arg1}}", "{{arg2}}"],
      "env": {
        "{{ENV_KEY_1}}": "${{{ENV_KEY_1}}}",
        "{{ENV_KEY_2}}": "${{{ENV_KEY_2}}}"
      }
    },
    "{{http_server_name}}": {
      "type": "http",
      "url": "https://{{host}}/sse",
      "headers": {
        "Authorization": "Bearer ${{{MCP_AUTH_TOKEN}}}"
      }
    }
  }
}
