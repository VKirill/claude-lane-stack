{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-lane-stack.local/schemas/run-v2.schema.json",
  "title": "Claude Lane Stack run contract v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "slug",
    "repo",
    "project_cwd",
    "base_sha",
    "created_at",
    "score",
    "pools",
    "gate",
    "finalize"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "slug": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "repo": {"type": "string", "pattern": "^/"},
    "project_cwd": {"type": "string", "pattern": "^/"},
    "base_sha": {"type": "string", "pattern": "^[0-9a-fA-F]{40,64}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "score": {"type": "integer", "minimum": 0},
    "pools": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "verification"],
      "properties": {
        "provider": {"type": "integer", "minimum": 1, "maximum": 10},
        "verification": {"type": "integer", "minimum": 1, "maximum": 10}
      }
    },
    "gate": {"enum": ["none", "pre-merge"]},
    "finalize": {
      "type": "object",
      "additionalProperties": false,
      "required": ["progress_now", "close_next", "close_open"],
      "properties": {
        "progress_now": {"type": ["string", "null"]},
        "close_next": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "close_open": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    }
  }
}
