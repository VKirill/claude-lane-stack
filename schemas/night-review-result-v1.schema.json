{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-lane-stack.local/schemas/night-review-result-v1.schema.json",
  "title": "Typed Codex night review result v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "chunk_id", "verdict", "findings"],
  "properties": {
    "schema_version": {"const": 1},
    "chunk_id": {"type": "string", "minLength": 1},
    "verdict": {"enum": ["passed", "failed"]},
    "findings": {
      "type": "array",
      "items": {"$ref": "#/$defs/findingCandidate"}
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "line", "detail"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "line": {"type": ["integer", "null"], "minimum": 1},
        "detail": {"type": "string", "minLength": 1}
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "timeout_sec"],
      "properties": {
        "command": {"type": "string", "minLength": 1},
        "timeout_sec": {"type": "integer", "minimum": 1, "maximum": 7200}
      }
    },
    "findingCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "title",
        "summary",
        "actionable",
        "evidence",
        "scope",
        "verification"
      ],
      "properties": {
        "severity": {"enum": ["P0", "P1", "P2", "P3"]},
        "title": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "actionable": {"type": "boolean"},
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/evidence"}
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owns_paths", "never_touch"],
          "properties": {
            "owns_paths": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            },
            "never_touch": {"$ref": "#/$defs/stringList"}
          }
        },
        "verification": {
          "type": "array",
          "items": {"$ref": "#/$defs/verification"}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"actionable": {"const": true}}},
          "then": {"properties": {"verification": {"minItems": 1}}}
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {"properties": {"verdict": {"const": "failed"}}},
      "then": {"properties": {"findings": {"minItems": 1}}}
    }
  ]
}
