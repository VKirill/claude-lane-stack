{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-lane-stack.local/schemas/finding-v1.schema.json",
  "title": "Canonical night review finding v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fingerprint",
    "source_sha",
    "source_task",
    "source_attempt",
    "source_chunk",
    "severity",
    "title",
    "summary",
    "actionable",
    "evidence",
    "scope",
    "verification",
    "status",
    "first_seen",
    "last_seen"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_sha": {
      "anyOf": [
        {"type": "string", "pattern": "^[0-9a-fA-F]{40,64}$"},
        {"type": "null"}
      ]
    },
    "source_task": {"type": ["string", "null"]},
    "source_attempt": {
      "anyOf": [{"type": "integer", "minimum": 1}, {"type": "null"}]
    },
    "source_chunk": {"type": "string", "minLength": 1},
    "severity": {"enum": ["P0", "P1", "P2", "P3"]},
    "title": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1},
    "actionable": {"type": "boolean"},
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "line", "detail"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "line": {"type": ["integer", "null"], "minimum": 1},
          "detail": {"type": "string", "minLength": 1}
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owns_paths", "never_touch"],
      "properties": {
        "owns_paths": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "never_touch": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "timeout_sec"],
        "properties": {
          "command": {"type": "string", "minLength": 1},
          "timeout_sec": {"type": "integer", "minimum": 1, "maximum": 7200}
        }
      }
    },
    "status": {"enum": ["open", "needs_human", "in_progress", "fixed", "dismissed"]},
    "first_seen": {"type": "string", "format": "date-time"},
    "last_seen": {"type": "string", "format": "date-time"},
    "closure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "run", "acceptance", "review", "closed_at"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1},
        "run": {"type": "string", "minLength": 1},
        "acceptance": {"type": "string", "minLength": 1},
        "review": {"type": "string", "minLength": 1},
        "commit_sha": {
          "anyOf": [
            {"type": "string", "pattern": "^[0-9a-fA-F]{40,64}$"},
            {"type": "null"}
          ]
        },
        "closed_at": {"type": "string", "format": "date-time"}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"actionable": {"const": true}}},
      "then": {"properties": {"verification": {"minItems": 1}}}
    },
    {
      "if": {"properties": {"status": {"const": "fixed"}}},
      "then": {"required": ["closure"]}
    }
  ]
}
