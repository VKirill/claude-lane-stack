#!/usr/bin/env python3
"""Verify task changes stay inside owns_paths; never_touch clean.

On main/master: uncommitted-only (dirty tree is common).
On feature/worktree branch: merge-base(main)...HEAD + uncommitted.
"""
from __future__ import annotations

import argparse
import fnmatch
import hashlib
import json
import os
import re
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

try:
    import yaml  # type: ignore
except ImportError:
    yaml = None

IGNORE_PREFIXES = (
    ".agents/",
    ".repowise/",
    ".worktrees/",
    ".claude/worktrees/",
    "node_modules/",
    ".git/",
)
SAFE_NAME = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$")


class GitCommandError(RuntimeError):
    pass


def load_task(path: Path) -> dict:
    text = path.read_text(encoding="utf-8", errors="replace")
    if yaml:
        try:
            data = yaml.safe_load(text) or {}
            if isinstance(data, dict):
                return data
        except Exception:
            pass
    data: dict = {}
    m = re.search(r"^project_cwd:\s*[\"']?([^\"'\n]+)", text, re.M)
    if m:
        data["project_cwd"] = m.group(1).strip()
    return data


def match_any(path: str, patterns: list) -> bool:
    path = path.lstrip("./")
    for pat in patterns:
        pat = str(pat).strip().strip('"').strip("'")
        if not pat:
            continue
        if pat.endswith("/**"):
            prefix = pat[:-3].rstrip("/")
            if path == prefix or path.startswith(prefix + "/"):
                return True
        if fnmatch.fnmatch(path, pat):
            return True
        if path == pat or path.startswith(pat.rstrip("/") + "/"):
            return True
    return False


def run_git(cwd: Path, *args: str) -> str:
    try:
        result = subprocess.run(
            ["git", *args],
            cwd=str(cwd),
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )
    except OSError as exc:
        raise GitCommandError(f"cannot run git {' '.join(args)}: {exc}") from exc
    if result.returncode != 0:
        detail = result.stderr.strip() or f"exit {result.returncode}"
        raise GitCommandError(f"git {' '.join(args)} failed: {detail}")
    return result.stdout


def main_ref(cwd: Path) -> str:
    for ref in ("main", "master"):
        try:
            run_git(cwd, "rev-parse", "--verify", ref)
        except GitCommandError:
            continue
        else:
            return ref
    run_git(cwd, "rev-parse", "--verify", "HEAD")
    return "HEAD"


def filter_noise(files: list[str]) -> list[str]:
    out = []
    for f in files:
        if any(f.startswith(p) for p in IGNORE_PREFIXES):
            continue
        out.append(f)
    return sorted(set(out))


def uncommitted(cwd: Path) -> list[str]:
    files: list[str] = []
    for cmd in (
        ["diff", "--name-only", "HEAD"],
        ["diff", "--name-only", "--cached"],
        ["ls-files", "--others", "--exclude-standard"],
    ):
        for line in run_git(cwd, *cmd).splitlines():
            if line.strip():
                files.append(line.strip())
    return filter_noise(files)


def branch_changes(cwd: Path, base: str) -> list[str]:
    files: list[str] = []
    mb = run_git(cwd, "merge-base", base, "HEAD").strip()
    spec = f"{mb}...HEAD" if mb else f"{base}...HEAD"
    for line in run_git(cwd, "diff", "--name-only", spec).splitlines():
        if line.strip():
            files.append(line.strip())
    files.extend(uncommitted(cwd))
    return filter_noise(files)


def evaluate_details(changed: list[str], owns: list, never: list) -> dict:
    violations, never_hits = [], []
    for f in changed:
        if match_any(f, never):
            never_hits.append(f)
        elif owns and not match_any(f, owns):
            violations.append(f)
    return {
        "changed_files": changed,
        "owns_paths": owns,
        "never_touch": never,
        "violations": violations,
        "never_touch_hits": never_hits,
        "status": "passed" if owns and not violations and not never_hits else ("skipped" if not owns else "failed"),
    }


def print_evaluation(details: dict) -> int:
    changed = details["changed_files"]
    owns = details["owns_paths"]
    violations = details["violations"]
    never_hits = details["never_touch_hits"]
    if not owns:
        print("WARN: no owns_paths/files — skip strict check")
        return 0
    if not changed:
        print("OK: no changed files to check")
        return 0

    if never_hits:
        print("FAIL never_touch:")
        for f in never_hits:
            print(f"  {f}")
    if violations:
        print("FAIL outside owns_paths:")
        for f in violations[:40]:
            print(f"  {f}")
        if len(violations) > 40:
            print(f"  ... +{len(violations) - 40} more")
        print("owns_paths:")
        for p in owns:
            print(f"  - {p}")
    if never_hits or violations:
        return 1
    print(f"OK: {len(changed)} changed file(s) within owns_paths")
    for f in changed[:30]:
        print(f"  {f}")
    return 0


def receipt_path_for(task_path: Path, task_id: str) -> Path | None:
    if task_path.parent.name != "tasks":
        return None
    run_dir = task_path.parent.parent
    if run_dir.parent.name != "runs" or run_dir.parent.parent.name != ".agents":
        return None
    return run_dir / "artifacts" / task_id / "owns-check.json"


def write_receipt(path: Path, payload: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temp = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    temp.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    os.replace(temp, path)


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("task_file")
    ap.add_argument("--cwd", default="")
    ap.add_argument("--base", default="")
    ap.add_argument("--uncommitted-only", action="store_true")
    args = ap.parse_args()

    task_path = Path(args.task_file).resolve()
    data = load_task(task_path)
    task_id = str(data.get("id") or task_path.stem.split("-")[0])
    if not SAFE_NAME.fullmatch(task_id) or task_id in {".", ".."}:
        print(f"FAIL: invalid task id: {task_id!r}", file=sys.stderr)
        return 2
    owns = data.get("owns_paths") or data.get("files") or []
    never = data.get("never_touch") or []
    if isinstance(owns, str):
        owns = [owns]
    if isinstance(never, str):
        never = [never]
    owns, never = list(owns or []), list(never or [])

    cwd = Path(args.cwd or data.get("project_cwd") or ".").resolve()
    mode = "git inspection failed"
    try:
        branch = run_git(cwd, "rev-parse", "--abbrev-ref", "HEAD").strip()
        if args.uncommitted_only or (branch in ("main", "master") and not args.base):
            mode = f"uncommitted-only on {branch}"
            changed = uncommitted(cwd)
        else:
            base = args.base or main_ref(cwd)
            mode = f"vs {base}...HEAD + uncommitted on {branch}"
            changed = branch_changes(cwd, base)
        print(f"(mode: {mode})")
        details = evaluate_details(changed, owns, never)
        exit_code = print_evaluation(details)
    except GitCommandError as exc:
        details = {
            "changed_files": [],
            "owns_paths": owns,
            "never_touch": never,
            "violations": [],
            "never_touch_hits": [],
            "status": "failed",
            "error": str(exc),
        }
        exit_code = 2
        print(f"FAIL: {exc}", file=sys.stderr)
    receipt_path = receipt_path_for(task_path, task_id)
    if receipt_path is not None:
        receipt = {
            "schema_version": 2,
            "task_id": task_id,
            "task_sha256": hashlib.sha256(task_path.read_bytes()).hexdigest(),
            "checked_at": datetime.now(timezone.utc).isoformat(),
            "cwd": str(cwd),
            "mode": mode,
            **details,
            "exit_code": exit_code,
        }
        write_receipt(receipt_path, receipt)
        print(f"receipt: {receipt_path}")
    return exit_code


if __name__ == "__main__":
    sys.exit(main())
