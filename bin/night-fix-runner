#!/usr/bin/env python3
"""Resume and verify a generated night-fix run deterministically."""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


BIN_DIR = Path(__file__).resolve().parent
if str(BIN_DIR) not in sys.path:
    sys.path.insert(0, str(BIN_DIR))

from verification_safety import verification_error


ROOT = Path(__file__).resolve().parents[1]
LANE_CTL = ROOT / "bin" / "lane-ctl"
CHECK_OWNS = ROOT / "bin" / "check-owns-paths"
RUN_VALIDATE = ROOT / "bin" / "run-validate"
REVIEW_ENGINE = ROOT / "bin" / "night-review-engine"
WT_MERGE = ROOT / "bin" / "wt-merge-main"
STATE_NAME = "night-fix-state.json"
FINDING_INTERFACE = re.compile(r"^source_finding_id: ([0-9a-f]{64})$")
FINDING_CONTROL_INTERFACE = re.compile(
    r"^source_finding_control_sha256: ([0-9a-f]{64})$"
)
RUNNABLE_FINDING_STATUSES = frozenset({"open", "in_progress"})
COMMIT_OID = re.compile(r"^[0-9a-f]{40}(?:[0-9a-f]{24})?$")


class RunnerError(RuntimeError):
    pass


def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat()


def load_yaml(path: Path, label: str) -> dict[str, Any]:
    try:
        import yaml
    except ImportError as exc:
        raise RunnerError("PyYAML is required for the night-fix runner") from exc
    try:
        value = yaml.safe_load(path.read_text(encoding="utf-8"))
    except OSError as exc:
        raise RunnerError(f"cannot read {label} {path}: {exc}") from exc
    except yaml.YAMLError as exc:
        raise RunnerError(f"invalid YAML in {label} {path}: {exc}") from exc
    if not isinstance(value, dict):
        raise RunnerError(f"{label} must be a mapping: {path}")
    return value


def load_json(path: Path, label: str) -> dict[str, Any]:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except OSError as exc:
        raise RunnerError(f"cannot read {label} {path}: {exc}") from exc
    except json.JSONDecodeError as exc:
        raise RunnerError(f"invalid JSON in {label} {path}: {exc}") from exc
    if not isinstance(value, dict):
        raise RunnerError(f"{label} must be a JSON object: {path}")
    return value


def atomic_json(path: Path, value: object) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temporary = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    try:
        temporary.write_text(
            json.dumps(value, indent=2, sort_keys=True) + "\n", encoding="utf-8"
        )
        os.replace(temporary, path)
    finally:
        temporary.unlink(missing_ok=True)


def run_command(
    argv: list[str],
    *,
    cwd: Path | None = None,
    timeout: int = 7200,
    check: bool = True,
) -> subprocess.CompletedProcess[str]:
    try:
        result = subprocess.run(
            argv,
            cwd=cwd,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
            timeout=timeout,
        )
    except (OSError, subprocess.TimeoutExpired) as exc:
        raise RunnerError(f"cannot complete {argv[0]}: {exc}") from exc
    if check and result.returncode != 0:
        detail = result.stderr.strip() or result.stdout.strip() or f"exit {result.returncode}"
        raise RunnerError(f"{' '.join(argv[:4])}: {detail}")
    return result


def auto_merge_enabled(policy: dict[str, Any], *, requested: bool) -> bool:
    return requested and policy.get("auto_merge") is True


def read_policy(repo: Path) -> tuple[dict[str, Any], set[str]]:
    path = repo / ".agents" / "night-shift.yaml"
    if not path.is_file():
        return {}, set()
    policy = load_yaml(path, "night-shift policy")
    if set(policy) - {"auto_merge", "verification_executables"}:
        unknown = ", ".join(sorted(set(policy) - {"auto_merge", "verification_executables"}))
        raise RunnerError(f"unsupported night-shift policy keys: {unknown}")
    if "auto_merge" in policy and not isinstance(policy["auto_merge"], bool):
        raise RunnerError("night-shift auto_merge must be boolean")
    extra = policy.get("verification_executables", [])
    if not isinstance(extra, list) or not all(
        isinstance(item, str) and item and "/" not in item for item in extra
    ):
        raise RunnerError("verification_executables must be executable basenames")
    return policy, set(extra)


def finding_id(task: dict[str, Any]) -> str | None:
    for value in task.get("interfaces", []):
        if isinstance(value, str):
            match = FINDING_INTERFACE.fullmatch(value)
            if match:
                return match.group(1)
    return None


def finding_control_sha256(task: dict[str, Any]) -> str | None:
    for value in task.get("interfaces", []):
        if isinstance(value, str):
            match = FINDING_CONTROL_INTERFACE.fullmatch(value)
            if match:
                return match.group(1)
    return None


def control_digest(value: dict[str, Any]) -> str:
    encoded = json.dumps(value, sort_keys=True, separators=(",", ":")).encode()
    return hashlib.sha256(encoded).hexdigest()


def task_finding_control_digest(task: dict[str, Any], fingerprint: str) -> str:
    verification = []
    for check in task.get("verification", []):
        if not isinstance(check, dict):
            raise RunnerError("task verification control must contain objects")
        verification.append(
            {"command": check.get("command"), "timeout_sec": check.get("timeout_sec")}
        )
    return control_digest(
        {
            "fingerprint": fingerprint,
            "actionable": True,
            "scope": {
                "owns_paths": task.get("owns_paths"),
                "never_touch": task.get("never_touch"),
            },
            "verification": verification,
        }
    )


def canonical_finding_control_digest(finding: dict[str, Any]) -> str:
    return control_digest(
        {
            "fingerprint": finding.get("fingerprint"),
            "actionable": finding.get("actionable"),
            "scope": finding.get("scope"),
            "verification": finding.get("verification"),
        }
    )


def validate_task_finding(repo: Path, task: dict[str, Any]) -> dict[str, Any]:
    task_id = str(task["id"])
    fingerprint = task.get("finding_id")
    declared_control = task.get("finding_control_sha256")
    if not isinstance(fingerprint, str) or not fingerprint:
        raise RunnerError(f"task {task_id} is not bound to a canonical finding")
    if not isinstance(declared_control, str) or not declared_control:
        raise RunnerError(f"task {task_id} has no canonical finding control digest")

    contract = load_yaml(Path(task["path"]), "task contract")
    if finding_id(contract) != fingerprint:
        raise RunnerError(f"task {task_id} source finding identity changed")
    interface_control = finding_control_sha256(contract)
    task_control = task_finding_control_digest(contract, fingerprint)
    if interface_control != declared_control or task_control != declared_control:
        raise RunnerError(f"task {task_id} canonical finding control digest changed")

    path = repo / ".agents" / "findings" / f"{fingerprint}.json"
    if not path.is_file():
        raise RunnerError(f"source finding is missing for task {task_id}: {fingerprint}")
    finding = load_json(path, "source finding")
    if finding.get("fingerprint") != fingerprint:
        raise RunnerError(f"task {task_id} canonical finding identity changed")
    if finding.get("status") not in RUNNABLE_FINDING_STATUSES:
        raise RunnerError(
            f"task {task_id} source finding is not runnable: {finding.get('status')}"
        )
    if finding.get("actionable") is not True:
        raise RunnerError(f"task {task_id} source finding is not actionable")
    expected_scope = {
        "owns_paths": contract.get("owns_paths"),
        "never_touch": contract.get("never_touch"),
    }
    if finding.get("scope") != expected_scope:
        raise RunnerError(f"task {task_id} source finding scope changed")
    expected_verification = [
        {"command": check.get("command"), "timeout_sec": check.get("timeout_sec")}
        for check in contract.get("verification", [])
        if isinstance(check, dict)
    ]
    if finding.get("verification") != expected_verification:
        raise RunnerError(f"task {task_id} source finding verification changed")
    if canonical_finding_control_digest(finding) != declared_control:
        raise RunnerError(f"task {task_id} canonical finding control digest changed")
    return finding


def build_plan(
    repo: Path, run_dir: Path, *, extra_executables: set[str]
) -> dict[str, Any]:
    repo = repo.expanduser().resolve()
    run_dir = run_dir.expanduser().resolve()
    if not repo.is_dir() or not (repo / ".git").exists():
        raise RunnerError(f"repo is not a git checkout: {repo}")
    if run_dir.parent != repo / ".agents" / "runs":
        raise RunnerError("run-dir must be inside repo/.agents/runs")
    run = load_yaml(run_dir / "run.yaml", "run contract")
    metadata = load_yaml(run_dir / "worktree.json", "worktree metadata")
    raw_worktree = metadata.get("path")
    if not isinstance(raw_worktree, str):
        raise RunnerError("worktree metadata path is missing")
    worktree = Path(raw_worktree).expanduser().resolve()
    expected_worktree = (repo / ".worktrees" / run_dir.name).resolve()
    if worktree != expected_worktree or not worktree.is_dir():
        raise RunnerError(f"night fix worktree must be {expected_worktree}")
    if metadata.get("repo") != str(repo):
        raise RunnerError("worktree metadata repo does not match target repo")
    if metadata.get("branch") != f"agent/{run_dir.name}":
        raise RunnerError("worktree metadata branch does not match run slug")
    if Path(str(run.get("repo", ""))).resolve() != repo:
        raise RunnerError("run repo does not match target repo")
    if Path(str(run.get("project_cwd", ""))).resolve() != worktree:
        raise RunnerError("run project_cwd does not match worktree")
    if run.get("gate") != "pre-merge":
        raise RunnerError("night fix run must use gate: pre-merge")

    tasks: list[dict[str, Any]] = []
    seen: set[str] = set()
    for task_path in sorted((run_dir / "tasks").glob("*.yaml")):
        task = load_yaml(task_path, "task contract")
        task_id = task.get("id")
        if not isinstance(task_id, str) or not task_id or task_id in seen:
            raise RunnerError(f"invalid or duplicate task id in {task_path}")
        seen.add(task_id)
        if task.get("schema_version") != 2 or task.get("lane") not in {"agy", "grok"}:
            raise RunnerError(f"night fix task {task_id} must be schema v2 lane agy/grok")
        if Path(str(task.get("project_cwd", ""))).resolve() != worktree:
            raise RunnerError(f"task {task_id} project_cwd does not match worktree")
        verification = task.get("verification")
        if task.get("verify") not in {"smoke", "tests"} or not isinstance(
            verification, list
        ) or not verification:
            raise RunnerError(f"task {task_id} requires non-empty smoke/tests verification")
        validation_error: str | None = None
        for index, entry in enumerate(verification):
            if not isinstance(entry, dict):
                raise RunnerError(f"task {task_id} verification[{index}] is not an object")
            if Path(str(entry.get("cwd", ""))).resolve() != worktree:
                raise RunnerError(f"task {task_id} verification[{index}] cwd is not worktree")
            error = verification_error(str(entry.get("command", "")), extra_executables)
            if error and validation_error is None:
                validation_error = f"verification[{index}]: {error}"
        tasks.append(
            {
                "id": task_id,
                "path": str(task_path),
                "task_sha256": hashlib.sha256(task_path.read_bytes()).hexdigest(),
                "risk": task.get("risk"),
                "depends_on": list(task.get("depends_on", [])),
                "finding_id": finding_id(task),
                "finding_control_sha256": finding_control_sha256(task),
                "review_required": True,
                "validation_error": validation_error,
            }
        )
    if not tasks:
        raise RunnerError(f"night fix run has no tasks: {run_dir}")
    return {
        "schema_version": 1,
        "repo": str(repo),
        "run_dir": str(run_dir),
        "slug": run_dir.name,
        "worktree": str(worktree),
        "tasks": tasks,
    }


def state_path(run_dir: Path) -> Path:
    return run_dir / STATE_NAME


def load_or_create_state(repo: Path, plan: dict[str, Any]) -> dict[str, Any]:
    path = state_path(Path(plan["run_dir"]))
    if path.is_file():
        state = load_json(path, "night fix state")
        for key in ("repo", "run_dir", "slug", "worktree"):
            if state.get(key) != plan.get(key):
                raise RunnerError(f"existing night fix state {key} does not match this run")
        if not isinstance(state.get("tasks"), dict):
            raise RunnerError("night fix state tasks must be an object")
        planned = {task["id"]: task for task in plan["tasks"]}
        recorded = state["tasks"]
        removed = sorted(set(recorded) - set(planned))
        if removed:
            raise RunnerError(
                "existing night fix state contains removed tasks: " + ", ".join(removed)
            )
        identity_fields = (
            "task_sha256",
            "finding_id",
            "finding_control_sha256",
        )
        for task_id in sorted(set(recorded) & set(planned)):
            if any(
                recorded[task_id].get(field) != planned[task_id].get(field)
                for field in identity_fields
            ):
                raise RunnerError(
                    f"existing night fix state task identity changed: {task_id}"
                )
        additions = [task for task in plan["tasks"] if task["id"] not in recorded]
        if not additions:
            return state
        reconciled = json.loads(json.dumps(state))
        for task in additions:
            reconciled["tasks"][task["id"]] = new_task_state(task)
        reconciled["status"] = "running"
        save_state(repo, reconciled)
        return reconciled
    now = utc_now()
    state = {
        "schema_version": 1,
        "repo": plan["repo"],
        "run_dir": plan["run_dir"],
        "slug": plan["slug"],
        "worktree": plan["worktree"],
        "status": "running",
        "started_at": now,
        "updated_at": now,
        "tasks": {
            task["id"]: new_task_state(task)
            for task in plan["tasks"]
        },
    }
    save_state(repo, state)
    return state


def new_task_state(task: dict[str, Any]) -> dict[str, Any]:
    return {
        "stage": "pending",
        "attempts": 0,
        "finding_id": task.get("finding_id"),
        "finding_control_sha256": task.get("finding_control_sha256"),
        "task_sha256": task.get("task_sha256"),
    }


def save_state(repo: Path, state: dict[str, Any]) -> None:
    state["updated_at"] = utc_now()
    path = state_path(Path(state["run_dir"]))
    atomic_json(path, state)
    atomic_json(
        repo / ".agents" / "night-fix-current.json",
        {
            "schema_version": 1,
            "run_dir": state["run_dir"],
            "state": str(path),
            "status": state["status"],
            "updated_at": state["updated_at"],
        },
    )


def completed_merge_receipt(
    repo: Path, run_dir: Path, state: dict[str, Any]
) -> dict[str, Any] | None:
    path = run_dir / "merge.json"
    if not path.is_file():
        return None
    receipt = load_json(path, "merge receipt")
    if receipt.get("completed_at") is None:
        return None
    expected_identity = {
        "schema_version": 2,
        "repo": str(repo),
        "run": run_dir.name,
        "branch": f"agent/{run_dir.name}",
    }
    for field, expected in expected_identity.items():
        if receipt.get(field) != expected:
            raise RunnerError(f"completed merge receipt {field} does not match run")
    if not isinstance(receipt.get("completed_at"), str) or not receipt["completed_at"]:
        raise RunnerError("completed merge receipt has no completion timestamp")
    for field in ("source_commit", "merge_commit", "published_commit"):
        value = receipt.get(field)
        if not isinstance(value, str) or not COMMIT_OID.fullmatch(value):
            raise RunnerError(f"completed merge receipt {field} is invalid")
        exists = run_command(
            ["git", "cat-file", "-e", f"{value}^{{commit}}"],
            cwd=repo,
            timeout=60,
            check=False,
        )
        if exists.returncode != 0:
            raise RunnerError(f"completed merge receipt {field} is missing from Git")
    published = receipt["published_commit"]
    ancestor = run_command(
        ["git", "merge-base", "--is-ancestor", published, "HEAD"],
        cwd=repo,
        timeout=60,
        check=False,
    )
    if ancestor.returncode != 0:
        raise RunnerError("completed merge receipt is not published in current HEAD")
    finalize = receipt.get("finalize")
    if not isinstance(finalize, dict) or finalize.get("status") != "complete":
        raise RunnerError("completed merge receipt finalize step is not complete")
    finalize_receipt = finalize.get("receipt")
    if (
        not isinstance(finalize_receipt, str)
        or Path(finalize_receipt).resolve() != (run_dir / "finalize.json").resolve()
        or not (run_dir / "finalize.json").is_file()
    ):
        raise RunnerError("completed merge receipt finalize identity is invalid")
    remote = receipt.get("remote")
    if not isinstance(remote, dict):
        raise RunnerError("completed merge receipt remote status is invalid")
    remote_name = remote.get("name")
    if remote_name is None:
        remote_complete = (
            remote.get("attempted") is False
            and remote.get("pushed") is False
            and remote.get("sha") is None
            and remote.get("error") is None
        )
    else:
        remote_complete = (
            isinstance(remote_name, str)
            and bool(remote_name)
            and remote.get("attempted") is True
            and remote.get("pushed") is True
            and remote.get("sha") == published
            and remote.get("error") is None
        )
    if not remote_complete:
        raise RunnerError("completed merge receipt remote publication is incomplete")

    tasks = state.get("tasks")
    accepted_tasks = receipt.get("accepted_tasks")
    if not isinstance(tasks, dict) or not tasks or not isinstance(accepted_tasks, list):
        raise RunnerError("completed merge receipt task set is invalid")
    accepted_by_id = {
        item.get("task_id"): item
        for item in accepted_tasks
        if isinstance(item, dict) and isinstance(item.get("task_id"), str)
    }
    if set(accepted_by_id) != set(tasks):
        raise RunnerError("completed merge receipt task set does not match runner state")
    for task_id, task_state in tasks.items():
        accepted = accepted_by_id[task_id]
        if (
            not isinstance(task_state, dict)
            or task_state.get("stage") != "accepted"
            or accepted.get("accepted") is not True
            or accepted.get("task_sha256") != task_state.get("task_sha256")
            or accepted.get("verification") != "passed"
            or accepted.get("review") not in {"passed", "not_required"}
        ):
            raise RunnerError(
                f"completed merge receipt task {task_id} is not exactly accepted"
            )
    return receipt


def reconcile_completed_merge(
    repo: Path, run_dir: Path, *, mutate: bool
) -> dict[str, Any] | None:
    path = state_path(run_dir)
    if not path.is_file():
        if (run_dir / "merge.json").is_file():
            raise RunnerError("merge receipt exists without night-fix runner state")
        return None
    state = load_json(path, "night fix state")
    for field, expected in (
        ("repo", str(repo)),
        ("run_dir", str(run_dir)),
        ("slug", run_dir.name),
    ):
        if state.get(field) != expected:
            raise RunnerError(f"night fix state {field} does not match merge run")
    receipt = completed_merge_receipt(repo, run_dir, state)
    if receipt is None:
        return None
    if mutate:
        state["status"] = "merged"
        state["merged_at"] = receipt["completed_at"]
        state["published_commit"] = receipt["published_commit"]
        save_state(repo, state)
    return receipt


def set_stage(
    repo: Path,
    state: dict[str, Any],
    task_id: str,
    stage: str,
    **fields: object,
) -> None:
    task_state = state["tasks"][task_id]
    task_state["stage"] = stage
    task_state.update(fields)
    save_state(repo, state)


def lane_status(run_dir: Path, task_id: str) -> dict[str, Any]:
    result = run_command(
        [str(LANE_CTL), "status", "--run-dir", str(run_dir), "--task-id", task_id, "--json"],
        timeout=60,
    )
    try:
        value = json.loads(result.stdout)
    except json.JSONDecodeError as exc:
        raise RunnerError(f"invalid lane status for {task_id}: {exc}") from exc
    if not isinstance(value, dict):
        raise RunnerError(f"lane status for {task_id} is not an object")
    return value


def wait_for_provider(
    run_dir: Path,
    task_id: str,
    *,
    poll_interval: float,
    timeout: int,
) -> dict[str, Any]:
    deadline = time.monotonic() + timeout
    while True:
        status = lane_status(run_dir, task_id)
        if status.get("status") not in {"running", "launching", "unknown"}:
            return status
        if time.monotonic() >= deadline:
            run_command(
                [str(LANE_CTL), "cancel", "--run-dir", str(run_dir), "--task-id", task_id],
                timeout=60,
                check=False,
            )
            raise RunnerError(f"provider timeout for task {task_id}")
        time.sleep(poll_interval)


def acceptance_is_valid(
    run_dir: Path, task_id: str, task_sha256: str | None = None
) -> bool:
    path = run_dir / "artifacts" / task_id / "acceptance.json"
    if not path.is_file():
        return False
    try:
        receipt = load_json(path, "acceptance receipt")
    except RunnerError:
        return False
    return (
        receipt.get("accepted") is True
        and receipt.get("task_id") == task_id
        and (
            task_sha256 is None
            or receipt.get("task_sha256") == task_sha256
        )
    )


def git_head(worktree: Path) -> str:
    return run_command(["git", "rev-parse", "HEAD"], cwd=worktree, timeout=60).stdout.strip()


def worktree_snapshot(worktree: Path) -> str:
    digest = hashlib.sha256()
    digest.update(git_head(worktree).encode())
    tracked_diff = run_command(
        ["git", "diff", "--no-ext-diff", "--binary", "HEAD", "--"],
        cwd=worktree,
        timeout=120,
    ).stdout
    digest.update(b"\0tracked\0")
    digest.update(tracked_diff.encode())
    untracked = run_command(
        ["git", "ls-files", "--others", "--exclude-standard", "-z"],
        cwd=worktree,
        timeout=60,
    ).stdout
    for relative in sorted(path for path in untracked.split("\0") if path):
        blob = run_command(
            ["git", "hash-object", "--", relative], cwd=worktree, timeout=60
        ).stdout.strip()
        digest.update(b"\0untracked\0")
        digest.update(relative.encode())
        digest.update(b"\0")
        digest.update(blob.encode())
    return digest.hexdigest()


def commit_task(
    worktree: Path, task_id: str, *, expected_snapshot: str | None = None
) -> str | None:
    pending = prepare_task_commit(
        worktree, task_id, expected_snapshot=expected_snapshot
    )
    if pending is None:
        return None
    return apply_task_commit(worktree, task_id, pending)


def prepare_task_commit(
    worktree: Path, task_id: str, *, expected_snapshot: str | None
) -> dict[str, str] | None:
    if expected_snapshot is not None and worktree_snapshot(worktree) != expected_snapshot:
        raise RunnerError(f"task {task_id} worktree changed after review")
    status = run_command(["git", "status", "--porcelain"], cwd=worktree, timeout=60).stdout
    if not status.strip():
        return None
    run_command(["git", "add", "-A"], cwd=worktree, timeout=60)
    if expected_snapshot is not None and worktree_snapshot(worktree) != expected_snapshot:
        raise RunnerError(f"task {task_id} worktree changed after review")
    staged = run_command(
        ["git", "diff", "--cached", "--quiet"], cwd=worktree, timeout=60, check=False
    )
    if staged.returncode == 0:
        return None
    if staged.returncode != 1:
        raise RunnerError(f"cannot inspect staged changes for {task_id}")
    staged_tree = run_command(["git", "write-tree"], cwd=worktree, timeout=60).stdout.strip()
    parent = git_head(worktree)
    commit_sha = run_command(
        [
            "git",
            "-c",
            "user.name=Claude Lane Stack",
            "-c",
            "user.email=claude-lane-stack@localhost",
            "commit-tree",
            staged_tree,
            "-p",
            parent,
            "-m",
            f"fix(night): resolve {task_id}",
        ],
        cwd=worktree,
        timeout=120,
    ).stdout.strip()
    return {"commit_sha": commit_sha, "parent": parent, "tree": staged_tree}


def apply_task_commit(
    worktree: Path, task_id: str, pending: dict[str, Any]
) -> str:
    commit_sha = pending.get("commit_sha")
    parent = pending.get("parent")
    staged_tree = pending.get("tree")
    commit_re = re.compile(r"^[0-9a-f]{40}(?:[0-9a-f]{24})?$")
    if not all(
        isinstance(value, str) and commit_re.fullmatch(value)
        for value in (commit_sha, parent, staged_tree)
    ):
        raise RunnerError(f"task {task_id} pending commit identity is invalid")
    actual_tree = run_command(
        ["git", "rev-parse", f"{commit_sha}^{{tree}}"], cwd=worktree, timeout=60
    ).stdout.strip()
    actual_parent = run_command(
        ["git", "rev-parse", f"{commit_sha}^"], cwd=worktree, timeout=60
    ).stdout.strip()
    if actual_tree != staged_tree or actual_parent != parent:
        raise RunnerError(f"task {task_id} pending commit identity changed")
    current = git_head(worktree)
    if current == parent:
        run_command(
            ["git", "update-ref", "HEAD", commit_sha, parent],
            cwd=worktree,
            timeout=60,
        )
    elif current != commit_sha:
        raise RunnerError(f"task {task_id} branch changed during commit recovery")
    committed_tree = run_command(
        ["git", "rev-parse", "HEAD^{tree}"], cwd=worktree, timeout=60
    ).stdout.strip()
    if committed_tree != staged_tree:
        raise RunnerError(f"task {task_id} committed tree differs from reviewed state")
    if run_command(
        ["git", "status", "--porcelain"], cwd=worktree, timeout=60
    ).stdout.strip():
        raise RunnerError(f"task {task_id} worktree changed during commit recovery")
    return commit_sha


def mark_finding_fixed(
    repo: Path,
    finding: str | None,
    task_id: str,
    run_dir: Path,
    commit_sha: str | None,
) -> None:
    if not finding:
        return
    path = repo / ".agents" / "findings" / f"{finding}.json"
    if not path.is_file():
        raise RunnerError(f"source finding is missing for task {task_id}: {finding}")
    value = load_json(path, "source finding")
    existing_closure = value.get("closure")
    if (
        value.get("status") == "fixed"
        and isinstance(existing_closure, dict)
        and existing_closure.get("task_id") == task_id
    ):
        return
    value["status"] = "fixed"
    value["last_seen"] = utc_now()
    value["closure"] = {
        "task_id": task_id,
        "run": run_dir.name,
        "acceptance": str(run_dir / "artifacts" / task_id / "acceptance.json"),
        "review": str(run_dir / "artifacts" / task_id / "review.json"),
        "commit_sha": commit_sha,
        "closed_at": utc_now(),
    }
    try:
        import jsonschema

        schema = load_json(ROOT / "schemas" / "finding-v1.schema.json", "finding schema")
        jsonschema.Draft202012Validator(
            schema, format_checker=jsonschema.FormatChecker()
        ).validate(value)
    except ImportError as exc:
        raise RunnerError("jsonschema is required to close a finding") from exc
    except jsonschema.ValidationError as exc:
        raise RunnerError(f"fixed finding is invalid: {exc.message}") from exc
    atomic_json(path, value)


def mark_finding_needs_human(
    repo: Path, finding: str | None, task_id: str, reason: str
) -> None:
    if not finding:
        return
    path = repo / ".agents" / "findings" / f"{finding}.json"
    if not path.is_file():
        raise RunnerError(f"source finding is missing for task {task_id}: {finding}")
    value = load_json(path, "source finding")
    value["status"] = "needs_human"
    value["last_seen"] = utc_now()
    atomic_json(path, value)


def finalize_accepted_task(
    repo: Path,
    run_dir: Path,
    worktree: Path,
    task: dict[str, Any],
    state: dict[str, Any],
) -> bool:
    task_id = task["id"]
    task_state = state["tasks"][task_id]
    stored_commit = task_state.get("commit_sha")
    if task_state.get("stage") == "accepted" and isinstance(stored_commit, str):
        mark_finding_fixed(
            repo, task.get("finding_id"), task_id, run_dir, stored_commit
        )
        return True

    pending = task_state.get("pending_commit")
    if pending is not None and not isinstance(pending, dict):
        raise RunnerError(f"task {task_id} pending commit state is invalid")
    if pending is None:
        reviewed_snapshot = task_state.get("reviewed_snapshot")
        if not isinstance(reviewed_snapshot, str):
            raise RunnerError(
                f"accepted task {task_id} has no reviewed worktree snapshot"
            )
        pending = prepare_task_commit(
            worktree, task_id, expected_snapshot=reviewed_snapshot
        )
        if pending is not None:
            set_stage(
                repo,
                state,
                task_id,
                "committing",
                pending_commit=pending,
            )

    commit_sha = (
        apply_task_commit(worktree, task_id, pending)
        if pending is not None
        else git_head(worktree)
    )
    mark_finding_fixed(repo, task.get("finding_id"), task_id, run_dir, commit_sha)
    set_stage(repo, state, task_id, "accepted", commit_sha=commit_sha)
    return True


def process_task(
    repo: Path,
    run_dir: Path,
    worktree: Path,
    task: dict[str, Any],
    state: dict[str, Any],
    *,
    poll_interval: float,
    provider_timeout: int,
    codex_bin: str | None,
    primary_provider: str = "grok",
    provider_bin: str | None = None,
    grok_bin: str | None = None,
) -> bool:
    if provider_bin is None:
        provider_bin = grok_bin
    if grok_bin is not None:
        primary_provider = "grok"
    task_id = task["id"]
    task_file = Path(task["path"])
    task_state = state["tasks"][task_id]
    validation_error = task.get("validation_error")
    if isinstance(validation_error, str) and validation_error:
        mark_finding_needs_human(
            repo, task.get("finding_id"), task_id, validation_error
        )
        set_stage(
            repo,
            state,
            task_id,
            "needs_human",
            error=validation_error,
        )
        return False
    if acceptance_is_valid(run_dir, task_id, task.get("task_sha256")):
        return finalize_accepted_task(repo, run_dir, worktree, task, state)
    for dependency in task["depends_on"]:
        if state["tasks"].get(dependency, {}).get("stage") != "accepted":
            set_stage(repo, state, task_id, "blocked", error=f"dependency not accepted: {dependency}")
            return False

    try:
        validate_task_finding(repo, task)
    except RunnerError as exc:
        try:
            mark_finding_needs_human(
                repo, task.get("finding_id"), task_id, str(exc)
            )
        except RunnerError:
            pass
        set_stage(repo, state, task_id, "blocked", error=str(exc))
        return False

    base_ref = task_state.get("base_ref")
    if not isinstance(base_ref, str):
        base_ref = git_head(worktree)
        task_state["base_ref"] = base_ref
        save_state(repo, state)

    status: dict[str, Any] | None = None
    artifact_state = run_dir / "artifacts" / task_id / "state.json"
    if artifact_state.is_file():
        status = lane_status(run_dir, task_id)
    while True:
        if status is None or status.get("status") == "not_started":
            task_state["attempts"] = max(1, int(task_state.get("attempts", 0)))
            set_stage(repo, state, task_id, "dispatching", attempts=task_state["attempts"])
            start_argv = [
                    str(LANE_CTL),
                    "start",
                    "--run-dir",
                    str(run_dir),
                    "--task-file",
                    str(task_file),
                    "--project-cwd",
                    str(worktree),
                    "--provider",
                    primary_provider,
                ]
            if provider_bin:
                start_argv.extend(["--binary", provider_bin])
            started = run_command(
                start_argv,
                timeout=120,
                check=False,
            )
            if started.returncode != 0 and not artifact_state.is_file():
                raise RunnerError(started.stderr.strip() or f"cannot start task {task_id}")
            set_stage(repo, state, task_id, "provider_running")
            status = wait_for_provider(
                run_dir,
                task_id,
                poll_interval=poll_interval,
                timeout=provider_timeout,
            )
        elif status.get("status") in {"running", "launching", "unknown"}:
            status = wait_for_provider(
                run_dir,
                task_id,
                poll_interval=poll_interval,
                timeout=provider_timeout,
            )

        if status.get("status") in {"awaiting_verification", "verified"}:
            break
        attempt = int(status.get("attempt") or task_state.get("attempts") or 1)
        provider_receipt = status.get("provider")
        if attempt >= 2:
            if (
                attempt == 2
                and isinstance(provider_receipt, dict)
                and provider_receipt.get("name") in {"agy", "grok"}
                and provider_receipt.get("fallback_eligible") is True
            ):
                fallback_argv = [
                    str(LANE_CTL),
                    "fallback",
                    "--run-dir",
                    str(run_dir),
                    "--task-id",
                    task_id,
                ]
                if codex_bin:
                    fallback_argv.extend(["--binary", codex_bin])
                fallback = run_command(
                    fallback_argv,
                    timeout=120,
                    check=False,
                )
                if fallback.returncode != 0:
                    set_stage(
                        repo,
                        state,
                        task_id,
                        "blocked",
                        error=fallback.stderr.strip() or "Codex fallback launch failed",
                    )
                    return False
                task_state["attempts"] = 3
                set_stage(
                    repo,
                    state,
                    task_id,
                    "provider_running",
                    attempts=3,
                    provider="codex",
                    model="gpt-5.6-sol",
                    fallback_from=provider_receipt.get("name"),
                    fallback_failure_class=provider_receipt.get("failure_class"),
                )
                status = wait_for_provider(
                    run_dir,
                    task_id,
                    poll_interval=poll_interval,
                    timeout=provider_timeout,
                )
                continue
            set_stage(
                repo,
                state,
                task_id,
                "blocked",
                error=f"provider failed after bounded attempts: {status.get('status')}",
            )
            return False
        retried = run_command(
            [str(LANE_CTL), "retry", "--run-dir", str(run_dir), "--task-id", task_id],
            timeout=120,
            check=False,
        )
        if retried.returncode != 0:
            set_stage(repo, state, task_id, "blocked", error=retried.stderr.strip())
            return False
        task_state["attempts"] = 2
        set_stage(repo, state, task_id, "provider_running", attempts=2)
        status = wait_for_provider(
            run_dir,
            task_id,
            poll_interval=poll_interval,
            timeout=provider_timeout,
        )

    if status.get("status") != "verified":
        set_stage(repo, state, task_id, "verifying")
        verification = run_command(
            [
                str(LANE_CTL),
                "verify",
                "--run-dir",
                str(run_dir),
                "--task-file",
                str(task_file),
                "--project-cwd",
                str(worktree),
            ],
            timeout=7500,
            check=False,
        )
        if verification.returncode != 0:
            if int(status.get("attempt") or 1) < 2:
                retried = run_command(
                    [str(LANE_CTL), "retry", "--run-dir", str(run_dir), "--task-id", task_id],
                    timeout=120,
                    check=False,
                )
                if retried.returncode == 0:
                    task_state["attempts"] = 2
                    set_stage(repo, state, task_id, "provider_running", attempts=2)
                    return process_task(
                        repo,
                        run_dir,
                        worktree,
                        task,
                        state,
                        poll_interval=poll_interval,
                        provider_timeout=provider_timeout,
                        codex_bin=codex_bin,
                        primary_provider=primary_provider,
                        provider_bin=provider_bin,
                    )
            set_stage(repo, state, task_id, "blocked", error="verification failed")
            return False

    owns = run_command(
        [str(CHECK_OWNS), str(task_file), "--cwd", str(worktree), "--uncommitted-only"],
        timeout=300,
        check=False,
    )
    if owns.returncode != 0:
        set_stage(repo, state, task_id, "blocked", error="ownership check failed")
        return False

    artifact_dir = run_dir / "artifacts" / task_id
    review_path = artifact_dir / "review.json"
    review_argv = [
        str(REVIEW_ENGINE),
        "review-task",
        "--repo",
        str(repo),
        "--run-dir",
        str(run_dir),
        "--task-file",
        str(task_file),
        "--base-ref",
        base_ref,
        "--output",
        str(review_path),
    ]
    if codex_bin:
        review_argv.extend(["--codex-bin", codex_bin])
    reviewed_snapshot = worktree_snapshot(worktree)
    set_stage(repo, state, task_id, "reviewing")
    reviewed = run_command(review_argv, timeout=5400, check=False)
    if reviewed.returncode != 0 or not review_path.is_file():
        set_stage(repo, state, task_id, "blocked", error="fresh Codex re-review failed")
        return False
    review = load_json(review_path, "task re-review")
    if review.get("verdict") != "passed" or review.get("findings") != []:
        set_stage(repo, state, task_id, "blocked", error="fresh Codex re-review found defects")
        return False
    if worktree_snapshot(worktree) != reviewed_snapshot:
        set_stage(repo, state, task_id, "blocked", error="worktree changed during re-review")
        return False

    set_stage(
        repo,
        state,
        task_id,
        "accepting",
        reviewed_snapshot=reviewed_snapshot,
    )
    accepted = run_command(
        [
            str(LANE_CTL),
            "accept",
            "--run-dir",
            str(run_dir),
            "--task-file",
            str(task_file),
            "--project-cwd",
            str(worktree),
        ],
        timeout=120,
        check=False,
    )
    if accepted.returncode != 0 or not acceptance_is_valid(
        run_dir, task_id, task.get("task_sha256")
    ):
        set_stage(repo, state, task_id, "blocked", error="acceptance gate failed")
        return False
    return finalize_accepted_task(repo, run_dir, worktree, task, state)


def run_fix_plan(args: argparse.Namespace) -> int:
    repo = Path(args.repo).expanduser().resolve()
    run_dir = (
        Path(args.run_dir).expanduser().resolve()
        if args.run_dir
        else repo / ".agents" / "runs" / args.slug
    )
    if not repo.is_dir() or not (repo / ".git").exists():
        raise RunnerError(f"repo is not a git checkout: {repo}")
    if run_dir.parent != repo / ".agents" / "runs":
        raise RunnerError("run-dir must be inside repo/.agents/runs")
    recovered = reconcile_completed_merge(repo, run_dir, mutate=not args.dry_run)
    if recovered is not None:
        print(
            json.dumps(
                {
                    "status": "merged",
                    "run_dir": str(run_dir),
                    "published_commit": recovered["published_commit"],
                    "recovered": True,
                },
                sort_keys=True,
            )
        )
        return 0
    policy, extra_executables = read_policy(repo)
    plan = build_plan(repo, run_dir, extra_executables=extra_executables)
    if args.dry_run:
        print(json.dumps({**plan, "auto_merge": auto_merge_enabled(policy, requested=args.auto_merge)}, indent=2))
        return 0

    validation = run_command(
        [str(RUN_VALIDATE), "--run-dir", str(run_dir), "--phase", "pre-dispatch"],
        timeout=120,
        check=False,
    )
    if validation.returncode != 0:
        raise RunnerError(validation.stderr.strip() or "pre-dispatch validation failed")
    state = load_or_create_state(repo, plan)
    failures = 0
    for task in plan["tasks"]:
        try:
            if not process_task(
                repo,
                run_dir,
                Path(plan["worktree"]),
                task,
                state,
                poll_interval=args.poll_interval,
                provider_timeout=args.provider_timeout,
                codex_bin=args.codex_bin,
                primary_provider="grok" if args.grok_bin else args.provider,
                provider_bin=args.provider_bin or args.grok_bin,
            ):
                failures += 1
        except RunnerError as exc:
            failures += 1
            set_stage(repo, state, task["id"], "blocked", error=str(exc))
            print(f"night-fix-runner: task {task['id']}: {exc}", file=sys.stderr)

    projection = run_command(
        [
            str(REVIEW_ENGINE),
            "compile-fixes",
            str(repo),
            "--run-slug",
            plan["slug"],
        ],
        timeout=300,
        check=False,
    )
    if projection.returncode != 0:
        raise RunnerError(projection.stderr.strip() or "cannot refresh finding projections")
    if failures:
        state["status"] = "blocked"
        save_state(repo, state)
        return 1
    state["status"] = "accepted"
    save_state(repo, state)

    if auto_merge_enabled(policy, requested=args.auto_merge):
        validation = run_command(
            [str(RUN_VALIDATE), "--run-dir", str(run_dir), "--phase", "pre-merge"],
            timeout=120,
            check=False,
        )
        if validation.returncode != 0:
            raise RunnerError(validation.stderr.strip() or "pre-merge validation failed")
        state["status"] = "merging"
        state["merge_started_at"] = utc_now()
        save_state(repo, state)
        run_command([str(WT_MERGE), str(repo), plan["slug"]], timeout=1800)
        if reconcile_completed_merge(repo, run_dir, mutate=True) is None:
            raise RunnerError("wt-merge-main returned without a completed merge receipt")
    else:
        print(f"accepted night fixes remain in {plan['worktree']} (auto-merge disabled)")
    return 0


def positive_int(value: str) -> int:
    parsed = int(value)
    if parsed < 1:
        raise argparse.ArgumentTypeError("must be positive")
    return parsed


def nonnegative_float(value: str) -> float:
    parsed = float(value)
    if parsed < 0:
        raise argparse.ArgumentTypeError("must be non-negative")
    return parsed


def parser() -> argparse.ArgumentParser:
    ap = argparse.ArgumentParser(description="resume a generated night fix run")
    ap.add_argument("repo")
    selector = ap.add_mutually_exclusive_group(required=True)
    selector.add_argument("--run-dir")
    selector.add_argument("--slug")
    ap.add_argument("--dry-run", action="store_true")
    ap.add_argument("--auto-merge", action="store_true")
    ap.add_argument("--poll-interval", type=nonnegative_float, default=5.0)
    ap.add_argument("--provider-timeout", type=positive_int, default=7200)
    ap.add_argument("--provider", choices=("agy", "grok"), default="grok")
    ap.add_argument("--provider-bin")
    ap.add_argument("--codex-bin")
    ap.add_argument("--grok-bin", help=argparse.SUPPRESS)
    return ap


def main() -> int:
    args = parser().parse_args()
    try:
        return run_fix_plan(args)
    except (RunnerError, ValueError) as exc:
        print(f"night-fix-runner: {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
