#!/usr/bin/env python3
"""Periodic review of triggered gates.

Reads the append-only gate-event log written by bin/gate_log.py (default
~/.agents/logs/gate-events.jsonl) and summarizes the last N days: per-gate
pass/reject/fail counts, top owns_paths violations, top never_touch hits, top
rejection/failure reasons, and a per-project breakdown. The point is to surface
recurring blocks and false positives so the contracts and gates can be improved.

Usage:
  gate-report                     # last 7 days, markdown
  gate-report --days 14 --json    # last 14 days, machine-readable
  gate-report --project my-app --gate owns-paths
"""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

BIN_DIR = Path(__file__).resolve().parent
if str(BIN_DIR) not in sys.path:
    sys.path.insert(0, str(BIN_DIR))

from gate_log import (  # noqa: E402
    GATE_ORDER,
    STATUS_ORDER,
    aggregate,
    load_events,
    resolve_log_path,
    window_cutoff,
)


def _gate_table(agg: dict) -> list[str]:
    lines = ["| gate | passed | rejected | failed | skipped | total |", "|---|--:|--:|--:|--:|--:|"]
    gates = list(GATE_ORDER) + sorted(g for g in agg["by_gate"] if g not in GATE_ORDER)
    for gate in gates:
        counts = agg["by_gate"].get(gate, {})
        if not counts:
            continue
        total = sum(counts.values())
        cells = [str(counts.get(status, 0)) for status in STATUS_ORDER]
        lines.append(f"| {gate} | " + " | ".join(cells) + f" | {total} |")
    return lines


def _top_lines(counter_pairs: list, limit: int, *, indent: str = "- ") -> list[str]:
    if not counter_pairs:
        return ["- (none)"]
    return [f"{indent}`{value}` — {count}" for value, count in counter_pairs[:limit]]


def render_markdown(agg: dict, meta: dict) -> str:
    lines: list[str] = []
    lines.append(f"# Gate report — last {meta['days']} day(s)")
    lines.append("")
    lines.append(f"- log: `{meta['log_path']}`")
    lines.append(f"- window: {meta['since']} → {meta['until']}")
    if meta.get("project"):
        lines.append(f"- project filter: `{meta['project']}`")
    if meta.get("gate"):
        lines.append(f"- gate filter: `{meta['gate']}`")
    lines.append(f"- total gate evaluations: **{agg['total']}**")
    lines.append(f"- blocking (rejected/failed): **{agg['blocking']}**")
    lines.append("")
    lines.append("## By gate")
    lines.append("")
    if agg["by_gate"]:
        lines.extend(_gate_table(agg))
    else:
        lines.append("_No gate events in this window._")
    lines.append("")
    lines.append("## Top owns_paths violations")
    lines.append("")
    lines.extend(_top_lines(agg["top_violations"], meta["top"]))
    lines.append("")
    lines.append("## Top never_touch hits")
    lines.append("")
    lines.extend(_top_lines(agg["top_never_touch"], meta["top"]))
    lines.append("")
    lines.append("## Top blocking reasons")
    lines.append("")
    lines.extend(_top_lines(agg["top_details"], meta["top"]))
    lines.append("")
    lines.append("## By project")
    lines.append("")
    if agg["by_project"]:
        lines.append("| project | total | blocking |")
        lines.append("|---|--:|--:|")
        ordered = sorted(
            agg["by_project"].items(),
            key=lambda kv: (-kv[1].get("blocking", 0), -kv[1].get("total", 0), kv[0]),
        )
        for project, counts in ordered:
            lines.append(
                f"| `{project}` | {counts.get('total', 0)} | {counts.get('blocking', 0)} |"
            )
    else:
        lines.append("_No projects._")
    lines.append("")
    lines.append(f"## Recent blocking events (last {meta['limit_recent']})")
    lines.append("")
    recent = agg["blocking_recent"][: meta["limit_recent"]]
    if recent:
        for event in recent:
            ts = str(event.get("ts", "?"))
            gate = event.get("gate", "?")
            status = event.get("status", "?")
            run_slug = event.get("run_slug") or "-"
            task_id = event.get("task_id") or "-"
            detail = event.get("detail") or ""
            lines.append(f"- `{ts}` **{gate}/{status}** run=`{run_slug}` task=`{task_id}`")
            if detail:
                lines.append(f"  - {detail}")
    else:
        lines.append("_No blocking events in this window._ 🎉")
    lines.append("")
    lines.append("---")
    lines.append("_gate-report — ~/.agents/bin/gate-report_")
    return "\n".join(lines)


def main() -> int:
    parser = argparse.ArgumentParser(description="summarize triggered gates")
    parser.add_argument("--days", type=int, default=7, help="lookback window (default 7)")
    parser.add_argument("--project", default=None, help="filter by project path or basename")
    parser.add_argument("--gate", default=None, choices=sorted(GATE_ORDER))
    parser.add_argument("--log", default=None, help="gate-event log path override")
    parser.add_argument("--top", type=int, default=15, help="rows per top-N section")
    parser.add_argument("--limit-recent", type=int, default=20, help="recent blocking events")
    parser.add_argument("--json", action="store_true", help="emit machine-readable JSON")
    args = parser.parse_args()

    if args.days < 1:
        print("gate-report: --days must be >= 1", file=sys.stderr)
        return 2

    log_path = resolve_log_path(args.log)
    if log_path is None:
        print("gate-report: gate-event logging is disabled (CLAUDE_LANE_GATE_LOG=off)", file=sys.stderr)
        return 1

    cutoff, until = window_cutoff(args.days)
    events = load_events(
        log_path, cutoff=cutoff, project=args.project, gate=args.gate
    )
    agg = aggregate(events)
    meta = {
        "days": args.days,
        "log_path": str(log_path),
        "since": cutoff.isoformat(),
        "until": until.isoformat(),
        "project": args.project,
        "gate": args.gate,
        "top": args.top,
        "limit_recent": args.limit_recent,
    }

    if args.json:
        print(json.dumps({"meta": meta, "summary": agg}, indent=2, sort_keys=True))
    else:
        print(render_markdown(agg, meta))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
