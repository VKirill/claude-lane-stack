#!/usr/bin/env bash
# Auto-discover active Lane Stack projects and run night-review on them.
set -euo pipefail
export PATH="${HOME}/.agents/bin:${PATH}"

DRY_RUN=()
if [[ "${1:-}" == "--dry-run" ]]; then
  DRY_RUN=("--dry-run")
elif [[ -n "${1:-}" ]]; then
  echo "Usage: night-review-all [--dry-run]" >&2
  exit 1
fi

ROOTS=(
  "$HOME/apps"
  "$HOME/sites"
  "$HOME/tools"
)

is_lane_stack() {
  local d="$1"
  [[ -f "$d/CLAUDE.md" ]] && grep -q 'Claude Lane Stack' "$d/CLAUDE.md" && return 0
  [[ -f "$d/.agents/routing.profile.yaml" ]] && return 0
  [[ -d "$d/.agents/runs" ]] && return 0
  return 1
}

is_active() {
  local proj="$1"
  if [[ -n "$(git -C "$proj" log --since='24 hours ago' --oneline -1 2>/dev/null)" ]]; then
    return 0
  fi
  local today
  today="$(date +%Y-%m-%d)"
  if [[ -d "$proj/.agents/session-log/$today" ]]; then
    return 0
  fi
  return 1
}

total=0
active=0

for root in "${ROOTS[@]}"; do
  [[ -d "$root" ]] || continue
  # depth 2: apps/foo, tools/foo
  while IFS= read -r -d '' gitdir; do
    proj=$(dirname "$gitdir")
    if is_lane_stack "$proj"; then
      total=$((total+1))
      if is_active "$proj"; then
        active=$((active+1))
        echo "==== $proj ===="
        night-review "$proj" "${DRY_RUN[@]}" || echo "WARN: failed $proj"
      else
        echo "skip (idle): $proj"
      fi
    fi
  done < <(find "$root" -maxdepth 3 -type d -name .git -print0 2>/dev/null)
done

echo "Reviewed $active of $total lane-stack projects."
echo "Cron example: 0 3 * * * $HOME/.agents/bin/night-review-all >> $HOME/.agents/logs/night-review.log 2>&1"
