#!/usr/bin/env python3
"""Run a typed writer provider behind the lane control-plane boundary.

Grok uses run-scoped warm-session affinity. Codex is a one-shot fallback that
uses the same report and runtime receipt contract without session reuse.
"""

from __future__ import annotations

import argparse
import fcntl
import hashlib
import json
import os
import re
import select
import shutil
import signal
import stat
import subprocess
import sys
import tempfile
import time
import uuid
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import IO


STATE_VERSION = 1
HARD_MAX_TASKS = 10
DEFAULT_POOL_SIZE = 5
HARD_MAX_POOL = 10
SAFE_NAME = re.compile(r"^[A-Za-z0-9_.-]+$")
GROK_SANDBOX_PROFILE = "off"
CODEX_SANDBOX_PROFILE = "workspace-write"
RUNTIME_SANDBOX_PROFILE = "bubblewrap-workspace"
PROTOCOL_FAILURE_EXIT = 65
MAX_PROVIDER_LOG_BYTES = 1024 * 1024
MAX_REPORT_SCAN_CHARS = 512 * 1024
MAX_REPORT_BYTES = 256 * 1024
MAX_EVENT_NAME = 80
MAX_FAILURE_EVIDENCE_BYTES = 64 * 1024
REPORT_BEGIN = "<<<LANE_REPORT:BEGIN>>>"
REPORT_END = "<<<LANE_REPORT:END>>>"
