def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat()


def load_state(path: Path) -> dict:
    if not path.exists():
        return {"version": STATE_VERSION, "sessions": {}, "history": []}
    try:
        state = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise RuntimeError(f"cannot read session state {path}: {exc}") from exc
    if state.get("version") != STATE_VERSION:
        raise RuntimeError(
            f"unsupported session state version {state.get('version')!r} in {path}"
        )
    state.setdefault("sessions", {})
    state.setdefault("history", [])
    return state


def save_state(path: Path, state: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temp = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    temp.write_text(json.dumps(state, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    os.replace(temp, path)


def lock_file(path: Path, *, nonblocking: bool = False) -> IO[str] | None:
    path.parent.mkdir(parents=True, exist_ok=True)
    handle = path.open("a+", encoding="utf-8")
    flags = fcntl.LOCK_EX | (fcntl.LOCK_NB if nonblocking else 0)
    try:
        fcntl.flock(handle.fileno(), flags)
    except BlockingIOError:
        handle.close()
        return None
    return handle


def unlock_file(handle: IO[str]) -> None:
    fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
    handle.close()


def runtime_lock_dir(run_dir: Path) -> Path:
    digest = hashlib.sha256(str(run_dir.resolve()).encode("utf-8")).hexdigest()[:20]
    configured = os.environ.get("XDG_RUNTIME_DIR")
    roots = []
    if configured:
        roots.append(Path(configured) / "claude-lane-stack")
    roots.append(Path("/tmp") / f"claude-lane-stack-{os.getuid()}")

    errors: list[str] = []
    for root in roots:
        path = root / "session-locks" / digest
        try:
            path.mkdir(parents=True, exist_ok=True)
            root.chmod(0o700)
            path.chmod(0o700)
            probe = path / f".probe-{os.getpid()}"
            probe.touch(exist_ok=False)
            probe.unlink()
            return path
        except OSError as exc:
            errors.append(f"{path}: {exc}")
    raise RuntimeError("no writable session lock directory: " + "; ".join(errors))


def rotation_reason(record: dict | None, *, cwd: str, model: str, max_tasks: int) -> str | None:
    if not record:
        return None
    if record.get("provider") == "codex":
        return "ephemeral_provider"
    if record.get("invalid"):
        return record.get("invalid_reason") or "invalid"
    if record.get("status") == "running":
        return "stale_running"
    if not record.get("session_id"):
        return "missing_session_id"
    if record.get("cwd") != cwd:
        return "cwd_changed"
    if record.get("model") != model:
        return "model_changed"
    if record.get("sandbox") != RUNTIME_SANDBOX_PROFILE:
        return "sandbox_changed"
    success_count = int(record.get("success_count", len(record.get("tasks", []))))
    if success_count >= max_tasks:
        return "task_limit"
    return None


@dataclass
class Lease:
    key: str
    slot: int
    handle: IO[str]
    record: dict
    is_new: bool


class LaneInterrupted(Exception):
    def __init__(self, signum: int) -> None:
        super().__init__(f"interrupted by signal {signum}")
        self.signum = signum


@dataclass
class StreamResult:
    provider_exit_code: int
    exit_code: int
    session_id: str | None
    stop_reason: str | None
    usage: dict | None
    model_usage: dict | None
    num_turns: int | None
    total_cost_usd: int | float | None
    total_cost_usd_ticks: int | None
    cost_is_partial: bool | None
    usage_is_incomplete: bool | None
    protocol_error: str | None
    report_sha256: str | None
    log_truncated: bool
    stderr_bytes: int
    failure_class: str | None
    failure_retryable: bool
    fallback_eligible: bool
    failure_source: str | None
    failure_evidence_sha256: str | None


def acquire_lease(
    *,
    run_dir: Path,
    provider: str,
    role: str,
    cwd: str,
    model: str,
    task_id: str,
    pool_size: int,
    max_tasks: int,
) -> Lease:
    state_path = run_dir / "sessions.json"
    locks_dir = runtime_lock_dir(run_dir)
    state_lock_path = locks_dir / "state.lock"
    last_wait_notice = 0.0

    while True:
        state_lock = lock_file(state_lock_path)
        assert state_lock is not None
        state = load_state(state_path)
        run_identity = str(run_dir.resolve())
        stored_run = state.get("run_dir")
        if stored_run is not None and stored_run != run_identity:
            for old_record in state["sessions"].values():
                archived = dict(old_record)
                archived["rotation_reason"] = "run_dir_changed"
                archived["rotated_at"] = utc_now()
                state["history"].append(archived)
            state["sessions"] = {}
        state["run_dir"] = run_identity

        warm: list[tuple[str, int]] = []
        cold: list[int] = []
        for slot in range(pool_size):
            key = f"{provider}:{role}:{slot}"
            record = state["sessions"].get(key)
            if record and rotation_reason(
                record, cwd=cwd, model=model, max_tasks=max_tasks
            ) is None:
                warm.append((record.get("updated_at", ""), slot))
            else:
                cold.append(slot)
        ordered_slots = [slot for _, slot in sorted(warm, reverse=True)] + cold

        selected_handle: IO[str] | None = None
        selected_slot = -1
        for slot in ordered_slots:
            handle = lock_file(
                locks_dir / f"{provider}-{role}-{slot}.lock", nonblocking=True
            )
            if handle is not None:
                selected_handle = handle
                selected_slot = slot
                break

        if selected_handle is None:
            unlock_file(state_lock)
            now = time.monotonic()
            if now - last_wait_notice >= 10:
                print(
                    f"LANE_SESSION waiting provider={provider} role={role} "
                    f"pool={pool_size}",
                    flush=True,
                )
                last_wait_notice = now
            time.sleep(0.2)
            continue

        key = f"{provider}:{role}:{selected_slot}"
        old = state["sessions"].get(key)
        reason = rotation_reason(old, cwd=cwd, model=model, max_tasks=max_tasks)
        is_new = old is None or reason is not None
        if old is not None and reason is not None:
            archived = dict(old)
            archived["rotation_reason"] = reason
            archived["rotated_at"] = utc_now()
            state["history"].append(archived)

        if is_new:
            generation = int((old or {}).get("generation", 0)) + 1
            record = {
                "provider": provider,
                "role": role,
                "slot": selected_slot,
                "generation": generation,
                "session_id": str(uuid.uuid4()) if provider == "grok" else None,
                "cwd": cwd,
                "model": model,
                "sandbox": RUNTIME_SANDBOX_PROFILE,
                "tasks": [],
                "success_count": 0,
                "created_at": utc_now(),
                "updated_at": utc_now(),
                "status": "starting",
                "invalid": False,
            }
        else:
            record = dict(old)

        record["status"] = "running"
        record["current_task"] = task_id
        record["updated_at"] = utc_now()
        state["sessions"][key] = record
        state["defaults"] = {"pool_size": pool_size, "max_tasks": max_tasks}
        save_state(state_path, state)
        unlock_file(state_lock)
        return Lease(key, selected_slot, selected_handle, record, is_new)


def provider_command(
    args: argparse.Namespace, lease: Lease, *, prompt_sha256: str
) -> list[str]:
    binary = args.binary or shutil.which(args.provider)
    if not binary:
        raise RuntimeError(f"{args.provider} binary not found")
    if args.provider == "codex":
        return [
            binary,
            "exec",
            "--json",
            "--ephemeral",
            "--ignore-user-config",
            "--disable",
            "multi_agent",
            "--model",
            args.model,
            "-c",
            f'model_reasoning_effort="{args.reasoning_effort}"',
            "-c",
            'approval_policy="never"',
            "--sandbox",
            CODEX_SANDBOX_PROFILE,
            "--cd",
            str(args.cwd),
            "--skip-git-repo-check",
            "-",
        ]
    if args.provider != "grok":
        raise RuntimeError(f"unsupported provider {args.provider!r}")
    command = [
        binary,
        "--no-subagents",
        "--no-auto-update",
        "--prompt-file",
        str(args.prompt_file),
        "--model",
        args.model,
        "--reasoning-effort",
        args.reasoning_effort,
        "--permission-mode",
        "bypassPermissions",
        "--sandbox",
        GROK_SANDBOX_PROFILE,
        "--rules",
        (
            "Lane runtime task boundary (non-negotiable): "
            f"task_id={args.task_id}; workspace={args.cwd.resolve()}; "
            f"prompt_file={args.prompt_file.resolve()}; prompt_sha256={prompt_sha256}. "
            "Treat the prompt's raw task YAML as authoritative. Write only paths "
            "matched by owns_paths, honor never_touch, do not spawn subagents, "
            "and do not commit, merge, or push. The .agents control plane is "
            "read-only to you. Return the canonical report in your final response "
            f"between {REPORT_BEGIN} and {REPORT_END}; it must contain exact "
            f"TASK_ID: {args.task_id}, PROMPT_SHA256: {prompt_sha256}, and a "
            "STATUS line whose value is exactly one of complete, partial, "
            "timeout, or unavailable."
        ),
        "--output-format",
        "streaming-json",
        "--cwd",
        str(args.cwd),
    ]
    session_id = lease.record["session_id"]
    if lease.is_new:
        command[1:1] = ["--session-id", session_id]
    else:
        command[1:1] = ["--resume", session_id]
    return command


def provider_input(
    args: argparse.Namespace, *, prompt_sha256: str
) -> bytes | None:
    if args.provider != "codex":
        return None
    prompt = args.prompt_file.read_text(encoding="utf-8")
    boundary = (
        "\n\nLane runtime task boundary (non-negotiable): "
        f"task_id={args.task_id}; workspace={args.cwd.resolve()}; "
        f"prompt_file={args.prompt_file.resolve()}; prompt_sha256={prompt_sha256}. "
        "Treat the raw task YAML above as authoritative. Write only paths matched "
        "by owns_paths, honor never_touch, do not spawn subagents, and do not "
        "commit, merge, or push. The .agents control plane is read-only to you. "
        "Return the canonical report as the final response between "
        f"{REPORT_BEGIN} and {REPORT_END}; it must contain exact "
        f"TASK_ID: {args.task_id}, PROMPT_SHA256: {prompt_sha256}, and a STATUS "
        "line whose value is exactly one of complete, partial, timeout, or unavailable."
    )
    return (prompt + boundary + "\n").encode("utf-8")


def control_plane_root(run_dir: Path) -> Path:
    for candidate in (run_dir, *run_dir.parents):
        if candidate.name == ".agents":
            return candidate
    raise RuntimeError(f"run-dir must be inside a .agents control plane: {run_dir}")


def provider_environment(provider: str) -> dict[str, str]:
    allowed = (
        PROVIDER_ENV_KEYS
        | PROVIDER_AUTH_ENV_KEYS.get(provider, frozenset())
        | TEST_PROVIDER_ENV_KEYS
    )
    environment = {
        key: value for key, value in os.environ.items() if key in allowed
    }
    environment.update({"CLAUDE_LANE_AUTOMATION": "1", "TMPDIR": "/tmp"})
    if provider == "grok":
        environment.update(
            {
                "GROK_CLAUDE_HOOKS_ENABLED": "0",
                "GROK_SUBAGENTS": "0",
                "GROK_SANDBOX": GROK_SANDBOX_PROFILE,
            }
        )
    return environment


def prepare_codex_home(provider: str) -> Path | None:
    if provider != "codex":
        return None
    configured = os.environ.get("CODEX_HOME")
    source_home = (
        Path(configured).expanduser().resolve()
        if configured
        else (Path.home() / ".codex").resolve()
    )
    auth_source = source_home / "auth.json"
    if not auth_source.is_file():
        raise RuntimeError(f"Codex auth file not found: {auth_source}")
    scratch = Path(tempfile.mkdtemp(prefix=f"claude-lane-codex-{os.getuid()}-"))
    scratch.chmod(0o700)
    auth_target = scratch / "auth.json"
    shutil.copyfile(auth_source, auth_target)
    auth_target.chmod(0o600)
    return scratch


def active_pathname_sockets() -> list[Path]:
    sockets: set[Path] = set()
    try:
        lines = Path("/proc/net/unix").read_text(encoding="utf-8").splitlines()[1:]
    except OSError:
        return []
    for line in lines:
        fields = line.split(maxsplit=7)
        if len(fields) != 8 or not fields[7].startswith("/"):
            continue
        path = Path(fields[7])
        try:
            if stat.S_ISSOCK(path.stat(follow_symlinks=False).st_mode):
                sockets.add(path)
        except OSError:
            continue
    return sorted(sockets, key=str)


def sandbox_provider_command(
    command: list[str],
    *,
    provider: str,
    run_dir: Path,
    cwd: Path,
    home: Path,
    provider_state_dir: Path | None = None,
) -> list[str]:
    bwrap = shutil.which("bwrap")
    if not bwrap:
        raise RuntimeError(
            "bubblewrap is required to protect the .agents control plane"
        )
    control_root = control_plane_root(run_dir)
    sandbox_command = list(command)
    codex_binary: Path | None = None
    if provider == "codex":
        try:
            codex_binary = Path(command[0]).resolve(strict=True)
        except OSError as exc:
            raise RuntimeError(f"cannot resolve Codex binary: {command[0]}") from exc
        if not codex_binary.is_file():
            raise RuntimeError(f"Codex binary is not a regular file: {codex_binary}")
        sandbox_command[0] = "/opt/claude-lane-codex"
    wrapped = [
        bwrap,
        "--die-with-parent",
        "--ro-bind",
        "/",
        "/",
        "--dev",
        "/dev",
        "--unshare-pid",
        "--unshare-ipc",
        "--proc",
        "/proc",
        "--tmpfs",
        "/run",
        "--tmpfs",
        "/tmp",
        "--tmpfs",
        "/var/tmp",
    ]
    writable_paths = (
        (home / ".grok", cwd)
        if provider == "grok"
        else tuple(path for path in (cwd, provider_state_dir) if path is not None)
    )
    for writable in writable_paths:
        if writable.exists():
            wrapped.extend(("--bind", str(writable), str(writable)))
    wrapped.extend(("--ro-bind", str(control_root), str(control_root)))
    hidden_paths: set[Path] = set()
    if provider == "grok":
        hidden_paths.add((home / ".codex").resolve())
        configured_codex_home = os.environ.get("CODEX_HOME")
        if configured_codex_home:
            hidden_paths.add(Path(configured_codex_home).expanduser().resolve())
    elif provider == "codex":
        hidden_paths.update(
            {
                (home / ".codex").resolve(),
                (home / ".grok").resolve(),
            }
        )
    for hidden in sorted(hidden_paths, key=str):
        if provider_state_dir is not None and hidden == provider_state_dir:
            continue
        if hidden.is_dir():
            wrapped.extend(("--tmpfs", str(hidden)))
        elif hidden.exists():
            wrapped.extend(("--ro-bind", "/dev/null", str(hidden)))
    for socket_path in active_pathname_sockets():
        hidden_by_private_tmpfs = any(
            socket_path.is_relative_to(root)
            for root in (Path("/run"), Path("/var/run"), Path("/tmp"), Path("/var/tmp"))
        )
        exposed_by_writable_bind = any(
            socket_path.is_relative_to(path) for path in writable_paths
        )
        if hidden_by_private_tmpfs and not exposed_by_writable_bind:
            continue
        wrapped.extend(("--ro-bind", "/dev/null", str(socket_path)))
    if codex_binary is not None:
        wrapped.extend(
            (
                "--tmpfs",
                "/opt",
                "--ro-bind",
                str(codex_binary),
                sandbox_command[0],
            )
        )
    wrapped.extend(("--chdir", str(cwd), "--", *sandbox_command))
    return wrapped


def runtime_attempt(output: Path) -> int | None:
    parent = output.parent
    if parent.parent.name != "attempts" or not parent.name.isdigit():
        return None
    attempt = int(parent.name)
    return attempt if attempt >= 1 else None


def extract_lane_report(
    response: str,
    *,
    task_id: str,
    prompt_sha256: str,
    begin_count: int,
    end_count: int,
) -> str:
    if begin_count != 1 or end_count != 1:
        if begin_count == 0:
            raise ValueError("lane report is missing")
        raise ValueError("lane report envelope must appear exactly once")
    begin = response.rfind(REPORT_BEGIN)
    content_start = begin + len(REPORT_BEGIN)
    end = response.find(REPORT_END, content_start)
    if end < 0:
        raise ValueError("lane report end marker is missing")
    if response[end + len(REPORT_END) :].strip():
        raise ValueError("lane report must be the final response block")
    report = response[content_start:end].strip() + "\n"
    if "\x00" in report or len(report.encode("utf-8")) > MAX_REPORT_BYTES:
        raise ValueError("lane report is invalid or too large")
    task_matches = re.findall(r"(?m)^TASK_ID:\s*(\S+)\s*$", report)
    if not task_matches:
        raise ValueError("lane report task_id is missing")
    if len(task_matches) != 1 or task_matches[0] != task_id:
        raise ValueError("lane report task_id mismatch")
    prompt_matches = re.findall(
        r"(?m)^PROMPT_SHA256:\s*([0-9a-f]{64})\s*$", report
    )
    if not prompt_matches:
        raise ValueError("lane report prompt_sha256 is missing")
    if len(prompt_matches) != 1 or prompt_matches[0] != prompt_sha256:
        raise ValueError("lane report prompt_sha256 mismatch")
    status_matches = re.findall(
        r"(?m)^STATUS:\s*(complete|partial|timeout|unavailable)\s*$", report
    )
    if len(status_matches) != 1:
        raise ValueError("lane report status is missing or invalid")
    return report


def validate_report_path(path: Path, *, root: Path) -> None:
    base = root.resolve(strict=True)
    absolute = Path(os.path.abspath(path))
    try:
        relative = absolute.relative_to(base)
    except ValueError as exc:
        raise RuntimeError(f"lane report escapes run directory: {path}") from exc
    current = base
    for part in relative.parts:
        current = current / part
        if current.is_symlink():
            raise RuntimeError(f"refusing symlinked lane report path: {path}")


def materialize_lane_report(path: Path, report: str, *, root: Path) -> str:
    validate_report_path(path, root=root)
    path.parent.mkdir(parents=True, exist_ok=True)
    validate_report_path(path, root=root)
    temp = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    try:
        with temp.open("x", encoding="utf-8") as handle:
            handle.write(report)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(temp, path)
    finally:
        try:
            temp.unlink()
        except FileNotFoundError:
            pass
    return hashlib.sha256(report.encode("utf-8")).hexdigest()


def terminate_provider(process: subprocess.Popen[bytes] | None) -> None:
    if process is None or process.poll() is not None:
        return
    try:
        os.killpg(process.pid, signal.SIGTERM)
    except ProcessLookupError:
        return
    try:
        process.wait(timeout=3)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(process.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        process.wait(timeout=3)


def safe_scalar(value: object) -> int | float | None:
    if isinstance(value, bool) or not isinstance(value, (int, float)) or value < 0:
        return None
    return value


def sanitized_usage(value: object, allowed: set[str]) -> dict | None:
    if not isinstance(value, dict):
        return None
    result = {
        key: scalar
        for key in allowed
        if (scalar := safe_scalar(value.get(key))) is not None
    }
    return result or None


def sanitized_model_usage(value: object) -> dict | None:
    if not isinstance(value, dict):
        return None
    result: dict[str, dict] = {}
    for model, metrics in list(value.items())[:20]:
        if not isinstance(model, str) or not SAFE_NAME.fullmatch(model.replace("/", "-")):
            continue
        clean = sanitized_usage(metrics, MODEL_USAGE_FIELDS)
        if clean:
            result[model] = clean
    return result or None


def provider_version(
    command: list[str], *, cwd: Path, environment: dict[str, str]
) -> str | None:
    try:
        result = subprocess.run(
            command,
            cwd=cwd,
            env=environment,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=5,
            check=False,
        )
    except (OSError, subprocess.SubprocessError):
        return None
    if result.returncode != 0:
        return None
    output = (result.stdout or "")[:4096]
    if not output:
        return None
    match = VERSION_TOKEN.search(output)
    return match.group(1) if match else None


def sanitized_stop_reason(value: object) -> str | None:
    if not isinstance(value, str) or not value:
        return None
    return value if value in RECOGNIZED_STOP_REASONS else "Other"


def bounded_evidence_append(buffer: bytearray, data: bytes) -> None:
    remaining = MAX_FAILURE_EVIDENCE_BYTES - len(buffer)
    if remaining > 0:
        buffer.extend(data[:remaining])


def grok_model_matches(requested_model: str, model_usage: dict | None) -> bool:
    if not model_usage or len(model_usage) != 1:
        return False
    effective = next(iter(model_usage))
    allowed = {requested_model}
    if requested_model == "grok-4.5":
        allowed.add("grok-4.5-build")
    return effective in allowed


def classify_grok_failure(
    evidence: bytes,
    *,
    provider_exit_code: int,
    protocol_error: str | None,
) -> tuple[str | None, bool, bool, str | None, str | None]:
    error_event = protocol_error == "provider emitted an error event"
    if protocol_error is not None and not error_event:
        failure_class = (
            "grok_model_mismatch"
            if protocol_error == "effective model does not match requested model"
            else "grok_protocol_failure"
        )
        return failure_class, True, False, "protocol", None
    if provider_exit_code == 0 and not error_event:
        return None, False, False, None, None

    lower = evidence.decode("utf-8", errors="ignore").lower()
    patterns: tuple[tuple[str, tuple[str, ...], bool], ...] = (
        (
            "grok_bootstrap_transient",
            ("settings fetch failed", "failed to load settings", "settings unavailable"),
            True,
        ),
        (
            "grok_model_unavailable",
            ("unknown model", "model not found", "unsupported model", "model unavailable"),
            True,
        ),
        (
            "grok_quota_exhausted",
            ("rate limit", "quota", "usage limit", "limit reached", "status 429", " 429 "),
            True,
        ),
        (
            "grok_auth_unavailable",
            ("unauthorized", "authentication failed", "login required", "invalid token"),
            True,
        ),
        (
            "grok_region_unavailable",
            ("region unavailable", "not available in your region", "geo blocked", "status 403"),
            True,
        ),
        (
            "grok_transport_transient",
            ("connection reset", "timed out", "timeout", "status 503", "service unavailable"),
            True,
        ),
    )
    evidence_digest = hashlib.sha256(evidence).hexdigest() if evidence else None
    for failure_class, signatures, fallback_eligible in patterns:
        if any(signature in lower for signature in signatures):
            return failure_class, True, fallback_eligible, "provider", evidence_digest
    if error_event:
        return "grok_protocol_failure", True, False, "protocol", evidence_digest
    return "grok_provider_failed", True, False, "exit", evidence_digest


def stream_codex_provider(
    process: subprocess.Popen[bytes],
    output: IO[bytes],
    *,
    task_id: str,
    prompt_sha256: str,
    report_path: Path,
    report_root: Path,
) -> StreamResult:
    assert process.stdout is not None
    assert process.stderr is not None
    stdout_fd = process.stdout.fileno()
    stderr_fd = process.stderr.fileno()
    open_fds = {stdout_fd, stderr_fd}
    pending = b""
    log_bytes = 0
    log_truncated = False
    protocol_error: str | None = None
    thread_id: str | None = None
    turn_completed = False
    response_tail = ""
    marker_overlap = ""
    report_begin_count = 0
    report_end_count = 0
    report_sha256: str | None = None
    stderr_bytes = 0
    usage: dict | None = None

    def write_log(data: bytes) -> None:
        nonlocal log_bytes, log_truncated
        remaining = MAX_PROVIDER_LOG_BYTES - log_bytes
        if remaining <= 0:
            log_truncated = True
            return
        chunk = data[:remaining]
        output.write(chunk)
        output.flush()
        log_bytes += len(chunk)
        if len(chunk) < len(data):
            log_truncated = True

    def visible_marker(event_type: str) -> None:
        marker = f"CODEX_EVENT {event_type}\n".encode("utf-8")
        sys.stdout.buffer.write(marker)
        sys.stdout.buffer.flush()

    def set_protocol_error(reason: str, line: bytes = b"") -> None:
        nonlocal protocol_error
        if protocol_error is not None:
            return
        protocol_error = reason
        digest = hashlib.sha256(line).hexdigest()[:16]
        write_log(
            f"\n[codex protocol error: {reason}; bytes={len(line)}; sha256={digest}]\n".encode(
                "utf-8"
            )
        )
        visible_marker("protocol-error")

    def process_line(line: bytes) -> None:
        nonlocal thread_id, turn_completed, response_tail, marker_overlap
        nonlocal report_begin_count, report_end_count, usage
        if not line.strip():
            return
        try:
            event = json.loads(line)
        except (UnicodeDecodeError, json.JSONDecodeError):
            set_protocol_error("malformed json stream", line)
            return
        if not isinstance(event, dict) or not isinstance(event.get("type"), str):
            set_protocol_error("event must be an object with a string type", line)
            return
        event_type = event["type"]
        if len(event_type) > MAX_EVENT_NAME or not SAFE_NAME.fullmatch(event_type):
            set_protocol_error("event type is invalid", line)
            return
        if event_type == "thread.started":
            value = event.get("thread_id")
            if isinstance(value, str) and value:
                thread_id = value
            visible_marker(event_type)
        elif event_type == "item.completed":
            item = event.get("item")
            if not isinstance(item, dict):
                set_protocol_error("completed item must be an object", line)
                return
            if item.get("type") == "agent_message":
                data = item.get("text")
                if not isinstance(data, str):
                    set_protocol_error("agent message text must be a string", line)
                    return
                encoded = data.encode("utf-8", errors="replace")
                response_tail = (response_tail + data)[-MAX_REPORT_SCAN_CHARS:]
                marker_scan = marker_overlap + data
                report_begin_count += marker_scan.count(REPORT_BEGIN)
                report_end_count += marker_scan.count(REPORT_END)
                overlap_size = max(len(REPORT_BEGIN), len(REPORT_END)) - 1
                marker_overlap = marker_scan[-overlap_size:]
                write_log(encoded)
                sys.stdout.buffer.write(encoded)
                sys.stdout.buffer.flush()
            else:
                write_log(f"\n[codex item: {item.get('type', 'unknown')}]\n".encode())
                visible_marker(event_type)
        elif event_type == "turn.completed":
            if turn_completed:
                set_protocol_error("duplicate turn.completed event", line)
                return
            turn_completed = True
            usage = sanitized_usage(event.get("usage"), TOKEN_FIELDS)
            visible_marker(event_type)
        elif event_type in {"turn.failed", "error"}:
            set_protocol_error("Codex turn failed", line)
        else:
            write_log(f"\n[codex event: {event_type}]\n".encode("utf-8"))
            visible_marker(event_type)

    def consume(chunk: bytes) -> None:
        nonlocal pending
        pending += chunk
        while b"\n" in pending:
            line, pending = pending.split(b"\n", 1)
            process_line(line)

    def consume_stderr(chunk: bytes) -> None:
        nonlocal stderr_bytes
        stderr_bytes += len(chunk)
        digest = hashlib.sha256(chunk).hexdigest()[:16]
        write_log(
            f"\n[codex stderr: bytes={len(chunk)}; sha256={digest}]\n".encode("utf-8")
        )
        visible_marker("stderr")

    while open_fds:
        ready, _, _ = select.select(list(open_fds), [], [], 0.1)
        for fd in ready:
            chunk = os.read(fd, 65536)
            if chunk:
                consume(chunk) if fd == stdout_fd else consume_stderr(chunk)
            else:
                open_fds.discard(fd)
    if pending:
        process_line(pending)

    provider_exit_code = process.wait()
    if provider_exit_code == 0 and protocol_error is None and not turn_completed:
        protocol_error = "stream ended without turn.completed"
    if provider_exit_code == 0 and protocol_error is None:
        try:
            report = extract_lane_report(
                response_tail,
                task_id=task_id,
                prompt_sha256=prompt_sha256,
                begin_count=report_begin_count,
                end_count=report_end_count,
            )
            report_sha256 = materialize_lane_report(
                report_path, report, root=report_root
            )
        except (OSError, RuntimeError, ValueError) as exc:
            protocol_error = str(exc)
    exit_code = (
        PROTOCOL_FAILURE_EXIT
        if provider_exit_code == 0 and protocol_error is not None
        else provider_exit_code
    )
    failure_class = None
    failure_source = None
    if exit_code != 0:
        failure_class = (
            "codex_protocol_failure" if protocol_error else "codex_provider_failed"
        )
        failure_source = "protocol" if protocol_error else "exit"
    return StreamResult(
        provider_exit_code=provider_exit_code,
        exit_code=exit_code,
        session_id=thread_id,
        stop_reason="TurnCompleted" if turn_completed else None,
        usage=usage,
        model_usage=None,
        num_turns=1 if turn_completed else None,
        total_cost_usd=None,
        total_cost_usd_ticks=None,
        cost_is_partial=None,
        usage_is_incomplete=None,
        protocol_error=protocol_error,
        report_sha256=report_sha256,
        log_truncated=log_truncated,
        stderr_bytes=stderr_bytes,
        failure_class=failure_class,
        failure_retryable=False,
        fallback_eligible=False,
        failure_source=failure_source,
        failure_evidence_sha256=None,
    )


def stream_provider(
    process: subprocess.Popen[bytes],
    output: IO[bytes],
    *,
    provider: str,
    expected_session_id: str,
    requested_model: str,
    task_id: str,
    prompt_sha256: str,
    report_path: Path,
    report_root: Path,
) -> StreamResult:
    if provider == "codex":
        return stream_codex_provider(
            process,
            output,
            task_id=task_id,
            prompt_sha256=prompt_sha256,
            report_path=report_path,
            report_root=report_root,
        )
    assert process.stdout is not None
    assert process.stderr is not None
    stdout_fd = process.stdout.fileno()
    stderr_fd = process.stderr.fileno()
    open_fds = {stdout_fd, stderr_fd}
    pending = b""
    log_bytes = 0
    log_truncated = False
    protocol_error: str | None = None
    end_event: dict | None = None
    saw_error = False
    stderr_bytes = 0
    response_tail = ""
    marker_overlap = ""
    report_begin_count = 0
    report_end_count = 0
    report_sha256: str | None = None
    failure_evidence = bytearray()

    def write_log(data: bytes) -> None:
        nonlocal log_bytes, log_truncated
        remaining = MAX_PROVIDER_LOG_BYTES - log_bytes
        if remaining <= 0:
            log_truncated = True
            return
        chunk = data[:remaining]
        output.write(chunk)
        output.flush()
        log_bytes += len(chunk)
        if len(chunk) < len(data):
            log_truncated = True

    def visible_marker(event_type: str) -> None:
        marker = f"GROK_EVENT {event_type}\n".encode("utf-8")
        sys.stdout.buffer.write(marker)
        sys.stdout.buffer.flush()

    def set_protocol_error(reason: str, line: bytes) -> None:
        nonlocal protocol_error
        if protocol_error is not None:
            return
        protocol_error = reason
        digest = hashlib.sha256(line).hexdigest()[:16]
        write_log(
            f"\n[grok protocol error: {reason}; bytes={len(line)}; sha256={digest}]\n".encode(
                "utf-8"
            )
        )
        visible_marker("protocol-error")

    def process_line(line: bytes) -> None:
        nonlocal end_event, saw_error, response_tail, marker_overlap
        nonlocal report_begin_count, report_end_count
        if not line.strip():
            return
        try:
            event = json.loads(line)
        except (UnicodeDecodeError, json.JSONDecodeError):
            set_protocol_error("malformed streaming-json", line)
            return
        if not isinstance(event, dict) or not isinstance(event.get("type"), str):
            set_protocol_error("event must be an object with a string type", line)
            return
        event_type = event["type"]
        if len(event_type) > MAX_EVENT_NAME or not SAFE_NAME.fullmatch(event_type):
            set_protocol_error("event type is invalid", line)
            return
        if end_event is not None:
            set_protocol_error("event received after end", line)
            return

        if event_type == "text":
            data = event.get("data")
            if not isinstance(data, str):
                set_protocol_error("text event data must be a string", line)
                return
            encoded = data.encode("utf-8", errors="replace")
            response_tail = (response_tail + data)[-MAX_REPORT_SCAN_CHARS:]
            marker_scan = marker_overlap + data
            report_begin_count += marker_scan.count(REPORT_BEGIN)
            report_end_count += marker_scan.count(REPORT_END)
            overlap_size = max(len(REPORT_BEGIN), len(REPORT_END)) - 1
            marker_overlap = marker_scan[-overlap_size:]
            write_log(encoded)
            sys.stdout.buffer.write(encoded)
            sys.stdout.buffer.flush()
        elif event_type == "thought":
            if not isinstance(event.get("data"), str):
                set_protocol_error("thought event data must be a string", line)
                return
            write_log(b"\n[grok event: thought]\n")
            visible_marker("thought")
        elif event_type == "error":
            message = event.get("message")
            if not isinstance(message, str):
                set_protocol_error("error event message must be a string", line)
                return
            saw_error = True
            bounded_evidence_append(
                failure_evidence, message.encode("utf-8", errors="replace")
            )
            write_log(b"\n[grok event: error]\n")
            visible_marker("error")
        elif event_type == "end":
            session_id = event.get("sessionId")
            stop_reason = event.get("stopReason")
            if not isinstance(session_id, str) or session_id != expected_session_id:
                set_protocol_error("end event sessionId mismatch", line)
                return
            if not isinstance(stop_reason, str) or not stop_reason:
                set_protocol_error("end event stopReason must be a non-empty string", line)
                return
            safe_stop_reason = sanitized_stop_reason(stop_reason)
            end_event = dict(event)
            end_event["stopReason"] = safe_stop_reason
            write_log(f"\n[grok end: {safe_stop_reason}]\n".encode("utf-8"))
            visible_marker("end")
            if safe_stop_reason not in SUCCESS_STOP_REASONS:
                set_protocol_error(
                    f"unsuccessful terminal reason: {safe_stop_reason}", line
                )
        else:
            write_log(f"\n[grok event: {event_type}]\n".encode("utf-8"))
            visible_marker(event_type)

    def consume(chunk: bytes) -> None:
        nonlocal pending
        pending += chunk
        while b"\n" in pending:
            line, pending = pending.split(b"\n", 1)
            process_line(line)

    def consume_stderr(chunk: bytes) -> None:
        nonlocal stderr_bytes
        stderr_bytes += len(chunk)
        bounded_evidence_append(failure_evidence, chunk)
        digest = hashlib.sha256(chunk).hexdigest()[:16]
        write_log(
            f"\n[grok stderr: bytes={len(chunk)}; sha256={digest}]\n".encode("utf-8")
        )
        visible_marker("stderr")

    while open_fds:
        ready, _, _ = select.select(list(open_fds), [], [], 0.1)
        for fd in ready:
            chunk = os.read(fd, 65536)
            if chunk:
                if fd == stdout_fd:
                    consume(chunk)
                else:
                    consume_stderr(chunk)
            else:
                open_fds.discard(fd)
    if pending:
        process_line(pending)

    provider_exit_code = process.wait()
    if provider_exit_code == 0 and protocol_error is None and saw_error:
        protocol_error = "provider emitted an error event"
    if provider_exit_code == 0 and protocol_error is None and end_event is None:
        protocol_error = "stream ended without an end event"
    model_usage = sanitized_model_usage((end_event or {}).get("modelUsage"))
    if (
        provider_exit_code == 0
        and protocol_error is None
        and not grok_model_matches(requested_model, model_usage)
    ):
        protocol_error = "effective model does not match requested model"
    if provider_exit_code == 0 and protocol_error is None:
        try:
            report = extract_lane_report(
                response_tail,
                task_id=task_id,
                prompt_sha256=prompt_sha256,
                begin_count=report_begin_count,
                end_count=report_end_count,
            )
            report_sha256 = materialize_lane_report(
                report_path, report, root=report_root
            )
        except (OSError, RuntimeError, ValueError) as exc:
            protocol_error = str(exc)
    exit_code = (
        PROTOCOL_FAILURE_EXIT
        if provider_exit_code == 0 and protocol_error is not None
        else provider_exit_code
    )
    end = end_event or {}
    num_turns = end.get("num_turns")
    if isinstance(num_turns, bool) or not isinstance(num_turns, int) or num_turns < 0:
        num_turns = None
    ticks = end.get("total_cost_usd_ticks")
    if isinstance(ticks, bool) or not isinstance(ticks, int) or ticks < 0:
        ticks = None
    classification_error = protocol_error
    if saw_error and protocol_error == "unsuccessful terminal reason: Error":
        classification_error = "provider emitted an error event"
    (
        failure_class,
        failure_retryable,
        fallback_eligible,
        failure_source,
        failure_evidence_sha256,
    ) = classify_grok_failure(
        bytes(failure_evidence),
        provider_exit_code=provider_exit_code,
        protocol_error=classification_error,
    )
    return StreamResult(
        provider_exit_code=provider_exit_code,
        exit_code=exit_code,
        session_id=end.get("sessionId") if isinstance(end.get("sessionId"), str) else None,
        stop_reason=end.get("stopReason") if isinstance(end.get("stopReason"), str) else None,
        usage=sanitized_usage(end.get("usage"), TOKEN_FIELDS),
        model_usage=model_usage,
        num_turns=num_turns,
        total_cost_usd=safe_scalar(end.get("total_cost_usd")),
        total_cost_usd_ticks=ticks,
        cost_is_partial=end.get("cost_is_partial")
        if isinstance(end.get("cost_is_partial"), bool)
        else None,
        usage_is_incomplete=end.get("usage_is_incomplete")
        if isinstance(end.get("usage_is_incomplete"), bool)
        else None,
        protocol_error=protocol_error,
        report_sha256=report_sha256,
        log_truncated=log_truncated,
        stderr_bytes=stderr_bytes,
        failure_class=failure_class,
        failure_retryable=failure_retryable,
        fallback_eligible=fallback_eligible,
        failure_source=failure_source,
        failure_evidence_sha256=failure_evidence_sha256,
    )


def write_runtime_receipt(
    *,
    path: Path,
    args: argparse.Namespace,
    lease: Lease,
    prompt_sha256: str | None,
    provider_version_text: str | None,
    started_at: str,
    result: StreamResult,
    failure_class: str | None = None,
) -> None:
    effective_failure_class = failure_class or result.failure_class
    provider_sandbox = (
        GROK_SANDBOX_PROFILE if args.provider == "grok" else CODEX_SANDBOX_PROFILE
    )
    permission_mode = "bypassPermissions" if args.provider == "grok" else "never"
    receipt: dict[str, object] = {
        "schema_version": 1,
        "provider": args.provider,
        "provider_version": provider_version_text,
        "model": args.model,
        "reasoning_effort": args.reasoning_effort,
        "sandbox": RUNTIME_SANDBOX_PROFILE,
        "provider_sandbox": provider_sandbox,
        "subagents_enabled": False,
        "permission_mode": permission_mode,
        "control_plane_read_only": True,
        "task_id": args.task_id,
        "role": args.role,
        "slot": lease.slot,
        "mode": (
            "ephemeral"
            if args.provider == "codex"
            else "new" if lease.is_new else "resume"
        ),
        "session_id": result.session_id or lease.record.get("session_id"),
        "started_at": started_at,
        "finished_at": utc_now(),
        "provider_exit_code": result.provider_exit_code,
        "exit_code": result.exit_code,
        "protocol_valid": (
            result.exit_code == 0
            and result.protocol_error is None
            and effective_failure_class is None
        ),
        "log_truncated": result.log_truncated,
        "stderr_bytes": result.stderr_bytes,
    }
    attempt = runtime_attempt(args.output)
    if attempt is not None:
        receipt["attempt"] = attempt
    optional = {
        "stop_reason": result.stop_reason,
        "usage": result.usage,
        "model_usage": result.model_usage,
        "num_turns": result.num_turns,
        "total_cost_usd": result.total_cost_usd,
        "total_cost_usd_ticks": result.total_cost_usd_ticks,
        "cost_is_partial": result.cost_is_partial,
        "usage_is_incomplete": result.usage_is_incomplete,
        "protocol_error": result.protocol_error,
        "report_sha256": result.report_sha256,
        "prompt_sha256": prompt_sha256,
        "failure_class": effective_failure_class,
        "failure_retryable": result.failure_retryable
        if effective_failure_class is not None
        else None,
        "fallback_eligible": result.fallback_eligible
        if effective_failure_class is not None
        else None,
        "failure_source": result.failure_source,
        "failure_evidence_sha256": result.failure_evidence_sha256,
    }
    receipt.update({key: value for key, value in optional.items() if value is not None})
    save_state(path, receipt)


def finish_lease(
    *,
    run_dir: Path,
    lease: Lease,
    task_id: str,
    exit_code: int,
    captured_session_id: str | None,
) -> dict:
    state_path = run_dir / "sessions.json"
    state_lock = lock_file(runtime_lock_dir(run_dir) / "state.lock")
    assert state_lock is not None
    state = load_state(state_path)
    record = dict(state["sessions"].get(lease.key, lease.record))
    record.pop("current_task", None)
    record["updated_at"] = utc_now()

    if exit_code == 0 and captured_session_id:
        record["session_id"] = captured_session_id
    if exit_code == 0 and record.get("session_id"):
        record["success_count"] = int(
            record.get("success_count", len(record.get("tasks", [])))
        ) + 1
        if task_id not in record["tasks"]:
            record["tasks"].append(task_id)
        record["status"] = "idle"
        record["invalid"] = False
        record.pop("invalid_reason", None)
    elif exit_code == 0:
        record["status"] = "capture_failed"
        record["invalid"] = True
        record["invalid_reason"] = "conversation_capture_failed"
    else:
        record["status"] = "failed"
        record["invalid"] = True
        record["invalid_reason"] = f"provider_exit_{exit_code}"

    state["sessions"][lease.key] = record
    save_state(state_path, state)
    unlock_file(state_lock)
    return record


def run_provider(args: argparse.Namespace) -> int:
    run_dir = args.run_dir.resolve()
    cwd = args.cwd.resolve()
    if not cwd.is_dir():
        raise RuntimeError(f"cwd is not a directory: {cwd}")
    if not args.prompt_file.is_file():
        raise RuntimeError(f"prompt file not found: {args.prompt_file}")

    lease = acquire_lease(
        run_dir=run_dir,
        provider=args.provider,
        role=args.role,
        cwd=str(cwd),
        model=args.model,
        task_id=args.task_id,
        pool_size=args.pool_size,
        max_tasks=args.max_tasks,
    )
    completed = False
    captured: str | None = lease.record.get("session_id")
    process: subprocess.Popen[bytes] | None = None
    result: StreamResult | None = None
    version_text: str | None = None
    prompt_sha256: str | None = None
    provider_state_dir: Path | None = None
    started_at = utc_now()
    old_handlers: dict[int, signal.Handlers] = {}

    def handle_signal(signum: int, _frame: object) -> None:
        raise LaneInterrupted(signum)

    for signum in (signal.SIGINT, signal.SIGTERM):
        old_handlers[signum] = signal.getsignal(signum)
        signal.signal(signum, handle_signal)
    try:
        prompt_sha256 = hashlib.sha256(args.prompt_file.read_bytes()).hexdigest()
        provider_argv = provider_command(args, lease, prompt_sha256=prompt_sha256)
        stdin_payload = provider_input(args, prompt_sha256=prompt_sha256)
        provider_state_dir = prepare_codex_home(args.provider)
        provider_env = provider_environment(args.provider)
        if provider_state_dir is not None:
            provider_env["CODEX_HOME"] = str(provider_state_dir)
        provider_home = Path(provider_env.get("HOME", str(Path.home()))).resolve()
        command = sandbox_provider_command(
            provider_argv,
            provider=args.provider,
            run_dir=run_dir,
            cwd=cwd,
            home=provider_home,
            provider_state_dir=provider_state_dir,
        )
        version_text = provider_version(
            sandbox_provider_command(
                [provider_argv[0], "--version"],
                provider=args.provider,
                run_dir=run_dir,
                cwd=cwd,
                home=provider_home,
                provider_state_dir=provider_state_dir,
            ),
            cwd=cwd,
            environment=provider_env,
        )
        args.output.parent.mkdir(parents=True, exist_ok=True)

        print(
            f"LANE_SESSION start provider={args.provider} role={args.role} "
            f"slot={lease.slot} mode={'new' if lease.is_new else 'resume'} "
            f"task={args.task_id}",
            flush=True,
        )
        with args.output.open("wb") as output:
            process = subprocess.Popen(
                command,
                cwd=cwd,
                env=provider_env,
                stdin=subprocess.PIPE if stdin_payload is not None else subprocess.DEVNULL,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                start_new_session=True,
            )
            if stdin_payload is not None:
                assert process.stdin is not None
                process.stdin.write(stdin_payload)
                process.stdin.close()
            result = stream_provider(
                process,
                output,
                provider=args.provider,
                expected_session_id=str(lease.record["session_id"]),
                requested_model=args.model,
                task_id=args.task_id,
                prompt_sha256=prompt_sha256,
                report_path=run_dir / "artifacts" / args.task_id / "report.md",
                report_root=run_dir,
            )
            if result.session_id:
                captured = result.session_id
            exit_code = result.exit_code

        record = finish_lease(
            run_dir=run_dir,
            lease=lease,
            task_id=args.task_id,
            exit_code=exit_code,
            captured_session_id=captured,
        )
        write_runtime_receipt(
            path=args.output.with_name("runtime.json"),
            args=args,
            lease=lease,
            prompt_sha256=prompt_sha256,
            provider_version_text=version_text,
            started_at=started_at,
            result=result,
        )
        completed = True
        print(
            f"LANE_SESSION done provider={args.provider} slot={lease.slot} "
            f"task={args.task_id} exit={exit_code} status={record['status']} "
            f"turns={record['success_count']}",
            flush=True,
        )
        return exit_code
    except LaneInterrupted as exc:
        terminate_provider(process)
        exit_code = 128 + exc.signum
        finish_lease(
            run_dir=run_dir,
            lease=lease,
            task_id=args.task_id,
            exit_code=exit_code,
            captured_session_id=captured,
        )
        result = StreamResult(
            provider_exit_code=exit_code,
            exit_code=exit_code,
            session_id=captured,
            stop_reason=None,
            usage=None,
            model_usage=None,
            num_turns=None,
            total_cost_usd=None,
            total_cost_usd_ticks=None,
            cost_is_partial=None,
            usage_is_incomplete=None,
            protocol_error="interrupted",
            report_sha256=None,
            log_truncated=False,
            stderr_bytes=0,
            failure_class=None,
            failure_retryable=False,
            fallback_eligible=False,
            failure_source="signal",
            failure_evidence_sha256=None,
        )
        write_runtime_receipt(
            path=args.output.with_name("runtime.json"),
            args=args,
            lease=lease,
            prompt_sha256=prompt_sha256,
            provider_version_text=version_text,
            started_at=started_at,
            result=result,
        )
        completed = True
        print(
            f"LANE_SESSION interrupted provider={args.provider} slot={lease.slot} "
            f"task={args.task_id} signal={exc.signum}",
            file=sys.stderr,
            flush=True,
        )
        return exit_code
    except BaseException as exc:
        try:
            terminate_provider(process)
        except Exception as cleanup_exc:
            print(
                "lane-session: provider cleanup failed "
                f"({type(cleanup_exc).__name__})",
                file=sys.stderr,
            )
        if not completed:
            try:
                finish_lease(
                    run_dir=run_dir,
                    lease=lease,
                    task_id=args.task_id,
                    exit_code=125,
                    captured_session_id=captured,
                )
            except Exception as state_exc:
                print(
                    "lane-session: failed to invalidate session "
                    f"({type(state_exc).__name__})",
                    file=sys.stderr,
                )
            failure = StreamResult(
                provider_exit_code=125,
                exit_code=125,
                session_id=captured,
                stop_reason=None,
                usage=None,
                model_usage=None,
                num_turns=None,
                total_cost_usd=None,
                total_cost_usd_ticks=None,
                cost_is_partial=None,
                usage_is_incomplete=None,
                protocol_error=None,
                report_sha256=None,
                log_truncated=False,
                stderr_bytes=0,
                failure_class=None,
                failure_retryable=False,
                fallback_eligible=False,
                failure_source="exception",
                failure_evidence_sha256=None,
            )
            try:
                write_runtime_receipt(
                    path=args.output.with_name("runtime.json"),
                    args=args,
                    lease=lease,
                    prompt_sha256=prompt_sha256,
                    provider_version_text=version_text,
                    started_at=started_at,
                    result=failure,
                    failure_class=type(exc).__name__,
                )
            except Exception as receipt_exc:
                print(
                    "lane-session: failed to write runtime receipt "
                    f"({type(receipt_exc).__name__})",
                    file=sys.stderr,
                )
        raise
    finally:
        if provider_state_dir is not None:
            shutil.rmtree(provider_state_dir, ignore_errors=True)
        for signum, old_handler in old_handlers.items():
            signal.signal(signum, old_handler)
        unlock_file(lease.handle)


def positive_bounded(value: str, *, maximum: int, name: str) -> int:
    parsed = int(value)
    if parsed < 1 or parsed > maximum:
        raise argparse.ArgumentTypeError(f"{name} must be between 1 and {maximum}")
    return parsed


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Run Grok in a warm, run-scoped session pool"
    )
    sub = parser.add_subparsers(dest="command", required=True)

    run = sub.add_parser("run", help="acquire a session slot and run one task")
    run.add_argument("--provider", required=True, choices=("grok", "codex"))
    run.add_argument("--run-dir", required=True, type=Path)
    run.add_argument("--task-id", required=True)
    run.add_argument("--role", required=True)
    run.add_argument("--cwd", required=True, type=Path)
    run.add_argument("--prompt-file", required=True, type=Path)
    run.add_argument("--output", required=True, type=Path)
    run.add_argument("--binary", help="provider binary override (primarily for tests)")
    run.add_argument("--model", required=True)
    run.add_argument("--reasoning-effort", default="high")
    run.add_argument("--print-timeout", default="90m")
    run.add_argument(
        "--pool-size",
        type=lambda value: positive_bounded(
            value, maximum=HARD_MAX_POOL, name="pool-size"
        ),
        default=positive_bounded(
            os.environ.get("LANE_SESSION_POOL_SIZE", str(DEFAULT_POOL_SIZE)),
            maximum=HARD_MAX_POOL,
            name="pool-size",
        ),
    )
    run.add_argument(
        "--max-tasks",
        type=lambda value: positive_bounded(
            value, maximum=HARD_MAX_TASKS, name="max-tasks"
        ),
        default=positive_bounded(
            os.environ.get("LANE_SESSION_MAX_TASKS", "7"),
            maximum=HARD_MAX_TASKS,
            name="max-tasks",
        ),
    )

    status = sub.add_parser("status", help="print run session state")
    status.add_argument("--run-dir", required=True, type=Path)
    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    if args.command == "status":
        state_path = args.run_dir.resolve() / "sessions.json"
        print(json.dumps(load_state(state_path), indent=2, sort_keys=True))
        return 0

    if not SAFE_NAME.fullmatch(args.role):
        parser.error("--role may contain only letters, numbers, dot, underscore, hyphen")
    if not SAFE_NAME.fullmatch(args.task_id):
        parser.error("--task-id may contain only letters, numbers, dot, underscore, hyphen")
    try:
        return run_provider(args)
    except (OSError, RuntimeError, subprocess.SubprocessError) as exc:
        print(f"lane-session: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
