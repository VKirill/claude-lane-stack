#!/usr/bin/env python3
"""Run Grok with run-scoped warm-session affinity.

Each run keeps a small pool of resumable writer sessions in sessions.json.
One task owns one pool slot at a time; parallel tasks spill into other slots.
"""

from __future__ import annotations

import argparse
import fcntl
import hashlib
import json
import os
import re
import select
import shutil
import signal
import subprocess
import sys
import time
import uuid
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import IO


STATE_VERSION = 1
HARD_MAX_TASKS = 10
DEFAULT_POOL_SIZE = 5
HARD_MAX_POOL = 10
SAFE_NAME = re.compile(r"^[A-Za-z0-9_.-]+$")
GROK_SANDBOX_PROFILE = "workspace"
PROTOCOL_FAILURE_EXIT = 65
MAX_PROVIDER_LOG_BYTES = 1024 * 1024
MAX_EVENT_NAME = 80
VERSION_TOKEN = re.compile(
    r"(?<![A-Za-z0-9])v?(\d+(?:\.\d+){1,3}(?:[-+][A-Za-z0-9.-]{1,32})?)(?![A-Za-z0-9])"
)
SAFE_STOP_REASONS = frozenset(
    {"EndTurn", "MaxTurns", "Stop", "Completed", "Cancelled", "Error"}
)
TOKEN_FIELDS = {
    "input_tokens",
    "cache_read_input_tokens",
    "output_tokens",
    "reasoning_tokens",
    "total_tokens",
}
MODEL_USAGE_FIELDS = {
    "inputTokens",
    "cacheReadInputTokens",
    "outputTokens",
    "reasoningTokens",
    "totalTokens",
    "modelCalls",
    "costUSD",
}


def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat()


def load_state(path: Path) -> dict:
    if not path.exists():
        return {"version": STATE_VERSION, "sessions": {}, "history": []}
    try:
        state = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise RuntimeError(f"cannot read session state {path}: {exc}") from exc
    if state.get("version") != STATE_VERSION:
        raise RuntimeError(
            f"unsupported session state version {state.get('version')!r} in {path}"
        )
    state.setdefault("sessions", {})
    state.setdefault("history", [])
    return state


def save_state(path: Path, state: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temp = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    temp.write_text(json.dumps(state, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    os.replace(temp, path)


def lock_file(path: Path, *, nonblocking: bool = False) -> IO[str] | None:
    path.parent.mkdir(parents=True, exist_ok=True)
    handle = path.open("a+", encoding="utf-8")
    flags = fcntl.LOCK_EX | (fcntl.LOCK_NB if nonblocking else 0)
    try:
        fcntl.flock(handle.fileno(), flags)
    except BlockingIOError:
        handle.close()
        return None
    return handle


def unlock_file(handle: IO[str]) -> None:
    fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
    handle.close()


def runtime_lock_dir(run_dir: Path) -> Path:
    digest = hashlib.sha256(str(run_dir.resolve()).encode("utf-8")).hexdigest()[:20]
    configured = os.environ.get("XDG_RUNTIME_DIR")
    roots = []
    if configured:
        roots.append(Path(configured) / "claude-lane-stack")
    roots.append(Path("/tmp") / f"claude-lane-stack-{os.getuid()}")

    errors: list[str] = []
    for root in roots:
        path = root / "session-locks" / digest
        try:
            path.mkdir(parents=True, exist_ok=True)
            root.chmod(0o700)
            path.chmod(0o700)
            probe = path / f".probe-{os.getpid()}"
            probe.touch(exist_ok=False)
            probe.unlink()
            return path
        except OSError as exc:
            errors.append(f"{path}: {exc}")
    raise RuntimeError("no writable session lock directory: " + "; ".join(errors))


def rotation_reason(record: dict | None, *, cwd: str, model: str, max_tasks: int) -> str | None:
    if not record:
        return None
    if record.get("invalid"):
        return record.get("invalid_reason") or "invalid"
    if record.get("status") == "running":
        return "stale_running"
    if not record.get("session_id"):
        return "missing_session_id"
    if record.get("cwd") != cwd:
        return "cwd_changed"
    if record.get("model") != model:
        return "model_changed"
    if record.get("sandbox") != GROK_SANDBOX_PROFILE:
        return "sandbox_changed"
    success_count = int(record.get("success_count", len(record.get("tasks", []))))
    if success_count >= max_tasks:
        return "task_limit"
    return None


@dataclass
class Lease:
    key: str
    slot: int
    handle: IO[str]
    record: dict
    is_new: bool


class LaneInterrupted(Exception):
    def __init__(self, signum: int) -> None:
        super().__init__(f"interrupted by signal {signum}")
        self.signum = signum


@dataclass
class StreamResult:
    provider_exit_code: int
    exit_code: int
    session_id: str | None
    stop_reason: str | None
    usage: dict | None
    model_usage: dict | None
    num_turns: int | None
    total_cost_usd: int | float | None
    total_cost_usd_ticks: int | None
    cost_is_partial: bool | None
    usage_is_incomplete: bool | None
    protocol_error: str | None
    log_truncated: bool
    stderr_bytes: int


def acquire_lease(
    *,
    run_dir: Path,
    provider: str,
    role: str,
    cwd: str,
    model: str,
    task_id: str,
    pool_size: int,
    max_tasks: int,
) -> Lease:
    state_path = run_dir / "sessions.json"
    locks_dir = runtime_lock_dir(run_dir)
    state_lock_path = locks_dir / "state.lock"
    last_wait_notice = 0.0

    while True:
        state_lock = lock_file(state_lock_path)
        assert state_lock is not None
        state = load_state(state_path)
        run_identity = str(run_dir.resolve())
        stored_run = state.get("run_dir")
        if stored_run is not None and stored_run != run_identity:
            for old_record in state["sessions"].values():
                archived = dict(old_record)
                archived["rotation_reason"] = "run_dir_changed"
                archived["rotated_at"] = utc_now()
                state["history"].append(archived)
            state["sessions"] = {}
        state["run_dir"] = run_identity

        warm: list[tuple[str, int]] = []
        cold: list[int] = []
        for slot in range(pool_size):
            key = f"{provider}:{role}:{slot}"
            record = state["sessions"].get(key)
            if record and rotation_reason(
                record, cwd=cwd, model=model, max_tasks=max_tasks
            ) is None:
                warm.append((record.get("updated_at", ""), slot))
            else:
                cold.append(slot)
        ordered_slots = [slot for _, slot in sorted(warm, reverse=True)] + cold

        selected_handle: IO[str] | None = None
        selected_slot = -1
        for slot in ordered_slots:
            handle = lock_file(
                locks_dir / f"{provider}-{role}-{slot}.lock", nonblocking=True
            )
            if handle is not None:
                selected_handle = handle
                selected_slot = slot
                break

        if selected_handle is None:
            unlock_file(state_lock)
            now = time.monotonic()
            if now - last_wait_notice >= 10:
                print(
                    f"LANE_SESSION waiting provider={provider} role={role} "
                    f"pool={pool_size}",
                    flush=True,
                )
                last_wait_notice = now
            time.sleep(0.2)
            continue

        key = f"{provider}:{role}:{selected_slot}"
        old = state["sessions"].get(key)
        reason = rotation_reason(old, cwd=cwd, model=model, max_tasks=max_tasks)
        is_new = old is None or reason is not None
        if old is not None and reason is not None:
            archived = dict(old)
            archived["rotation_reason"] = reason
            archived["rotated_at"] = utc_now()
            state["history"].append(archived)

        if is_new:
            generation = int((old or {}).get("generation", 0)) + 1
            record = {
                "provider": provider,
                "role": role,
                "slot": selected_slot,
                "generation": generation,
                "session_id": str(uuid.uuid4()) if provider == "grok" else None,
                "cwd": cwd,
                "model": model,
                "sandbox": GROK_SANDBOX_PROFILE,
                "tasks": [],
                "success_count": 0,
                "created_at": utc_now(),
                "updated_at": utc_now(),
                "status": "starting",
                "invalid": False,
            }
        else:
            record = dict(old)

        record["status"] = "running"
        record["current_task"] = task_id
        record["updated_at"] = utc_now()
        state["sessions"][key] = record
        state["defaults"] = {"pool_size": pool_size, "max_tasks": max_tasks}
        save_state(state_path, state)
        unlock_file(state_lock)
        return Lease(key, selected_slot, selected_handle, record, is_new)


def provider_command(
    args: argparse.Namespace, lease: Lease, *, prompt_sha256: str
) -> list[str]:
    if args.provider != "grok":
        raise RuntimeError(f"unsupported provider {args.provider!r}; only grok is supported")
    binary = args.binary or shutil.which(args.provider)
    if not binary:
        raise RuntimeError(f"{args.provider} binary not found")
    command = [
        binary,
        "--no-subagents",
        "--no-auto-update",
        "--prompt-file",
        str(args.prompt_file),
        "--model",
        args.model,
        "--reasoning-effort",
        args.reasoning_effort,
        "--permission-mode",
        "acceptEdits",
        "--sandbox",
        GROK_SANDBOX_PROFILE,
        "--rules",
        (
            "Lane runtime task boundary (non-negotiable): "
            f"task_id={args.task_id}; workspace={args.cwd.resolve()}; "
            f"prompt_file={args.prompt_file.resolve()}; prompt_sha256={prompt_sha256}. "
            "Treat the prompt's raw task YAML as authoritative. Write only paths "
            "matched by owns_paths, honor never_touch, do not spawn subagents, "
            "and do not commit, merge, or push."
        ),
        "--output-format",
        "streaming-json",
        "--cwd",
        str(args.cwd),
    ]
    session_id = lease.record["session_id"]
    if lease.is_new:
        command[1:1] = ["--session-id", session_id]
    else:
        command[1:1] = ["--resume", session_id]
    return command


def terminate_provider(process: subprocess.Popen[bytes] | None) -> None:
    if process is None or process.poll() is not None:
        return
    try:
        os.killpg(process.pid, signal.SIGTERM)
    except ProcessLookupError:
        return
    try:
        process.wait(timeout=3)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(process.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        process.wait(timeout=3)


def safe_scalar(value: object) -> int | float | None:
    if isinstance(value, bool) or not isinstance(value, (int, float)) or value < 0:
        return None
    return value


def sanitized_usage(value: object, allowed: set[str]) -> dict | None:
    if not isinstance(value, dict):
        return None
    result = {
        key: scalar
        for key in allowed
        if (scalar := safe_scalar(value.get(key))) is not None
    }
    return result or None


def sanitized_model_usage(value: object) -> dict | None:
    if not isinstance(value, dict):
        return None
    result: dict[str, dict] = {}
    for model, metrics in list(value.items())[:20]:
        if not isinstance(model, str) or not SAFE_NAME.fullmatch(model.replace("/", "-")):
            continue
        clean = sanitized_usage(metrics, MODEL_USAGE_FIELDS)
        if clean:
            result[model] = clean
    return result or None


def provider_version(binary: str) -> str | None:
    try:
        result = subprocess.run(
            [binary, "--version"],
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=5,
            check=False,
        )
    except (OSError, subprocess.SubprocessError):
        return None
    if result.returncode != 0:
        return None
    line = (result.stdout or "").splitlines()[0:1]
    if not line:
        return None
    match = VERSION_TOKEN.search(line[0])
    return match.group(1) if match else None


def sanitized_stop_reason(value: object) -> str | None:
    if not isinstance(value, str) or not value:
        return None
    return value if value in SAFE_STOP_REASONS else "Other"


def stream_provider(
    process: subprocess.Popen[bytes],
    output: IO[bytes],
    *,
    expected_session_id: str,
) -> StreamResult:
    assert process.stdout is not None
    assert process.stderr is not None
    stdout_fd = process.stdout.fileno()
    stderr_fd = process.stderr.fileno()
    open_fds = {stdout_fd, stderr_fd}
    pending = b""
    log_bytes = 0
    log_truncated = False
    protocol_error: str | None = None
    end_event: dict | None = None
    saw_error = False
    stderr_bytes = 0

    def write_log(data: bytes) -> None:
        nonlocal log_bytes, log_truncated
        remaining = MAX_PROVIDER_LOG_BYTES - log_bytes
        if remaining <= 0:
            log_truncated = True
            return
        chunk = data[:remaining]
        output.write(chunk)
        output.flush()
        log_bytes += len(chunk)
        if len(chunk) < len(data):
            log_truncated = True

    def visible_marker(event_type: str) -> None:
        marker = f"GROK_EVENT {event_type}\n".encode("utf-8")
        sys.stdout.buffer.write(marker)
        sys.stdout.buffer.flush()

    def set_protocol_error(reason: str, line: bytes) -> None:
        nonlocal protocol_error
        if protocol_error is not None:
            return
        protocol_error = reason
        digest = hashlib.sha256(line).hexdigest()[:16]
        write_log(
            f"\n[grok protocol error: {reason}; bytes={len(line)}; sha256={digest}]\n".encode(
                "utf-8"
            )
        )
        visible_marker("protocol-error")

    def process_line(line: bytes) -> None:
        nonlocal end_event, saw_error
        if not line.strip():
            return
        try:
            event = json.loads(line)
        except (UnicodeDecodeError, json.JSONDecodeError):
            set_protocol_error("malformed streaming-json", line)
            return
        if not isinstance(event, dict) or not isinstance(event.get("type"), str):
            set_protocol_error("event must be an object with a string type", line)
            return
        event_type = event["type"]
        if len(event_type) > MAX_EVENT_NAME or not SAFE_NAME.fullmatch(event_type):
            set_protocol_error("event type is invalid", line)
            return
        if end_event is not None:
            set_protocol_error("event received after end", line)
            return

        if event_type == "text":
            data = event.get("data")
            if not isinstance(data, str):
                set_protocol_error("text event data must be a string", line)
                return
            encoded = data.encode("utf-8", errors="replace")
            write_log(encoded)
            sys.stdout.buffer.write(encoded)
            sys.stdout.buffer.flush()
        elif event_type == "thought":
            if not isinstance(event.get("data"), str):
                set_protocol_error("thought event data must be a string", line)
                return
            write_log(b"\n[grok event: thought]\n")
            visible_marker("thought")
        elif event_type == "error":
            if not isinstance(event.get("message"), str):
                set_protocol_error("error event message must be a string", line)
                return
            saw_error = True
            write_log(b"\n[grok event: error]\n")
            visible_marker("error")
        elif event_type == "end":
            session_id = event.get("sessionId")
            stop_reason = event.get("stopReason")
            if not isinstance(session_id, str) or session_id != expected_session_id:
                set_protocol_error("end event sessionId mismatch", line)
                return
            if not isinstance(stop_reason, str) or not stop_reason:
                set_protocol_error("end event stopReason must be a non-empty string", line)
                return
            safe_stop_reason = sanitized_stop_reason(stop_reason)
            end_event = dict(event)
            end_event["stopReason"] = safe_stop_reason
            write_log(f"\n[grok end: {safe_stop_reason}]\n".encode("utf-8"))
            visible_marker("end")
        else:
            write_log(f"\n[grok event: {event_type}]\n".encode("utf-8"))
            visible_marker(event_type)

    def consume(chunk: bytes) -> None:
        nonlocal pending
        pending += chunk
        while b"\n" in pending:
            line, pending = pending.split(b"\n", 1)
            process_line(line)

    def consume_stderr(chunk: bytes) -> None:
        nonlocal stderr_bytes
        stderr_bytes += len(chunk)
        digest = hashlib.sha256(chunk).hexdigest()[:16]
        write_log(
            f"\n[grok stderr: bytes={len(chunk)}; sha256={digest}]\n".encode("utf-8")
        )
        visible_marker("stderr")

    while open_fds:
        ready, _, _ = select.select(list(open_fds), [], [], 0.1)
        for fd in ready:
            chunk = os.read(fd, 65536)
            if chunk:
                if fd == stdout_fd:
                    consume(chunk)
                else:
                    consume_stderr(chunk)
            else:
                open_fds.discard(fd)
    if pending:
        process_line(pending)

    provider_exit_code = process.wait()
    if provider_exit_code == 0 and protocol_error is None and saw_error:
        protocol_error = "provider emitted an error event"
    if provider_exit_code == 0 and protocol_error is None and end_event is None:
        protocol_error = "stream ended without an end event"
    exit_code = (
        PROTOCOL_FAILURE_EXIT
        if provider_exit_code == 0 and protocol_error is not None
        else provider_exit_code
    )
    end = end_event or {}
    num_turns = end.get("num_turns")
    if isinstance(num_turns, bool) or not isinstance(num_turns, int) or num_turns < 0:
        num_turns = None
    ticks = end.get("total_cost_usd_ticks")
    if isinstance(ticks, bool) or not isinstance(ticks, int) or ticks < 0:
        ticks = None
    return StreamResult(
        provider_exit_code=provider_exit_code,
        exit_code=exit_code,
        session_id=end.get("sessionId") if isinstance(end.get("sessionId"), str) else None,
        stop_reason=end.get("stopReason") if isinstance(end.get("stopReason"), str) else None,
        usage=sanitized_usage(end.get("usage"), TOKEN_FIELDS),
        model_usage=sanitized_model_usage(end.get("modelUsage")),
        num_turns=num_turns,
        total_cost_usd=safe_scalar(end.get("total_cost_usd")),
        total_cost_usd_ticks=ticks,
        cost_is_partial=end.get("cost_is_partial")
        if isinstance(end.get("cost_is_partial"), bool)
        else None,
        usage_is_incomplete=end.get("usage_is_incomplete")
        if isinstance(end.get("usage_is_incomplete"), bool)
        else None,
        protocol_error=protocol_error,
        log_truncated=log_truncated,
        stderr_bytes=stderr_bytes,
    )


def write_runtime_receipt(
    *,
    path: Path,
    args: argparse.Namespace,
    lease: Lease,
    prompt_sha256: str | None,
    provider_version_text: str | None,
    started_at: str,
    result: StreamResult,
    failure_class: str | None = None,
) -> None:
    receipt: dict[str, object] = {
        "schema_version": 1,
        "provider": args.provider,
        "provider_version": provider_version_text,
        "model": args.model,
        "reasoning_effort": args.reasoning_effort,
        "sandbox": GROK_SANDBOX_PROFILE,
        "subagents_enabled": False,
        "task_id": args.task_id,
        "role": args.role,
        "slot": lease.slot,
        "mode": "new" if lease.is_new else "resume",
        "session_id": result.session_id or lease.record.get("session_id"),
        "started_at": started_at,
        "finished_at": utc_now(),
        "provider_exit_code": result.provider_exit_code,
        "exit_code": result.exit_code,
        "protocol_valid": result.protocol_error is None and failure_class is None,
        "log_truncated": result.log_truncated,
        "stderr_bytes": result.stderr_bytes,
    }
    optional = {
        "stop_reason": result.stop_reason,
        "usage": result.usage,
        "model_usage": result.model_usage,
        "num_turns": result.num_turns,
        "total_cost_usd": result.total_cost_usd,
        "total_cost_usd_ticks": result.total_cost_usd_ticks,
        "cost_is_partial": result.cost_is_partial,
        "usage_is_incomplete": result.usage_is_incomplete,
        "protocol_error": result.protocol_error,
        "prompt_sha256": prompt_sha256,
        "failure_class": failure_class,
    }
    receipt.update({key: value for key, value in optional.items() if value is not None})
    save_state(path, receipt)


def finish_lease(
    *,
    run_dir: Path,
    lease: Lease,
    task_id: str,
    exit_code: int,
    captured_session_id: str | None,
) -> dict:
    state_path = run_dir / "sessions.json"
    state_lock = lock_file(runtime_lock_dir(run_dir) / "state.lock")
    assert state_lock is not None
    state = load_state(state_path)
    record = dict(state["sessions"].get(lease.key, lease.record))
    record.pop("current_task", None)
    record["updated_at"] = utc_now()

    if exit_code == 0 and captured_session_id:
        record["session_id"] = captured_session_id
    if exit_code == 0 and record.get("session_id"):
        record["success_count"] = int(
            record.get("success_count", len(record.get("tasks", [])))
        ) + 1
        if task_id not in record["tasks"]:
            record["tasks"].append(task_id)
        record["status"] = "idle"
        record["invalid"] = False
        record.pop("invalid_reason", None)
    elif exit_code == 0:
        record["status"] = "capture_failed"
        record["invalid"] = True
        record["invalid_reason"] = "conversation_capture_failed"
    else:
        record["status"] = "failed"
        record["invalid"] = True
        record["invalid_reason"] = f"provider_exit_{exit_code}"

    state["sessions"][lease.key] = record
    save_state(state_path, state)
    unlock_file(state_lock)
    return record


def run_provider(args: argparse.Namespace) -> int:
    run_dir = args.run_dir.resolve()
    cwd = args.cwd.resolve()
    if not cwd.is_dir():
        raise RuntimeError(f"cwd is not a directory: {cwd}")
    if not args.prompt_file.is_file():
        raise RuntimeError(f"prompt file not found: {args.prompt_file}")

    lease = acquire_lease(
        run_dir=run_dir,
        provider=args.provider,
        role=args.role,
        cwd=str(cwd),
        model=args.model,
        task_id=args.task_id,
        pool_size=args.pool_size,
        max_tasks=args.max_tasks,
    )
    completed = False
    captured: str | None = lease.record.get("session_id")
    process: subprocess.Popen[bytes] | None = None
    result: StreamResult | None = None
    version_text: str | None = None
    prompt_sha256: str | None = None
    started_at = utc_now()
    old_handlers: dict[int, signal.Handlers] = {}

    def handle_signal(signum: int, _frame: object) -> None:
        raise LaneInterrupted(signum)

    for signum in (signal.SIGINT, signal.SIGTERM):
        old_handlers[signum] = signal.getsignal(signum)
        signal.signal(signum, handle_signal)
    try:
        prompt_sha256 = hashlib.sha256(args.prompt_file.read_bytes()).hexdigest()
        command = provider_command(args, lease, prompt_sha256=prompt_sha256)
        version_text = provider_version(command[0])
        args.output.parent.mkdir(parents=True, exist_ok=True)

        print(
            f"LANE_SESSION start provider={args.provider} role={args.role} "
            f"slot={lease.slot} mode={'new' if lease.is_new else 'resume'} "
            f"task={args.task_id}",
            flush=True,
        )
        provider_env = os.environ.copy()
        provider_env.update(
            {
                "CLAUDE_LANE_AUTOMATION": "1",
                "GROK_CLAUDE_HOOKS_ENABLED": "0",
                "GROK_SUBAGENTS": "0",
                "GROK_SANDBOX": GROK_SANDBOX_PROFILE,
            }
        )
        with args.output.open("wb") as output:
            process = subprocess.Popen(
                command,
                cwd=cwd,
                env=provider_env,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                start_new_session=True,
            )
            result = stream_provider(
                process,
                output,
                expected_session_id=str(lease.record["session_id"]),
            )
            if result.session_id:
                captured = result.session_id
            exit_code = result.exit_code

        record = finish_lease(
            run_dir=run_dir,
            lease=lease,
            task_id=args.task_id,
            exit_code=exit_code,
            captured_session_id=captured,
        )
        write_runtime_receipt(
            path=args.output.with_name("runtime.json"),
            args=args,
            lease=lease,
            prompt_sha256=prompt_sha256,
            provider_version_text=version_text,
            started_at=started_at,
            result=result,
        )
        completed = True
        print(
            f"LANE_SESSION done provider={args.provider} slot={lease.slot} "
            f"task={args.task_id} exit={exit_code} status={record['status']} "
            f"turns={record['success_count']}",
            flush=True,
        )
        return exit_code
    except LaneInterrupted as exc:
        terminate_provider(process)
        exit_code = 128 + exc.signum
        finish_lease(
            run_dir=run_dir,
            lease=lease,
            task_id=args.task_id,
            exit_code=exit_code,
            captured_session_id=captured,
        )
        result = StreamResult(
            provider_exit_code=exit_code,
            exit_code=exit_code,
            session_id=captured,
            stop_reason=None,
            usage=None,
            model_usage=None,
            num_turns=None,
            total_cost_usd=None,
            total_cost_usd_ticks=None,
            cost_is_partial=None,
            usage_is_incomplete=None,
            protocol_error="interrupted",
            log_truncated=False,
            stderr_bytes=0,
        )
        write_runtime_receipt(
            path=args.output.with_name("runtime.json"),
            args=args,
            lease=lease,
            prompt_sha256=prompt_sha256,
            provider_version_text=version_text,
            started_at=started_at,
            result=result,
        )
        completed = True
        print(
            f"LANE_SESSION interrupted provider={args.provider} slot={lease.slot} "
            f"task={args.task_id} signal={exc.signum}",
            file=sys.stderr,
            flush=True,
        )
        return exit_code
    except BaseException as exc:
        try:
            terminate_provider(process)
        except Exception as cleanup_exc:
            print(
                "lane-session: provider cleanup failed "
                f"({type(cleanup_exc).__name__})",
                file=sys.stderr,
            )
        if not completed:
            try:
                finish_lease(
                    run_dir=run_dir,
                    lease=lease,
                    task_id=args.task_id,
                    exit_code=125,
                    captured_session_id=captured,
                )
            except Exception as state_exc:
                print(
                    "lane-session: failed to invalidate session "
                    f"({type(state_exc).__name__})",
                    file=sys.stderr,
                )
            failure = StreamResult(
                provider_exit_code=125,
                exit_code=125,
                session_id=captured,
                stop_reason=None,
                usage=None,
                model_usage=None,
                num_turns=None,
                total_cost_usd=None,
                total_cost_usd_ticks=None,
                cost_is_partial=None,
                usage_is_incomplete=None,
                protocol_error=None,
                log_truncated=False,
                stderr_bytes=0,
            )
            try:
                write_runtime_receipt(
                    path=args.output.with_name("runtime.json"),
                    args=args,
                    lease=lease,
                    prompt_sha256=prompt_sha256,
                    provider_version_text=version_text,
                    started_at=started_at,
                    result=failure,
                    failure_class=type(exc).__name__,
                )
            except Exception as receipt_exc:
                print(
                    "lane-session: failed to write runtime receipt "
                    f"({type(receipt_exc).__name__})",
                    file=sys.stderr,
                )
        raise
    finally:
        for signum, old_handler in old_handlers.items():
            signal.signal(signum, old_handler)
        unlock_file(lease.handle)


def positive_bounded(value: str, *, maximum: int, name: str) -> int:
    parsed = int(value)
    if parsed < 1 or parsed > maximum:
        raise argparse.ArgumentTypeError(f"{name} must be between 1 and {maximum}")
    return parsed


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Run Grok in a warm, run-scoped session pool"
    )
    sub = parser.add_subparsers(dest="command", required=True)

    run = sub.add_parser("run", help="acquire a session slot and run one task")
    run.add_argument("--provider", required=True, choices=("grok",))
    run.add_argument("--run-dir", required=True, type=Path)
    run.add_argument("--task-id", required=True)
    run.add_argument("--role", required=True)
    run.add_argument("--cwd", required=True, type=Path)
    run.add_argument("--prompt-file", required=True, type=Path)
    run.add_argument("--output", required=True, type=Path)
    run.add_argument("--binary", help="provider binary override (primarily for tests)")
    run.add_argument("--model", required=True)
    run.add_argument("--reasoning-effort", default="high")
    run.add_argument("--print-timeout", default="90m")
    run.add_argument(
        "--pool-size",
        type=lambda value: positive_bounded(
            value, maximum=HARD_MAX_POOL, name="pool-size"
        ),
        default=positive_bounded(
            os.environ.get("LANE_SESSION_POOL_SIZE", str(DEFAULT_POOL_SIZE)),
            maximum=HARD_MAX_POOL,
            name="pool-size",
        ),
    )
    run.add_argument(
        "--max-tasks",
        type=lambda value: positive_bounded(
            value, maximum=HARD_MAX_TASKS, name="max-tasks"
        ),
        default=positive_bounded(
            os.environ.get("LANE_SESSION_MAX_TASKS", "7"),
            maximum=HARD_MAX_TASKS,
            name="max-tasks",
        ),
    )

    status = sub.add_parser("status", help="print run session state")
    status.add_argument("--run-dir", required=True, type=Path)
    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    if args.command == "status":
        state_path = args.run_dir.resolve() / "sessions.json"
        print(json.dumps(load_state(state_path), indent=2, sort_keys=True))
        return 0

    if not SAFE_NAME.fullmatch(args.role):
        parser.error("--role may contain only letters, numbers, dot, underscore, hyphen")
    if not SAFE_NAME.fullmatch(args.task_id):
        parser.error("--task-id may contain only letters, numbers, dot, underscore, hyphen")
    try:
        return run_provider(args)
    except (OSError, RuntimeError, subprocess.SubprocessError) as exc:
        print(f"lane-session: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
