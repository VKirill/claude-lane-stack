#!/usr/bin/env python3
"""Typed control plane for detached AGY/Grok lanes.

The CLI deliberately exposes lifecycle operations, not a generic command
runner. Provider launches are assembled here from validated task contracts;
retries replay the recorded argv vector; verification commands can only come
from the task YAML.
"""

from __future__ import annotations

import argparse
import fcntl
import hashlib
import json
import os
import re
import shutil
import signal
import subprocess
import sys
import time
from contextlib import contextmanager
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import IO, Iterator


BIN_DIR = Path(__file__).resolve().parent
if str(BIN_DIR) not in sys.path:
    sys.path.insert(0, str(BIN_DIR))

from verification_safety import verification_argv, verification_error


ROOT = Path(__file__).resolve().parents[1]
LANE_BG = ROOT / "bin" / "lane-bg"
LANE_EXEC = ROOT / "bin" / "lane-exec"
LANE_SESSION = ROOT / "bin" / "lane-session"
WRITER_CONTRACT = ROOT / "agents" / "grok" / "writer.md"

SAFE_NAME = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$")
SAFE_MODEL = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_.:/-]{0,127}$")
HARD_PROVIDER_POOL = 10
HARD_VERIFY_POOL = 10
HARD_MAX_TASKS = 10
HARD_TAIL_LINES = 1000
HARD_VERIFY_TIMEOUT = 86400
HARD_V2_VERIFY_TIMEOUT = 7200
MAX_PRIMARY_ATTEMPTS = 2
MAX_ATTEMPTS = 3
PRIMARY_MODELS = {
    "agy": "gemini-3.6-flash-high",
    "grok": "grok-4.5",
    "qwen": "qwen3.8-max-preview",
}
CODEX_FALLBACK_MODEL = "gpt-5.6-sol"
CODEX_FALLBACK_REASONING = "high"
TAIL_SOURCES = {
    "supervisor": "lane-bg.supervisor.log",
    "executor": "lane-exec.log",
    "provider": "provider.out",
    "report": "report.md",
    "verification": "verified.txt",
}
REVIEW_RECEIPT_FIELDS = {
    "schema_version",
    "receipt_type",
    "task_id",
    "task_sha256",
    "attempt",
    "project_cwd",
    "base_ref",
    "reviewed_diff_sha256",
    "reviewed_tree_sha256",
    "verdict",
    "findings",
    "reviewed_at",
}
SHA256_HEX = re.compile(r"^[0-9a-f]{64}$")
GIT_COMMIT_HEX = re.compile(r"^(?:[0-9a-f]{40}|[0-9a-f]{64})$")


class ContractError(RuntimeError):
    """A caller supplied a value outside the typed control-plane contract."""


class OperationError(RuntimeError):
    """A validated lifecycle operation failed to execute."""


@dataclass(frozen=True)
class TaskContext:
    run_dir: Path
    task_id: str
    task_file: Path
    project_cwd: Path
    artifact_dir: Path
    task: dict
    raw_task: str


def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat()


def json_bytes(payload: object) -> bytes:
    return (json.dumps(payload, indent=2, sort_keys=True) + "\n").encode("utf-8")


def atomic_write(path: Path, data: str | bytes) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temp = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    if isinstance(data, str):
        temp.write_text(data, encoding="utf-8")
    else:
        temp.write_bytes(data)
    os.replace(temp, path)


def write_json(path: Path, payload: object) -> None:
    atomic_write(path, json_bytes(payload))


def read_json(path: Path) -> dict:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError as exc:
        raise ContractError(f"required state file not found: {path}") from exc
    except (OSError, json.JSONDecodeError) as exc:
        raise ContractError(f"cannot read JSON state {path}: {exc}") from exc
    if not isinstance(value, dict):
        raise ContractError(f"JSON state must be an object: {path}")
    return value


def is_within(path: Path, root: Path) -> bool:
    try:
        path.relative_to(root)
    except ValueError:
        return False
    return True


def validate_name(value: str, label: str) -> str:
    if not SAFE_NAME.fullmatch(value):
        raise ContractError(
            f"{label} must contain only letters, numbers, dot, underscore, or hyphen"
        )
    return value


def validate_run_dir(value: str | Path) -> Path:
    path = Path(value).expanduser().resolve()
    if not path.is_dir():
        raise ContractError(f"RUN_DIR is not a directory: {path}")
    if path.parent.name != "runs" or path.parent.parent.name != ".agents":
        raise ContractError(f"RUN_DIR must be .agents/runs/<slug>: {path}")
    validate_name(path.name, "run slug")
    return path


def artifact_dir_for(run_dir: Path, task_id: str, *, create: bool = False) -> Path:
    validate_name(task_id, "task id")
    artifacts_root = (run_dir / "artifacts").resolve(strict=False)
    if not is_within(artifacts_root, run_dir):
        raise ContractError("RUN_DIR/artifacts may not escape through a symlink")
    artifact_dir = (artifacts_root / task_id).resolve(strict=False)
    if not is_within(artifact_dir, artifacts_root):
        raise ContractError("artifact path must stay under RUN_DIR/artifacts")
    if create:
        artifact_dir.mkdir(parents=True, exist_ok=True)
    return artifact_dir


def safe_child_file(root: Path, name: str) -> Path:
    """Resolve a fixed artifact filename without following an escape symlink."""
    candidate = root / name
    resolved = candidate.resolve(strict=False)
    if not is_within(resolved, root):
        raise ContractError(f"artifact file may not escape its root: {candidate}")
    return candidate


def load_task_yaml(task_file: Path) -> tuple[dict, str]:
    try:
        raw = task_file.read_text(encoding="utf-8")
    except OSError as exc:
        raise ContractError(f"cannot read task YAML {task_file}: {exc}") from exc
    try:
        import yaml  # type: ignore

        value = yaml.safe_load(raw) or {}
    except ImportError as exc:
        raise ContractError("PyYAML is required to read task contracts") from exc
    except Exception as exc:
        raise ContractError(f"cannot parse task YAML {task_file}: {exc}") from exc
    if not isinstance(value, dict):
        raise ContractError(f"task YAML must contain a mapping: {task_file}")
    return value, raw


def load_yaml_mapping(path: Path, label: str) -> dict:
    try:
        raw = path.read_text(encoding="utf-8")
    except OSError as exc:
        raise ContractError(f"cannot read {label} {path}: {exc}") from exc
    try:
        import yaml  # type: ignore

        value = yaml.safe_load(raw) or {}
    except ImportError as exc:
        raise ContractError(f"PyYAML is required to read {label}") from exc
    except Exception as exc:
        raise ContractError(f"cannot parse {label} {path}: {exc}") from exc
    if not isinstance(value, dict):
        raise ContractError(f"{label} must contain a mapping: {path}")
    return value


def context_schema_version(context: TaskContext) -> tuple[int, dict | None]:
    task_version = context.task.get("schema_version", 1)
    if not isinstance(task_version, int):
        raise ContractError("task schema_version must be an integer")
    run_path = safe_child_file(context.run_dir, "run.yaml")
    if not run_path.exists():
        if task_version >= 2:
            raise ContractError("schema_version 2 tasks require RUN_DIR/run.yaml")
        return 1, None
    run_contract = load_yaml_mapping(run_path, "run.yaml")
    run_version = run_contract.get("schema_version")
    if run_version != 2:
        raise ContractError("run.yaml schema_version must be 2")
    if task_version != 2:
        raise ContractError("tasks in a schema_version 2 run must declare schema_version: 2")
    return 2, run_contract


def task_digest(context: TaskContext) -> str:
    try:
        return hashlib.sha256(context.task_file.read_bytes()).hexdigest()
    except OSError as exc:
        raise ContractError(f"cannot hash task YAML {context.task_file}: {exc}") from exc


def state_path_for(artifact_dir: Path) -> Path:
    return safe_child_file(artifact_dir, "state.json")


def load_task_state(artifact_dir: Path) -> dict | None:
    return read_optional_json(state_path_for(artifact_dir))


def write_task_state(artifact_dir: Path, state: dict) -> None:
    write_json(state_path_for(artifact_dir), state)


def attempt_dir_for(
    artifact_dir: Path, attempt: int, *, create: bool = False
) -> Path:
    if not isinstance(attempt, int) or attempt < 1 or attempt > 99:
        raise ContractError("attempt must be between 1 and 99")
    attempts_root = (artifact_dir / "attempts").resolve(strict=False)
    if not is_within(attempts_root, artifact_dir):
        raise ContractError("attempts path may not escape the task artifact root")
    attempt_dir = (attempts_root / f"{attempt:02d}").resolve(strict=False)
    if not is_within(attempt_dir, attempts_root):
        raise ContractError("attempt path may not escape attempts")
    if create:
        try:
            attempt_dir.mkdir(parents=True, exist_ok=False)
        except FileExistsError as exc:
            raise ContractError(f"attempt directory already exists: {attempt_dir}") from exc
        except OSError as exc:
            raise OperationError(f"cannot create attempt directory {attempt_dir}: {exc}") from exc
    return attempt_dir


def current_attempt_dir(artifact_dir: Path, state: dict) -> Path:
    attempt = state.get("current_attempt", state.get("attempt"))
    if not isinstance(attempt, int) or attempt < 1:
        raise ContractError("state.json current_attempt is invalid")
    return attempt_dir_for(artifact_dir, attempt)


def require_immutable_task(context: TaskContext, state: dict) -> None:
    if state.get("schema_version") != 2:
        raise ContractError("state.json schema_version must be 2")
    if state.get("task_id") != context.task_id:
        raise ContractError("state.json task identity mismatch")
    if state.get("task_file") != str(context.task_file):
        raise ContractError("task file differs from immutable state")
    expected = state.get("task_sha256")
    actual = task_digest(context)
    if not isinstance(expected, str) or expected != actual:
        raise ContractError("task YAML changed after first start (sha256 mismatch)")


def context_from_state(run_dir: Path, task_id: str, state: dict) -> TaskContext:
    task_file = state.get("task_file")
    project_cwd = state.get("project_cwd")
    if not isinstance(task_file, str) or not isinstance(project_cwd, str):
        raise ContractError("state.json is missing task_file/project_cwd")
    context = validate_task_context(
        run_dir_value=run_dir,
        task_id=task_id,
        task_file_value=task_file,
        project_cwd_value=project_cwd,
        create_artifact=False,
    )
    version, _ = context_schema_version(context)
    if version != 2:
        raise ContractError("state.json v2 requires a schema_version 2 contract")
    require_immutable_task(context, state)
    return context


def validate_task_context(
    *,
    run_dir_value: str | Path,
    task_id: str | None,
    task_file_value: str | Path,
    project_cwd_value: str | Path,
    create_artifact: bool,
) -> TaskContext:
    run_dir = validate_run_dir(run_dir_value)
    tasks_root = (run_dir / "tasks").resolve()
    if not is_within(tasks_root, run_dir):
        raise ContractError("RUN_DIR/tasks may not escape through a symlink")
    task_file = Path(task_file_value).expanduser().resolve()
    if not task_file.is_file() or not is_within(task_file, tasks_root):
        raise ContractError("task_file must be a file under RUN_DIR/tasks")

    project_cwd = Path(project_cwd_value).expanduser().resolve()
    if not project_cwd.is_dir():
        raise ContractError(f"project_cwd is not a directory: {project_cwd}")

    task, raw_task = load_task_yaml(task_file)
    yaml_task_id = str(task.get("id", ""))
    validate_name(yaml_task_id, "task YAML id")
    effective_task_id = task_id or yaml_task_id
    validate_name(effective_task_id, "task id")
    if yaml_task_id != effective_task_id:
        raise ContractError(
            f"task id mismatch: selector={effective_task_id!r}, YAML={task.get('id')!r}"
        )
    contract_cwd = task.get("project_cwd")
    if not isinstance(contract_cwd, str) or not contract_cwd:
        raise ContractError("task YAML must declare project_cwd")
    if Path(contract_cwd).expanduser().resolve() != project_cwd:
        raise ContractError("--project-cwd must equal task YAML project_cwd")

    artifact_dir = artifact_dir_for(
        run_dir, effective_task_id, create=create_artifact
    )
    return TaskContext(
        run_dir=run_dir,
        task_id=effective_task_id,
        task_file=task_file,
        project_cwd=project_cwd,
        artifact_dir=artifact_dir,
        task=task,
        raw_task=raw_task,
    )


def prompt_for(context: TaskContext) -> str:
    try:
        writer = WRITER_CONTRACT.read_text(encoding="utf-8")
    except OSError as exc:
        raise OperationError(f"cannot read canonical writer contract: {exc}") from exc
    header = (
        "\n\n---\n"
        f"PROJECT_CWD: {context.project_cwd}\n"
        f"TASK_FILE: {context.task_file}\n"
        f"ARTIFACT_DIR: {context.artifact_dir}\n"
        "--- RAW TASK YAML (verbatim) ---\n"
    )
    return writer.rstrip() + header + context.raw_task


def append_event(run_dir: Path, event_type: str, task_id: str, **fields: object) -> None:
    event = {"ts": utc_now(), "type": event_type, "task_id": task_id, **fields}
    event_path = safe_child_file(run_dir, "events.jsonl")
    event_path.parent.mkdir(parents=True, exist_ok=True)
    line = json.dumps(event, sort_keys=True, separators=(",", ":")) + "\n"
    with event_path.open("a", encoding="utf-8") as handle:
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
        handle.write(line)
        handle.flush()
        os.fsync(handle.fileno())
        fcntl.flock(handle.fileno(), fcntl.LOCK_UN)


def read_events(run_dir: Path, task_id: str | None = None) -> list[dict]:
    path = safe_child_file(run_dir, "events.jsonl")
    if not path.exists():
        return []
    events: list[dict] = []
    try:
        with path.open("r", encoding="utf-8") as handle:
            fcntl.flock(handle.fileno(), fcntl.LOCK_SH)
            lines = handle.readlines()
            fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
    except OSError as exc:
        raise OperationError(f"cannot read lifecycle events: {exc}") from exc
    for line_number, line in enumerate(lines, 1):
        if not line.strip():
            continue
        try:
            event = json.loads(line)
        except json.JSONDecodeError as exc:
            raise OperationError(
                f"invalid JSON in {path} at line {line_number}: {exc}"
            ) from exc
        if not isinstance(event, dict):
            raise OperationError(f"non-object lifecycle event at line {line_number}")
        if task_id is None or event.get("task_id") == task_id:
            events.append(event)
    return events


def parse_int_file(path: Path) -> int | None:
    try:
        return int(path.read_text(encoding="utf-8").strip())
    except (FileNotFoundError, OSError, ValueError):
        return None


def pid_start_time(pid: int) -> int | None:
    try:
        parts = Path(f"/proc/{pid}/stat").read_text(encoding="utf-8").split()
        return int(parts[21])
    except (OSError, IndexError, ValueError):
        return None


def pid_alive(pid: int | None, expected_start: int | None = None) -> bool:
    if pid is None or pid <= 1:
        return False
    try:
        parts = Path(f"/proc/{pid}/stat").read_text(encoding="utf-8").split()
        if len(parts) < 22 or parts[2] == "Z":
            return False
        if expected_start is not None and int(parts[21]) != expected_start:
            return False
        os.kill(pid, 0)
        return True
    except (OSError, ValueError):
        return False


def read_optional_json(path: Path) -> dict | None:
    if not path.exists():
        return None
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    return value if isinstance(value, dict) else None


def legacy_verification_receipt_trusted(
    run_dir: Path, control: dict, verification: dict | None
) -> bool:
    """Reject green receipts that do not prove the recorded legacy snapshot."""
    if not verification or verification.get("status") != "passed":
        return False
    attempt = control.get("attempt")
    if verification.get("attempt") != attempt:
        return False
    snapshot = control.get("verification_commands")
    records = verification.get("commands")
    if not isinstance(snapshot, list) or not isinstance(records, list):
        return False
    observed: list[str] = []
    for record in records:
        if (
            not isinstance(record, dict)
            or not isinstance(record.get("command"), str)
            or record.get("exit_code") != 0
        ):
            return False
        observed.append(record["command"])
    if observed != snapshot:
        return False
    if snapshot:
        return True

    task_file_value = control.get("task_file")
    if not isinstance(task_file_value, str):
        return False
    task_file = Path(task_file_value).expanduser().resolve()
    tasks_root = (run_dir / "tasks").resolve()
    if not task_file.is_file() or not is_within(task_file, tasks_root):
        return False
    try:
        task, _ = load_task_yaml(task_file)
    except ContractError:
        return False
    return str(task.get("verify", "none")).strip().lower() == "none"


def v2_verification_receipt_trusted(
    state: dict, task_id: str, verification: dict | None
) -> bool:
    if not verification or verification.get("schema_version") != 2:
        return False
    attempt = state.get("current_attempt", state.get("attempt"))
    return (
        verification.get("task_id") == task_id
        and verification.get("task_sha256") == state.get("task_sha256")
        and verification.get("attempt") == attempt
        and verification.get("task_file") == state.get("task_file")
        and verification.get("project_cwd") == state.get("project_cwd")
    )


def v2_review_receipt_identity_trusted(
    state: dict, task_id: str, review: dict | None
) -> bool:
    task_sha256 = state.get("task_sha256")
    attempt = state.get("current_attempt", state.get("attempt"))
    project_cwd = state.get("project_cwd")
    if (
        not review
        or not isinstance(task_sha256, str)
        or not isinstance(attempt, int)
        or not isinstance(project_cwd, str)
    ):
        return False
    try:
        require_review_receipt_identity(
            review,
            task_id=task_id,
            task_sha256=task_sha256,
            attempt=attempt,
            project_cwd=Path(project_cwd),
        )
    except ContractError:
        return False
    return True


def trusted_provider_report(
    artifact: Path,
    state: dict,
    task_id: str,
    control: dict | None = None,
) -> dict:
    attempt = state.get("current_attempt", state.get("attempt"))
    if not isinstance(attempt, int) or attempt < 1:
        return {"trusted": False, "reason": "attempt_invalid"}
    attempt_dir = current_attempt_dir(artifact, state)
    runtime_path = safe_child_file(attempt_dir, "runtime.json")
    if runtime_path.is_symlink() or not runtime_path.is_file():
        return {"trusted": False, "reason": "runtime_missing"}
    runtime = read_optional_json(runtime_path)
    if runtime is None:
        return {"trusted": False, "reason": "runtime_missing"}
    control_path = safe_child_file(attempt_dir, "control.json")
    if control_path.is_symlink() or not control_path.is_file():
        return {"trusted": False, "reason": "control_missing"}
    expected_control = control or read_optional_json(control_path)
    if expected_control is None:
        return {"trusted": False, "reason": "control_missing"}
    prompt_sha256 = expected_control.get("prompt_sha256")
    control_identity_valid = (
        expected_control.get("task_id") == task_id
        and expected_control.get("attempt") == attempt
        and expected_control.get("task_sha256") == state.get("task_sha256")
    )
    provider = runtime.get("provider")
    expected_provider = expected_control.get("provider", "qwen")
    provider_identity_valid = (
        provider in {"agy", "grok", "codex", "qwen"}
        and provider == expected_provider
        and runtime.get("model") == expected_control.get("model", runtime.get("model"))
        and runtime.get("reasoning_effort")
        == expected_control.get("reasoning_effort", runtime.get("reasoning_effort"))
    )
    provider_policy_valid = (
        provider == "agy"
        and runtime.get("stop_reason") == "TurnCompleted"
        and runtime.get("provider_sandbox") == "off"
        and runtime.get("permission_mode") == "always-proceed"
    ) or (
        provider == "grok"
        and runtime.get("stop_reason") == "EndTurn"
        and runtime.get("provider_sandbox") == "off"
        and runtime.get("permission_mode") == "bypassPermissions"
    ) or (
        provider == "codex"
        and runtime.get("model") == CODEX_FALLBACK_MODEL
        and runtime.get("reasoning_effort") == CODEX_FALLBACK_REASONING
        and runtime.get("stop_reason") == "TurnCompleted"
        and runtime.get("provider_sandbox") == "workspace-write"
        and runtime.get("permission_mode") == "never"
    ) or (
        provider == "qwen"
        and runtime.get("stop_reason") == "TurnCompleted"
        and runtime.get("provider_sandbox") == "off"
        and runtime.get("permission_mode") == "yolo"
    )
    required_runtime = (
        control_identity_valid
        and provider_identity_valid
        and provider_policy_valid
        and runtime.get("schema_version") == 1
        and runtime.get("task_id") == task_id
        and runtime.get("attempt") == attempt
        and runtime.get("provider_exit_code") == 0
        and runtime.get("exit_code") == 0
        and runtime.get("protocol_valid") is True
        and runtime.get("sandbox") == "bubblewrap-workspace"
        and runtime.get("subagents_enabled") is False
        and runtime.get("control_plane_read_only") is True
        and isinstance(prompt_sha256, str)
        and SHA256_HEX.fullmatch(prompt_sha256) is not None
        and runtime.get("prompt_sha256") == prompt_sha256
    )
    if not required_runtime:
        return {"trusted": False, "reason": "runtime_identity_mismatch"}
    recorded_sha256 = runtime.get("report_sha256")
    if not isinstance(recorded_sha256, str) or not SHA256_HEX.fullmatch(
        recorded_sha256
    ):
        return {"trusted": False, "reason": "runtime_report_digest_missing"}
    report_path = safe_child_file(artifact, "report.md")
    if report_path.is_symlink() or not report_path.is_file():
        return {"trusted": False, "reason": "report_missing"}
    try:
        report_bytes = report_path.read_bytes()
        report_text = report_bytes.decode("utf-8")
    except (OSError, UnicodeDecodeError):
        return {"trusted": False, "reason": "report_unreadable"}
    actual_sha256 = hashlib.sha256(report_bytes).hexdigest()
    if actual_sha256 != recorded_sha256:
        return {"trusted": False, "reason": "report_digest_mismatch"}
    task_matches = re.findall(r"(?m)^TASK_ID:\s*(\S+)\s*$", report_text)
    prompt_matches = re.findall(
        r"(?m)^PROMPT_SHA256:\s*([0-9a-f]{64})\s*$", report_text
    )
    if task_matches != [task_id] or prompt_matches != [prompt_sha256]:
        return {"trusted": False, "reason": "report_identity_mismatch"}
    report_status = markdown_field(report_path, ("STATUS",))
    return {
        "trusted": True,
        "reason": "runtime_report_digest_valid",
        "sha256": actual_sha256,
        "status": report_status,
        "runtime": runtime,
    }


def task_status_v2(
    run_dir: Path,
    task_id: str,
    artifact: Path,
    state: dict,
    *,
    persist: bool = False,
) -> dict:
    attempt_dir = current_attempt_dir(artifact, state)
    control = read_optional_json(safe_child_file(attempt_dir, "control.json")) or {}
    pid = parse_int_file(safe_child_file(attempt_dir, "lane-bg.pid"))
    expected_start = control.get("pid_start_time")
    if not isinstance(expected_start, int):
        expected_start = None
    running = pid_alive(pid, expected_start)
    exit_code = parse_int_file(safe_child_file(attempt_dir, "lane-bg.exit"))
    runtime = read_optional_json(safe_child_file(attempt_dir, "runtime.json")) or {}
    heartbeat_path = safe_child_file(artifact, "heartbeat.json")
    heartbeat_value = read_optional_json(heartbeat_path)
    heartbeat = {
        "exists": heartbeat_path.is_file(),
        "path": str(heartbeat_path),
        "age_seconds": (
            max(0.0, time.time() - heartbeat_path.stat().st_mtime)
            if heartbeat_path.exists()
            else None
        ),
        "value": heartbeat_value,
    }
    report_path = safe_child_file(artifact, "report.md")
    report_evidence = trusted_provider_report(
        artifact, state, task_id, control=control
    )
    report_status = report_evidence.get("status")
    report_complete = bool(
        report_evidence.get("trusted") and report_status == "complete"
    )
    verification_path = safe_child_file(attempt_dir, "verification.json")
    verification = read_optional_json(verification_path)
    verification_trusted = v2_verification_receipt_trusted(
        state, task_id, verification
    )
    review_path = safe_child_file(artifact, "review.json")
    review = read_optional_json(review_path)
    review_trusted = v2_review_receipt_identity_trusted(state, task_id, review)
    acceptance_path = safe_child_file(artifact, "acceptance.json")
    acceptance = read_optional_json(acceptance_path) or {}
    accepted_review = acceptance.get("review")
    review_binding_trusted = accepted_review == "not_required" or (
        accepted_review == "passed" and review_trusted
    )
    accepted = (
        report_complete
        and verification_trusted
        and verification is not None
        and verification.get("status") == "passed"
        and review_binding_trusted
        and acceptance.get("schema_version") == 2
        and acceptance.get("task_id") == task_id
        and acceptance.get("task_sha256") == state.get("task_sha256")
        and isinstance(acceptance.get("attempt"), int)
        and acceptance.get("attempt")
        == state.get("current_attempt", state.get("attempt"))
        and acceptance.get("provider_exit") == 0
        and acceptance.get(
            "provider", (report_evidence.get("runtime") or {}).get("provider")
        )
        == (report_evidence.get("runtime") or {}).get("provider")
        and acceptance.get(
            "model", (report_evidence.get("runtime") or {}).get("model")
        )
        == (report_evidence.get("runtime") or {}).get("model")
        and acceptance.get("report") == "complete"
        and acceptance.get("report_sha256") == report_evidence.get("sha256")
        and acceptance.get("owns_check") == "passed"
        and acceptance.get("verification") == "passed"
        and acceptance.get("review") in {"passed", "not_required"}
        and acceptance.get("accepted") is True
        and isinstance(acceptance.get("accepted_at"), str)
        and bool(acceptance.get("accepted_at"))
    )

    if accepted:
        status = "accepted"
        reason = "acceptance_valid"
        next_action = "none"
    elif state.get("status") == "cancelled":
        status = "cancelled"
        reason = "cancel_requested"
        next_action = "retry"
    elif state.get("status") == "stalled" and running:
        status = "stalled"
        reason = "heartbeat_stalled"
        next_action = "cancel"
    elif running:
        status = "running"
        reason = "provider_running"
        next_action = "wait"
    elif exit_code == 0:
        if not report_complete:
            status = "provider_incomplete"
            reason = (
                "report_incomplete"
                if report_evidence.get("trusted")
                else str(report_evidence.get("reason", "report_untrusted"))
            )
            next_action = "retry"
        elif verification_trusted and verification.get("status") == "passed":
            status = "verified"
            reason = "verification_passed"
            next_action = "accept"
        elif verification_trusted and verification.get("status") == "failed":
            status = "verification_failed"
            reason = "verification_failed"
            next_action = "retry"
        elif verification_trusted and verification.get("status") == "running":
            status = "verifying"
            reason = "verification_running"
            next_action = "wait"
        else:
            status = "awaiting_verification"
            reason = "provider_complete"
            next_action = "verify"
    elif exit_code is not None:
        status = "failed"
        reason = "provider_exit_nonzero"
        next_action = "retry"
    elif control:
        status = "unknown"
        reason = "provider_state_unknown"
        next_action = "inspect"
    else:
        status = "not_started"
        reason = "not_started"
        next_action = "start"

    if persist and (state.get("status") != status or state.get("accepted") is not accepted):
        state = dict(state)
        state["status"] = status
        state["accepted"] = accepted
        state["updated_at"] = utc_now()
        write_task_state(artifact, state)

    provider = {
        "name": runtime.get("provider"),
        "model": runtime.get("model"),
        "reasoning_effort": runtime.get("reasoning_effort"),
        "failure_class": runtime.get("failure_class"),
        "failure_retryable": runtime.get("failure_retryable"),
        "fallback_eligible": runtime.get("fallback_eligible"),
    }
    return {
        "schema_version": 2,
        "task_id": task_id,
        "status": status,
        "reason": reason,
        "report_complete": report_complete,
        "next_action": next_action,
        "accepted": accepted,
        "pid": pid,
        "running": running,
        "exit_code": exit_code,
        "attempt": state.get("current_attempt", state.get("attempt")),
        "artifact_dir": str(artifact),
        "attempt_dir": str(attempt_dir),
        "task_sha256": state.get("task_sha256"),
        "provider": provider,
        "heartbeat": heartbeat,
        "report": {
            "exists": report_path.is_file(),
            "complete": report_complete,
            "trusted": bool(report_evidence.get("trusted")),
            "reason": report_evidence.get("reason"),
            "sha256": report_evidence.get("sha256"),
            "status": report_status,
            "path": str(report_path),
        },
        "verification": {
            "exists": verification_path.is_file(),
            "verified": bool(
                verification_trusted and verification.get("status") == "passed"
            ),
            "path": str(verification_path),
            "status": (
                verification.get("status")
                if verification_trusted and verification
                else "untrusted" if verification else None
            ),
        },
        "review": {
            "exists": review_path.is_file(),
            "trusted": review_trusted,
            "path": str(review_path),
            "status": (
                review.get("verdict")
                if review_trusted and review
                else "untrusted" if review else None
            ),
        },
        "acceptance": {
            "exists": acceptance_path.is_file(),
            "path": str(acceptance_path),
        },
    }


def task_status(run_dir: Path, task_id: str, *, persist: bool = False) -> dict:
    artifact = artifact_dir_for(run_dir, task_id)
    state = load_task_state(artifact)
    if state is not None:
        return task_status_v2(run_dir, task_id, artifact, state, persist=persist)
    control = read_optional_json(artifact / "control.json") or {}
    pid = parse_int_file(artifact / "lane-bg.pid")
    expected_start = control.get("pid_start_time")
    if not isinstance(expected_start, int):
        expected_start = None
    running = pid_alive(pid, expected_start)
    exit_code = parse_int_file(artifact / "lane-bg.exit")

    task_events = read_events(run_dir, task_id)
    if exit_code is None:
        for event in reversed(task_events):
            if event.get("type") == "exit" and isinstance(event.get("exit_code"), int):
                exit_code = event["exit_code"]
                break

    heartbeat_path = artifact / "heartbeat.json"
    heartbeat_value = read_optional_json(heartbeat_path)
    heartbeat = {
        "exists": heartbeat_path.is_file(),
        "path": str(heartbeat_path),
        "age_seconds": (
            max(0.0, time.time() - heartbeat_path.stat().st_mtime)
            if heartbeat_path.exists()
            else None
        ),
        "value": heartbeat_value,
    }
    report_path = artifact / "report.md"
    verification_path = artifact / "verification.json"
    verified_path = artifact / "verified.txt"
    verification = read_optional_json(verification_path)
    current_attempt = control.get("attempt", 0)
    verification_matches_attempt = bool(
        verification and verification.get("attempt") == current_attempt
    )
    verification_trusted = legacy_verification_receipt_trusted(
        run_dir, control, verification
    )

    if running:
        status = "running"
    elif control.get("cancel_requested_at"):
        status = "cancelled"
    elif exit_code == 0:
        if (
            verified_path.is_file()
            and verification_trusted
        ):
            status = "verified"
        elif verification_matches_attempt and verification.get("status") == "failed":
            status = "verification_failed"
        else:
            status = "awaiting_verification"
    elif exit_code is not None:
        status = "failed"
    elif control:
        status = "unknown"
    else:
        status = "not_started"

    return {
        "task_id": task_id,
        "status": status,
        "pid": pid,
        "running": running,
        "exit_code": exit_code,
        "attempt": current_attempt,
        "artifact_dir": str(artifact),
        "heartbeat": heartbeat,
        "report": {"exists": report_path.is_file(), "path": str(report_path)},
        "verification": {
            "exists": verification_path.is_file() and verification_matches_attempt,
            "verified": verified_path.is_file() and verification_trusted,
            "path": str(verification_path),
            "status": (
                (
                    "untrusted"
                    if verification_matches_attempt
                    and verification
                    and verification.get("status") == "passed"
                    and not verification_trusted
                    else verification.get("status")
                )
                if verification_matches_attempt
                else None
            ),
        },
    }


def bounded_int(value: str, *, minimum: int, maximum: int, label: str) -> int:
    try:
        parsed = int(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError(f"{label} must be an integer") from exc
    if parsed < minimum or parsed > maximum:
        raise argparse.ArgumentTypeError(
            f"{label} must be between {minimum} and {maximum}"
        )
    return parsed


def configured_default(name: str, fallback: int, *, maximum: int) -> int:
    raw = os.environ.get(name, str(fallback))
    try:
        value = int(raw)
    except ValueError as exc:
        raise ContractError(f"{name} must be an integer") from exc
    if value < 1 or value > maximum:
        raise ContractError(f"{name} must be between 1 and {maximum}")
    return value


def resolve_binary(value: str | None) -> str | None:
    if value is None:
        return None
    if os.sep in value:
        path = Path(value).expanduser().resolve()
        if not path.is_file() or not os.access(path, os.X_OK):
            raise ContractError(f"--binary must name an executable file: {path}")
        return str(path)
    found = shutil.which(value)
    if not found:
        raise ContractError(f"--binary not found on PATH: {value}")
    return str(Path(found).resolve())


def validate_model(value: str) -> str:
    if not SAFE_MODEL.fullmatch(value):
        raise argparse.ArgumentTypeError("model contains unsupported characters")
    return value


def command_hash(argv: list[str]) -> str:
    canonical = json.dumps(argv, ensure_ascii=False, separators=(",", ":"))
    return hashlib.sha256(canonical.encode("utf-8")).hexdigest()


def build_launch_argv(
    context: TaskContext,
    args: argparse.Namespace,
    *,
    runtime_dir: Path | None = None,
    heartbeat_path: Path | None = None,
) -> list[str]:
    artifact = runtime_dir or context.artifact_dir
    heartbeat = heartbeat_path or (artifact / "heartbeat.json")
    session_argv = [
        str(LANE_SESSION),
        "run",
        "--provider",
        args.provider,
        "--run-dir",
        str(context.run_dir),
        "--task-id",
        context.task_id,
        "--role",
        "writer",
        "--cwd",
        str(context.project_cwd),
        "--prompt-file",
        str(artifact / "prompt.md"),
        "--output",
        str(artifact / "provider.out"),
        "--model",
        args.model,
        "--reasoning-effort",
        args.reasoning_effort,
        "--pool-size",
        str(args.pool_size),
        "--max-tasks",
        str(args.max_tasks),
    ]
    binary = resolve_binary(args.binary)
    if binary:
        session_argv.extend(["--binary", binary])

    return [
        str(LANE_BG),
        "--dir",
        str(artifact),
        "--label",
        context.task_id,
        "--",
        str(LANE_EXEC),
        "--idle",
        str(args.idle),
        "--max",
        str(args.max_runtime),
        "--heartbeat",
        str(heartbeat),
        "--log",
        str(artifact / "lane-exec.log"),
        "--label",
        context.task_id,
        "--event-log",
        str(context.run_dir / "events.jsonl"),
        "--event-task",
        context.task_id,
        "--",
        *session_argv,
    ]


def write_control(context: TaskContext, control: dict) -> None:
    write_json(context.artifact_dir / "control.json", control)


def launch(argv: list[str], *, cwd: Path) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(
            argv,
            cwd=cwd,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            timeout=10,
            check=False,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        raise OperationError(f"cannot launch detached lane: {exc}") from exc


def finish_launch_state(
    *, artifact: Path, control: dict, result: subprocess.CompletedProcess[str]
) -> dict:
    control["launcher_exit_code"] = result.returncode
    control["launcher_stdout"] = result.stdout
    control["launcher_stderr"] = result.stderr
    control["launched_at"] = utc_now()
    pid = parse_int_file(artifact / "lane-bg.pid")
    control["pid"] = pid
    control["pid_start_time"] = pid_start_time(pid) if pid is not None else None
    control["state"] = "started" if result.returncode == 0 else "launch_failed"
    write_json(artifact / "control.json", control)
    return {
        "task_id": control["task_id"],
        "status": control["state"],
        "pid": pid,
        "attempt": control["attempt"],
        "artifact_dir": str(artifact),
    }


def finish_launch_v2(
    *,
    artifact: Path,
    attempt_dir: Path,
    control: dict,
    state: dict,
    result: subprocess.CompletedProcess[str],
) -> dict:
    control["launcher_exit_code"] = result.returncode
    control["launcher_stdout"] = result.stdout
    control["launcher_stderr"] = result.stderr
    control["launched_at"] = utc_now()
    pid = parse_int_file(safe_child_file(attempt_dir, "lane-bg.pid"))
    control["pid"] = pid
    control["pid_start_time"] = pid_start_time(pid) if pid is not None else None
    write_json(safe_child_file(attempt_dir, "control.json"), control)
    state = dict(state)
    state["status"] = "running" if result.returncode == 0 else "failed"
    state["updated_at"] = utc_now()
    write_task_state(artifact, state)
    return {
        "schema_version": 2,
        "task_id": control["task_id"],
        "status": "started" if result.returncode == 0 else "launch_failed",
        "pid": pid,
        "attempt": control["attempt"],
        "artifact_dir": str(artifact),
        "attempt_dir": str(attempt_dir),
    }


def cmd_start_v2(
    context: TaskContext, args: argparse.Namespace, run_contract: dict
) -> int:
    artifact = context.artifact_dir
    if state_path_for(artifact).exists():
        raise ContractError("lane already has state.json; use retry")
    if safe_child_file(artifact, "control.json").exists():
        raise ContractError("cannot start v2 over a legacy lane")
    task_sha256 = task_digest(context)
    verification_executables = configured_verification_executables(context.run_dir)
    verification_snapshot = verification_entries(
        context.task,
        schema_version=2,
        enforce_nonempty=False,
        extra_executables=verification_executables,
    )
    attempt = 1
    attempt_dir = attempt_dir_for(artifact, attempt, create=True)
    prompt = prompt_for(context)
    prompt_path = safe_child_file(attempt_dir, "prompt.md")
    atomic_write(prompt_path, prompt)
    heartbeat_path = safe_child_file(artifact, "heartbeat.json")
    argv = build_launch_argv(
        context,
        args,
        runtime_dir=attempt_dir,
        heartbeat_path=heartbeat_path,
    )
    control = {
        "version": 2,
        "schema_version": 2,
        "task_id": context.task_id,
        "task_file": str(context.task_file),
        "task_sha256": task_sha256,
        "project_cwd": str(context.project_cwd),
        "artifact_dir": str(artifact),
        "attempt_dir": str(attempt_dir),
        "attempt": attempt,
        "heartbeat_file": str(heartbeat_path),
        "prompt_file": str(prompt_path),
        "prompt_sha256": hashlib.sha256(prompt.encode("utf-8")).hexdigest(),
        "provider": args.provider,
        "model": args.model,
        "reasoning_effort": args.reasoning_effort,
        "argv": argv,
        "argv_sha256": command_hash(argv),
        "verification_commands": verification_snapshot,
        "verification_executables": sorted(verification_executables),
        "created_at": utc_now(),
    }
    state = {
        "version": 2,
        "schema_version": 2,
        "run_schema_version": run_contract.get("schema_version"),
        "task_id": context.task_id,
        "task_file": str(context.task_file),
        "task_sha256": task_sha256,
        "project_cwd": str(context.project_cwd),
        "current_attempt": attempt,
        "attempt": attempt,
        "status": "launching",
        "accepted": False,
        "created_at": utc_now(),
        "updated_at": utc_now(),
    }
    write_json(safe_child_file(attempt_dir, "control.json"), control)
    write_task_state(artifact, state)
    append_event(context.run_dir, "control_start", context.task_id, attempt=attempt)
    result = launch(argv, cwd=context.project_cwd)
    payload = finish_launch_v2(
        artifact=artifact,
        attempt_dir=attempt_dir,
        control=control,
        state=state,
        result=result,
    )
    if result.returncode != 0:
        append_event(
            context.run_dir,
            "control_start_failed",
            context.task_id,
            attempt=attempt,
            exit_code=result.returncode,
        )
        print(json.dumps(payload, sort_keys=True))
        return 1
    print(json.dumps(payload, sort_keys=True))
    return 0


def cmd_start(args: argparse.Namespace) -> int:
    if args.model is None:
        args.model = PRIMARY_MODELS[args.provider]
    context = validate_task_context(
        run_dir_value=args.run_dir,
        task_id=args.task_id,
        task_file_value=args.task_file,
        project_cwd_value=args.project_cwd,
        create_artifact=True,
    )
    schema_version, run_contract = context_schema_version(context)
    lifecycle_lock = safe_child_file(context.artifact_dir, ".lifecycle.lock")
    with locked_file(lifecycle_lock):
        if schema_version == 2:
            assert run_contract is not None
            return cmd_start_v2(context, args, run_contract)
        control_path = context.artifact_dir / "control.json"
        if control_path.exists():
            raise ContractError("lane already has control.json; use retry")
        stale_pid = parse_int_file(context.artifact_dir / "lane-bg.pid")
        if pid_alive(stale_pid):
            raise ContractError(f"lane already has a running process: pid={stale_pid}")

        for stale in (
            "lane-bg.exit",
            "heartbeat.json",
            "verification.json",
            "verified.txt",
        ):
            safe_child_file(context.artifact_dir, stale).unlink(missing_ok=True)
        prompt = prompt_for(context)
        atomic_write(context.artifact_dir / "prompt.md", prompt)
        argv = build_launch_argv(context, args)
        control = {
            "version": 1,
            "task_id": context.task_id,
            "task_file": str(context.task_file),
            "project_cwd": str(context.project_cwd),
            "artifact_dir": str(context.artifact_dir),
            "prompt_file": str(context.artifact_dir / "prompt.md"),
            "prompt_sha256": hashlib.sha256(prompt.encode("utf-8")).hexdigest(),
            "provider": args.provider,
            "model": args.model,
            "reasoning_effort": args.reasoning_effort,
            "argv": argv,
            "argv_sha256": command_hash(argv),
            "verification_commands": verification_commands(context.task),
            "attempt": 1,
            "state": "launching",
            "created_at": utc_now(),
        }
        write_control(context, control)
        append_event(context.run_dir, "control_start", context.task_id, attempt=1)
        result = launch(argv, cwd=context.project_cwd)
        payload = finish_launch_state(
            artifact=context.artifact_dir, control=control, result=result
        )
        if result.returncode != 0:
            append_event(
                context.run_dir,
                "control_start_failed",
                context.task_id,
                attempt=1,
                exit_code=result.returncode,
            )
            print(json.dumps(payload, sort_keys=True))
            return 1
    print(json.dumps(payload, sort_keys=True))
    return 0


def cmd_status(args: argparse.Namespace) -> int:
    run_dir = validate_run_dir(args.run_dir)
    validate_name(args.task_id, "task id")
    artifact = artifact_dir_for(run_dir, args.task_id)
    if state_path_for(artifact).is_file():
        with locked_file(safe_child_file(artifact, ".lifecycle.lock")):
            payload = task_status(run_dir, args.task_id, persist=True)
    else:
        payload = task_status(run_dir, args.task_id)
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(
            f"task={payload['task_id']} status={payload['status']} "
            f"pid={payload['pid'] or ''} exit={payload['exit_code'] if payload['exit_code'] is not None else ''} "
            f"report={'yes' if payload['report']['exists'] else 'no'} "
            f"verified={'yes' if payload['verification']['verified'] else 'no'} "
            f"attempt={payload['attempt']}"
        )
    return 0


def tail_lines(path: Path, count: int) -> str:
    if not path.exists():
        return ""
    try:
        with path.open("rb") as handle:
            handle.seek(0, os.SEEK_END)
            position = handle.tell()
            data = b""
            while position > 0 and data.count(b"\n") <= count:
                take = min(8192, position)
                position -= take
                handle.seek(position)
                data = handle.read(take) + data
    except OSError as exc:
        raise OperationError(f"cannot read artifact log {path}: {exc}") from exc
    lines = data.decode("utf-8", errors="replace").splitlines(keepends=True)
    return "".join(lines[-count:])


def cmd_tail(args: argparse.Namespace) -> int:
    run_dir = validate_run_dir(args.run_dir)
    artifact = artifact_dir_for(run_dir, args.task_id)
    state = load_task_state(artifact)
    if state is not None and args.source != "report":
        source_root = current_attempt_dir(artifact, state)
    else:
        source_root = artifact
    path = safe_child_file(source_root, TAIL_SOURCES[args.source])
    sys.stdout.write(tail_lines(path, args.lines))
    return 0


def cmd_events(args: argparse.Namespace) -> int:
    run_dir = validate_run_dir(args.run_dir)
    if args.task_id is not None:
        validate_name(args.task_id, "task id")
    events = read_events(run_dir, args.task_id)[-args.limit :]
    if args.json:
        print(json.dumps(events, indent=2, sort_keys=True))
    else:
        for event in events:
            print(json.dumps(event, sort_keys=True))
    return 0


def child_pids(pid: int) -> list[int]:
    try:
        text = Path(f"/proc/{pid}/task/{pid}/children").read_text(encoding="utf-8")
    except OSError:
        return []
    result: list[int] = []
    for value in text.split():
        try:
            child = int(value)
        except ValueError:
            continue
        result.append(child)
        result.extend(child_pids(child))
    return result


def terminate_tree(pid: int, grace_seconds: float = 3.0) -> None:
    targets = list(reversed(child_pids(pid))) + [pid]
    for target in targets:
        try:
            os.kill(target, signal.SIGTERM)
        except ProcessLookupError:
            pass
    deadline = time.monotonic() + grace_seconds
    while time.monotonic() < deadline:
        if not any(pid_alive(target) for target in targets):
            return
        time.sleep(0.05)
    for target in targets:
        if pid_alive(target):
            try:
                os.kill(target, signal.SIGKILL)
            except ProcessLookupError:
                pass


def load_control_for(run_dir: Path, task_id: str) -> tuple[Path, dict]:
    artifact = artifact_dir_for(run_dir, task_id)
    state = load_task_state(artifact)
    control_root = current_attempt_dir(artifact, state) if state is not None else artifact
    control = read_json(safe_child_file(control_root, "control.json"))
    if control.get("task_id") != task_id:
        raise ContractError("control.json task identity mismatch")
    if state is None and control.get("artifact_dir") != str(artifact):
        raise ContractError("control.json task/artifact identity mismatch")
    if state is not None:
        if control.get("artifact_dir") != str(artifact):
            raise ContractError("control.json task artifact identity mismatch")
        if control.get("attempt_dir") != str(control_root):
            raise ContractError("control.json attempt identity mismatch")
        if control.get("task_sha256") != state.get("task_sha256"):
            raise ContractError("control.json task_sha256 does not match state")
        if control.get("attempt") != state.get(
            "current_attempt", state.get("attempt")
        ):
            raise ContractError("control.json attempt does not match state")
    return control_root, control


def cmd_cancel(args: argparse.Namespace) -> int:
    run_dir = validate_run_dir(args.run_dir)
    validate_name(args.task_id, "task id")
    task_artifact = artifact_dir_for(run_dir, args.task_id)
    with locked_file(safe_child_file(task_artifact, ".lifecycle.lock")):
        state = load_task_state(task_artifact)
        runtime_dir, control = load_control_for(run_dir, args.task_id)
        pid = parse_int_file(safe_child_file(runtime_dir, "lane-bg.pid"))
        expected_start = control.get("pid_start_time")
        if not isinstance(expected_start, int):
            expected_start = None
        was_running = pid_alive(pid, expected_start)
        if state is not None:
            state = dict(state)
            state["status"] = "cancelled"
            state["cancel_requested_at"] = utc_now()
            state["updated_at"] = utc_now()
            write_task_state(task_artifact, state)
        else:
            control["cancel_requested_at"] = utc_now()
            control["state"] = "cancelled"
            write_json(safe_child_file(runtime_dir, "control.json"), control)
        append_event(run_dir, "cancel", args.task_id, pid=pid, was_running=was_running)
        if was_running and pid is not None:
            terminate_tree(pid)
        payload = task_status(run_dir, args.task_id)
        payload["status"] = "cancelled"
    print(json.dumps(payload, sort_keys=True))
    return 0


def index_after(argv: list[str], token: str, start: int = 0) -> int:
    try:
        return argv.index(token, start)
    except ValueError as exc:
        raise ContractError(f"recorded argv is missing {token!r}") from exc


def parse_recorded_options(
    tokens: list[str], *, allowed: set[str], label: str
) -> dict[str, str]:
    if len(tokens) % 2:
        raise ContractError(f"recorded {label} argv must contain option/value pairs")
    parsed: dict[str, str] = {}
    for index in range(0, len(tokens), 2):
        option, value = tokens[index : index + 2]
        if option not in allowed:
            raise ContractError(f"unsupported option in recorded {label} argv: {option}")
        if option in parsed:
            raise ContractError(f"duplicate option in recorded {label} argv: {option}")
        parsed[option] = value
    return parsed


def require_recorded_options(
    parsed: dict[str, str], expected: dict[str, str], *, label: str
) -> None:
    for option, value in expected.items():
        if parsed.get(option) != value:
            raise ContractError(f"recorded {label} {option} mismatch")


def recorded_int(value: str | None, *, minimum: int, maximum: int, label: str) -> int:
    try:
        parsed = int(value or "")
    except ValueError as exc:
        raise ContractError(f"recorded {label} must be an integer") from exc
    if parsed < minimum or parsed > maximum:
        raise ContractError(f"recorded {label} must be between {minimum} and {maximum}")
    return parsed


def validate_recorded_argv(
    argv_value: object, *, artifact: Path, run_dir: Path, task_id: str, control: dict
) -> list[str]:
    if (
        not isinstance(argv_value, list)
        or not argv_value
        or not all(isinstance(item, str) and "\0" not in item for item in argv_value)
    ):
        raise ContractError("recorded argv must be a non-empty string array")
    argv = list(argv_value)
    if command_hash(argv) != control.get("argv_sha256"):
        raise ContractError("recorded argv checksum mismatch")
    if argv[0] != str(LANE_BG):
        raise ContractError("recorded argv must start with canonical lane-bg")
    first_separator = index_after(argv, "--", 1)
    bg_options = parse_recorded_options(
        argv[1:first_separator], allowed={"--dir", "--label"}, label="lane-bg"
    )
    require_recorded_options(
        bg_options,
        {"--dir": str(artifact), "--label": task_id},
        label="lane-bg",
    )
    if set(bg_options) != {"--dir", "--label"}:
        raise ContractError("recorded lane-bg argv is incomplete")
    if first_separator + 1 >= len(argv) or argv[first_separator + 1] != str(LANE_EXEC):
        raise ContractError("recorded argv must invoke canonical lane-exec")
    second_separator = index_after(argv, "--", first_separator + 2)
    exec_allowed = {
        "--idle",
        "--max",
        "--heartbeat",
        "--log",
        "--label",
        "--event-log",
        "--event-task",
    }
    exec_options = parse_recorded_options(
        argv[first_separator + 2 : second_separator],
        allowed=exec_allowed,
        label="lane-exec",
    )
    require_recorded_options(
        exec_options,
        {
            "--heartbeat": str(
                control.get("heartbeat_file", artifact / "heartbeat.json")
            ),
            "--log": str(artifact / "lane-exec.log"),
            "--label": task_id,
            "--event-log": str(run_dir / "events.jsonl"),
            "--event-task": task_id,
        },
        label="lane-exec",
    )
    if set(exec_options) != exec_allowed:
        raise ContractError("recorded lane-exec argv is incomplete")
    idle = recorded_int(exec_options.get("--idle"), minimum=5, maximum=3600, label="idle")
    maximum = recorded_int(
        exec_options.get("--max"), minimum=10, maximum=86400, label="max-runtime"
    )
    if maximum < idle:
        raise ContractError("recorded max-runtime must be greater than or equal to idle")
    if second_separator + 1 >= len(argv) or argv[second_separator + 1] != str(LANE_SESSION):
        raise ContractError("recorded argv must invoke canonical lane-session")
    session = second_separator + 1
    if argv[session + 1 : session + 2] != ["run"]:
        raise ContractError("recorded lane-session argv must use run")
    session_allowed = {
        "--provider",
        "--run-dir",
        "--task-id",
        "--role",
        "--cwd",
        "--prompt-file",
        "--output",
        "--model",
        "--reasoning-effort",
        "--pool-size",
        "--max-tasks",
        "--binary",
    }
    session_options = parse_recorded_options(
        argv[session + 2 :], allowed=session_allowed, label="lane-session"
    )
    recorded_provider = control.get("provider", "grok")
    if recorded_provider not in {"agy", "grok", "codex"}:
        raise ContractError("recorded provider is unsupported")
    required = {
        "--provider": recorded_provider,
        "--run-dir": str(run_dir),
        "--task-id": task_id,
        "--role": "writer",
        "--cwd": str(control.get("project_cwd")),
        "--prompt-file": str(artifact / "prompt.md"),
        "--output": str(artifact / "provider.out"),
    }
    require_recorded_options(session_options, required, label="lane-session")
    required_keys = set(required) | {
        "--model",
        "--reasoning-effort",
        "--pool-size",
        "--max-tasks",
    }
    if set(session_options) not in (required_keys, required_keys | {"--binary"}):
        raise ContractError("recorded lane-session argv is incomplete")
    model = session_options.get("--model", "")
    if not SAFE_MODEL.fullmatch(model):
        raise ContractError("recorded model contains unsupported characters")
    if session_options.get("--reasoning-effort") not in {"low", "medium", "high"}:
        raise ContractError("recorded reasoning effort is invalid")
    if recorded_provider == "codex" and (
        model != CODEX_FALLBACK_MODEL
        or session_options.get("--reasoning-effort") != CODEX_FALLBACK_REASONING
    ):
        raise ContractError("recorded Codex fallback profile is invalid")
    if control.get("model", model) != model:
        raise ContractError("recorded model does not match control")
    if control.get("reasoning_effort", session_options.get("--reasoning-effort")) != session_options.get(
        "--reasoning-effort"
    ):
        raise ContractError("recorded reasoning effort does not match control")
    recorded_int(
        session_options.get("--pool-size"),
        minimum=1,
        maximum=HARD_PROVIDER_POOL,
        label="pool-size",
    )
    recorded_int(
        session_options.get("--max-tasks"),
        minimum=1,
        maximum=HARD_MAX_TASKS,
        label="max-tasks",
    )
    if "--binary" in session_options:
        binary = Path(session_options["--binary"]).resolve()
        if not binary.is_file() or not os.access(binary, os.X_OK):
            raise ContractError(f"recorded binary is unavailable: {binary}")
    return argv


def relocate_attempt_argv(argv: list[str], old_dir: Path, new_dir: Path) -> list[str]:
    old_prefix = str(old_dir)
    new_prefix = str(new_dir)
    relocated: list[str] = []
    for token in argv:
        if token == old_prefix:
            relocated.append(new_prefix)
        elif token.startswith(old_prefix + os.sep):
            relocated.append(new_prefix + token[len(old_prefix) :])
        else:
            relocated.append(token)
    return relocated


def replace_recorded_option(argv: list[str], option: str, value: str) -> None:
    try:
        index = argv.index(option)
    except ValueError as exc:
        raise ContractError(f"recorded argv is missing {option}") from exc
    if index + 1 >= len(argv):
        raise ContractError(f"recorded argv option has no value: {option}")
    argv[index + 1] = value


def archive_root_report(artifact: Path, attempt_dir: Path) -> None:
    report_path = safe_child_file(artifact, "report.md")
    if not (report_path.exists() or report_path.is_symlink()):
        return
    if report_path.is_symlink() or not report_path.is_file():
        raise ContractError("cannot archive unsafe root report.md")
    archived_report = safe_child_file(attempt_dir, "report.md")
    if archived_report.exists() or archived_report.is_symlink():
        raise ContractError("current attempt already contains an archived report.md")
    try:
        os.replace(report_path, archived_report)
    except OSError as exc:
        raise OperationError(f"cannot archive root report.md: {exc}") from exc


def cmd_retry_v2(
    run_dir: Path, task_id: str, artifact: Path, state: dict
) -> tuple[int, dict]:
    context = context_from_state(run_dir, task_id, state)
    current = task_status(run_dir, task_id)
    if current["running"]:
        raise ContractError("cannot retry a running lane")
    state = read_json(state_path_for(artifact))
    if state.get("accepted") or state.get("status") == "done":
        raise ContractError("cannot retry an accepted task")
    attempt = state.get("current_attempt", state.get("attempt"))
    if not isinstance(attempt, int) or attempt < 1:
        raise ContractError("state.json current_attempt is invalid")
    if attempt >= MAX_PRIMARY_ATTEMPTS:
        raise ContractError(
            f"writer retry limit reached: maximum {MAX_PRIMARY_ATTEMPTS} attempts"
        )

    old_dir, old_control = load_control_for(run_dir, task_id)
    if old_control.get("provider", "grok") not in PRIMARY_MODELS:
        raise ContractError("retry replays AGY/Grok only; Codex fallback is one-shot")
    old_argv = validate_recorded_argv(
        old_control.get("argv"),
        artifact=old_dir,
        run_dir=run_dir,
        task_id=task_id,
        control=old_control,
    )
    old_prompt = safe_child_file(old_dir, "prompt.md")
    try:
        prompt_bytes = old_prompt.read_bytes()
    except OSError as exc:
        raise ContractError(f"cannot read recorded prompt: {exc}") from exc
    if hashlib.sha256(prompt_bytes).hexdigest() != old_control.get("prompt_sha256"):
        raise ContractError("recorded prompt checksum mismatch")

    next_attempt = attempt + 1
    new_dir = attempt_dir_for(artifact, next_attempt, create=True)
    new_prompt = safe_child_file(new_dir, "prompt.md")
    atomic_write(new_prompt, prompt_bytes)
    new_argv = relocate_attempt_argv(old_argv, old_dir, new_dir)
    control = dict(old_control)
    for key in (
        "launcher_exit_code",
        "launcher_stdout",
        "launcher_stderr",
        "launched_at",
        "pid",
        "pid_start_time",
    ):
        control.pop(key, None)
    control.update(
        {
            "attempt": next_attempt,
            "attempt_dir": str(new_dir),
            "prompt_file": str(new_prompt),
            "argv": new_argv,
            "argv_sha256": command_hash(new_argv),
            "created_at": utc_now(),
            "retry_of_attempt": attempt,
        }
    )
    validate_recorded_argv(
        new_argv,
        artifact=new_dir,
        run_dir=run_dir,
        task_id=task_id,
        control=control,
    )
    write_json(safe_child_file(new_dir, "control.json"), control)
    archive_root_report(artifact, old_dir)
    state = dict(state)
    state["current_attempt"] = next_attempt
    state["attempt"] = next_attempt
    state["status"] = "launching"
    state["accepted"] = False
    state["updated_at"] = utc_now()
    write_task_state(artifact, state)
    append_event(run_dir, "control_retry", task_id, attempt=next_attempt)
    result = launch(new_argv, cwd=context.project_cwd)
    payload = finish_launch_v2(
        artifact=artifact,
        attempt_dir=new_dir,
        control=control,
        state=state,
        result=result,
    )
    return (0 if result.returncode == 0 else 1), payload


def cmd_fallback_v2(
    run_dir: Path,
    task_id: str,
    artifact: Path,
    state: dict,
    *,
    binary_override: str | None,
) -> tuple[int, dict]:
    context = context_from_state(run_dir, task_id, state)
    current = task_status(run_dir, task_id)
    if current["running"]:
        raise ContractError("cannot fallback a running lane")
    state = read_json(state_path_for(artifact))
    if state.get("accepted") or state.get("status") == "done":
        raise ContractError("cannot fallback an accepted task")
    attempt = state.get("current_attempt", state.get("attempt"))
    if attempt != MAX_PRIMARY_ATTEMPTS:
        raise ContractError(
            f"Codex fallback requires exactly {MAX_PRIMARY_ATTEMPTS} completed writer attempts"
        )

    old_dir, old_control = load_control_for(run_dir, task_id)
    old_argv = validate_recorded_argv(
        old_control.get("argv"),
        artifact=old_dir,
        run_dir=run_dir,
        task_id=task_id,
        control=old_control,
    )
    primary_provider = old_control.get("provider", "grok")
    if primary_provider not in PRIMARY_MODELS:
        raise ContractError("Codex fallback may only replace an AGY/Grok attempt")
    runtime = read_json(safe_child_file(old_dir, "runtime.json"))
    if (
        runtime.get("provider") != primary_provider
        or runtime.get("fallback_eligible") is not True
        or runtime.get("exit_code") == 0
        or not isinstance(runtime.get("failure_class"), str)
    ):
        raise ContractError("current writer failure is not eligible for Codex fallback")

    old_prompt = safe_child_file(old_dir, "prompt.md")
    try:
        prompt_bytes = old_prompt.read_bytes()
    except OSError as exc:
        raise ContractError(f"cannot read recorded prompt: {exc}") from exc
    if hashlib.sha256(prompt_bytes).hexdigest() != old_control.get("prompt_sha256"):
        raise ContractError("recorded prompt checksum mismatch")

    next_attempt = attempt + 1
    if next_attempt > MAX_ATTEMPTS:
        raise ContractError(f"fallback limit reached: maximum {MAX_ATTEMPTS} attempts")
    new_dir = attempt_dir_for(artifact, next_attempt, create=True)
    new_prompt = safe_child_file(new_dir, "prompt.md")
    atomic_write(new_prompt, prompt_bytes)
    new_argv = relocate_attempt_argv(old_argv, old_dir, new_dir)
    replace_recorded_option(new_argv, "--provider", "codex")
    replace_recorded_option(new_argv, "--model", CODEX_FALLBACK_MODEL)
    replace_recorded_option(
        new_argv, "--reasoning-effort", CODEX_FALLBACK_REASONING
    )
    while "--binary" in new_argv:
        binary_index = new_argv.index("--binary")
        del new_argv[binary_index : binary_index + 2]
    binary = resolve_binary(binary_override)
    if binary is not None:
        new_argv.extend(["--binary", binary])

    control = dict(old_control)
    for key in (
        "launcher_exit_code",
        "launcher_stdout",
        "launcher_stderr",
        "launched_at",
        "pid",
        "pid_start_time",
        "retry_of_attempt",
    ):
        control.pop(key, None)
    control.update(
        {
            "attempt": next_attempt,
            "attempt_dir": str(new_dir),
            "prompt_file": str(new_prompt),
            "provider": "codex",
            "model": CODEX_FALLBACK_MODEL,
            "reasoning_effort": CODEX_FALLBACK_REASONING,
            "argv": new_argv,
            "argv_sha256": command_hash(new_argv),
            "created_at": utc_now(),
            "fallback_of_attempt": attempt,
            "fallback_from_provider": primary_provider,
            "fallback_failure_class": runtime["failure_class"],
        }
    )
    validate_recorded_argv(
        new_argv,
        artifact=new_dir,
        run_dir=run_dir,
        task_id=task_id,
        control=control,
    )
    write_json(safe_child_file(new_dir, "control.json"), control)
    archive_root_report(artifact, old_dir)
    state = dict(state)
    state["current_attempt"] = next_attempt
    state["attempt"] = next_attempt
    state["status"] = "launching"
    state["accepted"] = False
    state["updated_at"] = utc_now()
    write_task_state(artifact, state)
    append_event(
        run_dir,
        "control_fallback",
        task_id,
        attempt=next_attempt,
        provider="codex",
        model=CODEX_FALLBACK_MODEL,
    )
    result = launch(new_argv, cwd=context.project_cwd)
    payload = finish_launch_v2(
        artifact=artifact,
        attempt_dir=new_dir,
        control=control,
        state=state,
        result=result,
    )
    payload.update(provider="codex", model=CODEX_FALLBACK_MODEL)
    return (0 if result.returncode == 0 else 1), payload


def cmd_fallback(args: argparse.Namespace) -> int:
    run_dir = validate_run_dir(args.run_dir)
    validate_name(args.task_id, "task id")
    artifact = artifact_dir_for(run_dir, args.task_id)
    with locked_file(safe_child_file(artifact, ".lifecycle.lock")):
        state = load_task_state(artifact)
        if state is None:
            raise ContractError("Codex fallback requires a schema-v2 lane")
        exit_code, payload = cmd_fallback_v2(
            run_dir,
            args.task_id,
            artifact,
            state,
            binary_override=args.binary,
        )
    print(json.dumps(payload, sort_keys=True))
    return exit_code


def cmd_retry(args: argparse.Namespace) -> int:
    run_dir = validate_run_dir(args.run_dir)
    validate_name(args.task_id, "task id")
    artifact = artifact_dir_for(run_dir, args.task_id)
    lifecycle_lock = safe_child_file(artifact, ".lifecycle.lock")
    with locked_file(lifecycle_lock):
        state = load_task_state(artifact)
        if state is not None:
            exit_code, payload = cmd_retry_v2(
                run_dir, args.task_id, artifact, state
            )
            print(json.dumps(payload, sort_keys=True))
            return exit_code
        artifact, control = load_control_for(run_dir, args.task_id)
        current = task_status(run_dir, args.task_id)
        if current["running"]:
            raise ContractError("cannot retry a running lane")
        attempt = control.get("attempt")
        if not isinstance(attempt, int) or attempt < 1:
            raise ContractError("recorded attempt is invalid")
        if attempt >= MAX_PRIMARY_ATTEMPTS:
            raise ContractError(
                f"writer retry limit reached: maximum {MAX_PRIMARY_ATTEMPTS} attempts"
            )
        argv = validate_recorded_argv(
            control.get("argv"),
            artifact=artifact,
            run_dir=run_dir,
            task_id=args.task_id,
            control=control,
        )
        prompt_path = safe_child_file(artifact, "prompt.md")
        if control.get("prompt_file") != str(prompt_path):
            raise ContractError("recorded prompt path mismatch")
        try:
            prompt_digest = hashlib.sha256(prompt_path.read_bytes()).hexdigest()
        except OSError as exc:
            raise ContractError(f"cannot read recorded prompt: {exc}") from exc
        if prompt_digest != control.get("prompt_sha256"):
            raise ContractError("recorded prompt checksum mismatch")
        project_cwd = Path(str(control.get("project_cwd", ""))).resolve()
        if not project_cwd.is_dir():
            raise ContractError(f"recorded project_cwd is unavailable: {project_cwd}")

        for stale in (
            "lane-bg.exit",
            "heartbeat.json",
            "verification.json",
            "verified.txt",
        ):
            safe_child_file(artifact, stale).unlink(missing_ok=True)
        control.pop("cancel_requested_at", None)
        control["attempt"] = attempt + 1
        control["state"] = "launching"
        control["retry_requested_at"] = utc_now()
        write_json(artifact / "control.json", control)
        append_event(
            run_dir, "control_retry", args.task_id, attempt=control["attempt"]
        )
        result = launch(argv, cwd=project_cwd)
        payload = finish_launch_state(artifact=artifact, control=control, result=result)
    print(json.dumps(payload, sort_keys=True))
    return 0 if result.returncode == 0 else 1


@contextmanager
def locked_file(path: Path) -> Iterator[IO[str]]:
    path.parent.mkdir(parents=True, exist_ok=True)
    handle = path.open("a+", encoding="utf-8")
    fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
    try:
        yield handle
    finally:
        fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
        handle.close()


@contextmanager
def verification_slot(run_dir: Path, pool_size: int) -> Iterator[int]:
    artifacts_root = (run_dir / "artifacts").resolve(strict=False)
    if not is_within(artifacts_root, run_dir):
        raise ContractError("RUN_DIR/artifacts may not escape through a symlink")
    lock_root = (artifacts_root / ".verification-pool").resolve(strict=False)
    if not is_within(lock_root, artifacts_root):
        raise ContractError("verification pool path may not escape through a symlink")
    lock_root.mkdir(parents=True, exist_ok=True)
    handle: IO[str] | None = None
    slot = -1
    while handle is None:
        for candidate in range(pool_size):
            candidate_path = safe_child_file(lock_root, f"slot-{candidate}.lock")
            candidate_handle = candidate_path.open(
                "a+", encoding="utf-8"
            )
            try:
                fcntl.flock(
                    candidate_handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB
                )
            except BlockingIOError:
                candidate_handle.close()
                continue
            handle = candidate_handle
            slot = candidate
            break
        if handle is None:
            time.sleep(0.05)
    try:
        yield slot
    finally:
        fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
        handle.close()


def verification_commands(task: dict) -> list[str]:
    value = task.get("verification", [])
    if value is None:
        return []
    if not isinstance(value, list) or not all(isinstance(item, str) for item in value):
        raise ContractError("task verification must be a list of command strings")
    if any("\0" in item for item in value):
        raise ContractError("task verification commands may not contain NUL bytes")
    return list(value)


def configured_verification_executables(run_dir: Path) -> set[str]:
    policy_path = run_dir.parent.parent / "night-shift.yaml"
    if not policy_path.is_file():
        return set()
    policy, _ = load_task_yaml(policy_path)
    value = policy.get("verification_executables", [])
    if not isinstance(value, list) or not all(
        isinstance(item, str) and item and "/" not in item for item in value
    ):
        raise ContractError("verification_executables must be executable basenames")
    return set(value)


def recorded_verification_executables(control: dict) -> set[str]:
    value = control.get("verification_executables", [])
    if not isinstance(value, list) or not all(
        isinstance(item, str) and item and "/" not in item for item in value
    ):
        raise ContractError("recorded verification executable allowlist is invalid")
    return set(value)


def verification_entries(
    task: dict,
    *,
    schema_version: int,
    enforce_nonempty: bool,
    extra_executables: set[str] | None = None,
) -> list[dict]:
    value = task.get("verification", [])
    if value is None:
        value = []
    if not isinstance(value, list):
        raise ContractError("task verification must be a list")
    verify_level = str(task.get("verify", "none")).lower()
    if enforce_nonempty and verify_level in {"smoke", "tests"} and not value:
        raise ContractError(
            f"verify level {verify_level!r} requires at least one verification command"
        )

    if schema_version < 2:
        commands = verification_commands({"verification": value})
        return [
            {"command": command, "cwd": ".", "timeout_sec": 1800}
            for command in commands
        ]

    entries: list[dict] = []
    for index, item in enumerate(value):
        if isinstance(item, str):
            raise ContractError(
                "string verification commands are legacy-only; schema_version 2 "
                "requires {command, cwd, timeout_sec} entries"
            )
        if not isinstance(item, dict):
            raise ContractError(f"verification[{index}] must be a mapping")
        if set(item) != {"command", "cwd", "timeout_sec"}:
            raise ContractError(
                f"verification[{index}] must contain exactly command, cwd, timeout_sec"
            )
        command = item.get("command")
        cwd = item.get("cwd")
        timeout_sec = item.get("timeout_sec")
        if not isinstance(command, str) or not command.strip() or "\0" in command:
            raise ContractError(f"verification[{index}].command is invalid")
        safety_error = verification_error(command, extra_executables or set())
        if safety_error is not None:
            raise ContractError(f"verification[{index}]: {safety_error}")
        if (
            not isinstance(cwd, str)
            or not cwd
            or "\0" in cwd
            or not Path(cwd).is_absolute()
        ):
            raise ContractError(
                f"verification[{index}].cwd must be an absolute path"
            )
        if (
            not isinstance(timeout_sec, int)
            or isinstance(timeout_sec, bool)
            or timeout_sec < 1
            or timeout_sec > HARD_V2_VERIFY_TIMEOUT
        ):
            raise ContractError(
                f"verification[{index}].timeout_sec must be between 1 and "
                f"{HARD_V2_VERIFY_TIMEOUT}"
            )
        entries.append(
            {"command": command, "cwd": cwd, "timeout_sec": timeout_sec}
        )
    return entries


def resolve_verification_cwd(project_cwd: Path, value: str) -> Path:
    path = Path(value).resolve()
    if not is_within(path, project_cwd) or not path.is_dir():
        raise ContractError(
            f"structured verification cwd must stay in project_cwd and exist: {value}"
        )
    return path


def cmd_verify_v2(
    context: TaskContext, args: argparse.Namespace, state: dict
) -> int:
    require_immutable_task(context, state)
    artifact = context.artifact_dir
    result_dir = current_attempt_dir(artifact, state)
    result_path = safe_child_file(result_dir, "verification.json")
    verified_path = safe_child_file(result_dir, "verified.txt")
    lifecycle_lock = safe_child_file(artifact, ".lifecycle.lock")

    with verification_slot(context.run_dir, args.verify_pool_size) as slot:
        with locked_file(lifecycle_lock):
            state = read_json(state_path_for(artifact))
            require_immutable_task(context, state)
            result_dir, control = load_control_for(context.run_dir, context.task_id)
            attempt = state.get("current_attempt", state.get("attempt"))
            if control.get("attempt") != attempt:
                raise ContractError("current attempt control does not match state.json")
            current = task_status(context.run_dir, context.task_id)
            if current["running"]:
                raise ContractError("cannot verify while the provider is running")
            if current["exit_code"] != 0:
                raise ContractError("verification requires a completed provider exit code 0")
            report_evidence = trusted_provider_report(
                artifact, state, context.task_id, control=control
            )
            if not report_evidence.get("trusted"):
                raise ContractError(
                    "verification requires the current trusted provider report: "
                    f"{report_evidence.get('reason', 'untrusted')}"
                )
            if report_evidence.get("status") != "complete":
                raise ContractError(
                    "verification requires current provider report STATUS: complete"
                )
            snapshot = control.get("verification_commands")
            extra_executables = recorded_verification_executables(control)
            entries = verification_entries(
                {
                    "verification": snapshot,
                    "verify": context.task.get("verify", "none"),
                },
                schema_version=2,
                enforce_nonempty=True,
                extra_executables=extra_executables,
            )
            prepared_entries = [
                (
                    entry,
                    resolve_verification_cwd(context.project_cwd, entry["cwd"]),
                    verification_argv(entry["command"], extra_executables),
                )
                for entry in entries
            ]
            started_at = utc_now()
            running = {
                "version": 2,
                "schema_version": 2,
                "task_id": context.task_id,
                "task_sha256": state.get("task_sha256"),
                "task_file": str(context.task_file),
                "project_cwd": str(context.project_cwd),
                "attempt": attempt,
                "pool_size": args.verify_pool_size,
                "slot": slot,
                "status": "running",
                "started_at": started_at,
                "commands": [],
            }
            write_json(result_path, running)
            state["status"] = "verifying"
            state["updated_at"] = utc_now()
            write_task_state(artifact, state)
            append_event(
                context.run_dir,
                "verify_start",
                context.task_id,
                slot=slot,
                attempt=attempt,
                command_count=len(entries),
            )

            command_results: list[dict] = []
            evidence: list[str] = []
            passed = True
            for entry, command_cwd, command_argv in prepared_entries:
                command = entry["command"]
                timeout_sec = entry["timeout_sec"]
                command_started = utc_now()
                try:
                    completed = subprocess.run(
                        command_argv,
                        cwd=command_cwd,
                        text=True,
                        stdout=subprocess.PIPE,
                        stderr=subprocess.STDOUT,
                        timeout=timeout_sec,
                        check=False,
                    )
                    exit_code = completed.returncode
                    output = completed.stdout
                except subprocess.TimeoutExpired as exc:
                    exit_code = 124
                    partial = exc.stdout or ""
                    if isinstance(partial, bytes):
                        partial = partial.decode("utf-8", errors="replace")
                    output = str(partial) + (
                        f"verification command timed out after {timeout_sec}s\n"
                    )
                except OSError as exc:
                    exit_code = 127
                    output = f"cannot execute verification command: {exc}\n"
                passed = passed and exit_code == 0
                record = {
                    **entry,
                    "resolved_cwd": str(command_cwd),
                    "started_at": command_started,
                    "ended_at": utc_now(),
                    "exit_code": exit_code,
                    "output": output,
                }
                command_results.append(record)
                evidence.extend(
                    [
                        f"$ (cd {entry['cwd']} && {command})\n",
                        output,
                        "" if output.endswith("\n") or not output else "\n",
                        f"[exit {exit_code}]\n\n",
                    ]
                )

            payload = {
                **running,
                "status": "passed" if passed else "failed",
                "ended_at": utc_now(),
                "commands": command_results,
            }
            write_json(result_path, payload)
            if passed:
                atomic_write(
                    verified_path,
                    f"attempt={attempt}\n" + "".join(evidence),
                )
            else:
                verified_path.unlink(missing_ok=True)
            state["status"] = "verified" if passed else "verification_failed"
            state["updated_at"] = utc_now()
            write_task_state(artifact, state)
            append_event(
                context.run_dir,
                "verify_exit",
                context.task_id,
                slot=slot,
                attempt=attempt,
                status=payload["status"],
                exit_code=0 if passed else 1,
            )
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0 if passed else 1


def cmd_verify(args: argparse.Namespace) -> int:
    context = validate_task_context(
        run_dir_value=args.run_dir,
        task_id=args.task_id,
        task_file_value=args.task_file,
        project_cwd_value=args.project_cwd,
        create_artifact=False,
    )
    schema_version, _ = context_schema_version(context)
    state = load_task_state(context.artifact_dir)
    if schema_version == 2:
        if state is None:
            raise ContractError("schema_version 2 verification requires state.json")
        return cmd_verify_v2(context, args, state)
    registered_artifact, _ = load_control_for(context.run_dir, context.task_id)
    if registered_artifact != context.artifact_dir:
        raise ContractError("verification artifact identity mismatch")
    result_path = safe_child_file(context.artifact_dir, "verification.json")
    verified_path = safe_child_file(context.artifact_dir, "verified.txt")
    lifecycle_lock = safe_child_file(context.artifact_dir, ".lifecycle.lock")

    with verification_slot(context.run_dir, args.verify_pool_size) as slot:
        with locked_file(lifecycle_lock):
            artifact, control = load_control_for(context.run_dir, context.task_id)
            if artifact != context.artifact_dir:
                raise ContractError("verification artifact identity mismatch")
            if control.get("task_file") != str(context.task_file):
                raise ContractError("verification task_file differs from registered control")
            if control.get("project_cwd") != str(context.project_cwd):
                raise ContractError("verification project_cwd differs from registered control")
            attempt = control.get("attempt")
            if not isinstance(attempt, int) or attempt < 1:
                raise ContractError("recorded attempt is invalid")
            current = task_status(context.run_dir, context.task_id)
            if current["running"]:
                raise ContractError("cannot verify while the provider is running")
            if current["exit_code"] != 0:
                raise ContractError("verification requires a completed provider exit code 0")
            command_snapshot = control.get("verification_commands")
            if not isinstance(command_snapshot, list):
                raise ContractError("control.json is missing the verification snapshot")
            entries = verification_entries(
                {
                    "verification": command_snapshot,
                    "verify": context.task.get("verify", "none"),
                },
                schema_version=schema_version,
                enforce_nonempty=True,
            )
            commands = [entry["command"] for entry in entries]
            started_at = utc_now()
            running = {
                "version": 1,
                "task_id": context.task_id,
                "task_file": str(context.task_file),
                "project_cwd": str(context.project_cwd),
                "attempt": attempt,
                "pool_size": args.verify_pool_size,
                "slot": slot,
                "command_timeout": args.command_timeout,
                "status": "running",
                "started_at": started_at,
                "commands": [],
            }
            write_json(result_path, running)
            append_event(
                context.run_dir,
                "verify_start",
                context.task_id,
                slot=slot,
                attempt=attempt,
                command_count=len(commands),
            )

            command_results: list[dict] = []
            evidence: list[str] = []
            passed = True
            for command in commands:
                command_started = utc_now()
                try:
                    completed = subprocess.run(
                        ["/bin/bash", "-c", command],
                        cwd=context.project_cwd,
                        text=True,
                        stdout=subprocess.PIPE,
                        stderr=subprocess.STDOUT,
                        timeout=args.command_timeout,
                        check=False,
                    )
                    exit_code = completed.returncode
                    output = completed.stdout
                except subprocess.TimeoutExpired as exc:
                    exit_code = 124
                    partial = exc.stdout or ""
                    if isinstance(partial, bytes):
                        partial = partial.decode("utf-8", errors="replace")
                    output = (
                        str(partial)
                        + f"verification command timed out after {args.command_timeout}s\n"
                    )
                except OSError as exc:
                    exit_code = 127
                    output = f"cannot execute verification command: {exc}\n"
                passed = passed and exit_code == 0
                record = {
                    "command": command,
                    "started_at": command_started,
                    "ended_at": utc_now(),
                    "exit_code": exit_code,
                    "output": output,
                }
                command_results.append(record)
                evidence.extend(
                    [
                        f"$ {command}\n",
                        output,
                        "" if output.endswith("\n") or not output else "\n",
                        f"[exit {exit_code}]\n\n",
                    ]
                )

            payload = {
                **running,
                "status": "passed" if passed else "failed",
                "ended_at": utc_now(),
                "commands": command_results,
            }
            write_json(result_path, payload)
            if passed:
                atomic_write(
                    verified_path,
                    f"attempt={attempt}\n" + "".join(evidence),
                )
            else:
                verified_path.unlink(missing_ok=True)
            append_event(
                context.run_dir,
                "verify_exit",
                context.task_id,
                slot=slot,
                attempt=attempt,
                status=payload["status"],
                exit_code=0 if passed else 1,
            )
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0 if passed else 1


def markdown_field(path: Path, fields: tuple[str, ...]) -> str | None:
    try:
        text = path.read_text(encoding="utf-8")
    except OSError:
        return None
    names = "|".join(re.escape(field) for field in fields)
    match = re.search(
        rf"(?im)^\s*(?:{names})\s*:\s*([A-Za-z_-]+)\b", text
    )
    return match.group(1).lower() if match else None


def review_is_required(task: dict, run_contract: dict) -> bool:
    value = task.get("review_gate", run_contract.get("review_gate"))
    if isinstance(value, bool):
        return value
    if isinstance(value, str):
        normalized = value.strip().lower()
        if normalized in {"required", "require", "on", "true", "passed"}:
            return True
        if normalized in {"not_required", "none", "off", "false"}:
            return False
        raise ContractError(f"unsupported review_gate value: {value!r}")
    risk_requires_review = str(task.get("risk", "")).lower() in {
        "high",
        "critical",
    }
    run_gate = run_contract.get("gate")
    if run_gate == "none":
        return False
    if run_gate not in (None, "pre-merge"):
        raise ContractError(f"unsupported run gate value: {run_gate!r}")
    return risk_requires_review


def require_review_receipt_identity(
    review: dict,
    *,
    task_id: str,
    task_sha256: str,
    attempt: int,
    project_cwd: Path,
) -> None:
    if set(review) != REVIEW_RECEIPT_FIELDS:
        missing = sorted(REVIEW_RECEIPT_FIELDS - set(review))
        extra = sorted(set(review) - REVIEW_RECEIPT_FIELDS)
        raise ContractError(
            f"review.json fields do not match schema v2; missing={missing}, extra={extra}"
        )
    if review.get("schema_version") != 2:
        raise ContractError("review.json schema_version must be 2")
    if review.get("receipt_type") != "task_re_review":
        raise ContractError("review.json receipt_type must be task_re_review")
    if review.get("task_id") != task_id:
        raise ContractError("review.json task_id does not match task")
    if review.get("task_sha256") != task_sha256:
        raise ContractError("review.json task_sha256 does not match state")
    if review.get("attempt") != attempt:
        raise ContractError("review.json attempt is not current")
    if review.get("project_cwd") != str(project_cwd):
        raise ContractError("review.json project_cwd does not match task")
    base_ref = review.get("base_ref")
    if not isinstance(base_ref, str) or not GIT_COMMIT_HEX.fullmatch(base_ref):
        raise ContractError("review.json base_ref must be a full commit SHA")
    for field in ("reviewed_diff_sha256", "reviewed_tree_sha256"):
        value = review.get(field)
        if not isinstance(value, str) or not SHA256_HEX.fullmatch(value):
            raise ContractError(f"review.json {field} must be a SHA-256 digest")
    if review.get("verdict") != "passed" or review.get("findings") != []:
        raise ContractError("accept requires review.json verdict passed with no findings")
    reviewed_at = review.get("reviewed_at")
    if not isinstance(reviewed_at, str) or not reviewed_at:
        raise ContractError("review.json reviewed_at must be a timestamp")
    try:
        parsed_at = datetime.fromisoformat(reviewed_at.replace("Z", "+00:00"))
    except ValueError as exc:
        raise ContractError("review.json reviewed_at must be an ISO-8601 timestamp") from exc
    if parsed_at.tzinfo is None:
        raise ContractError("review.json reviewed_at must include a timezone")


def git_read(project_cwd: Path, *args: str) -> bytes:
    try:
        result = subprocess.run(
            ["git", "-C", str(project_cwd), *args],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )
    except OSError as exc:
        raise ContractError(f"cannot inspect reviewed Git worktree: {exc}") from exc
    if result.returncode != 0:
        error = result.stderr.decode("utf-8", errors="replace").strip()
        raise ContractError(
            f"cannot inspect reviewed Git worktree: {error or 'git failed'}"
        )
    return result.stdout


def reviewed_worktree_digests(
    project_cwd: Path, run_dir: Path, base_ref: str
) -> tuple[str, str]:
    root_raw = git_read(project_cwd, "rev-parse", "--show-toplevel")
    try:
        git_root = Path(os.fsdecode(root_raw.rstrip(b"\n"))).resolve()
    except (OSError, ValueError) as exc:
        raise ContractError("cannot resolve reviewed Git worktree root") from exc
    if git_root != project_cwd:
        raise ContractError("review project_cwd must be the Git worktree root")

    resolved_base = git_read(
        project_cwd, "rev-parse", "--verify", f"{base_ref}^{{commit}}"
    ).decode("ascii", errors="strict").strip()
    if resolved_base != base_ref:
        raise ContractError("review.json base_ref must be an immutable full commit SHA")

    runtime_relative: Path | None = None
    try:
        runtime_relative = run_dir.relative_to(project_cwd)
    except ValueError:
        pass
    diff_args = [
        "diff",
        "--no-ext-diff",
        "--binary",
        "--full-index",
        base_ref,
        "--",
    ]
    if runtime_relative is not None:
        runtime_path = runtime_relative.as_posix().rstrip("/")
        diff_args.extend([".", f":(exclude){runtime_path}/**"])
    diff = git_read(project_cwd, *diff_args)

    raw_untracked = git_read(
        project_cwd, "ls-files", "--others", "--exclude-standard", "-z"
    ).split(b"\0")
    tree = hashlib.sha256()
    tree.update(b"lane-review-tree-v1\0")
    tree.update(base_ref.encode("ascii") + b"\0")
    tree.update(len(diff).to_bytes(8, "big"))
    tree.update(diff)
    for raw_path in sorted(path for path in raw_untracked if path):
        relative = Path(os.fsdecode(raw_path))
        if relative.is_absolute() or ".." in relative.parts:
            raise ContractError("Git returned an unsafe untracked path")
        if runtime_relative is not None and (
            relative == runtime_relative or runtime_relative in relative.parents
        ):
            continue
        path = project_cwd / relative
        try:
            if path.is_symlink():
                kind = b"l"
                content = os.fsencode(os.readlink(path))
            else:
                stat = path.stat()
                if not path.is_file():
                    raise ContractError(
                        f"untracked review path is not a regular file: {relative}"
                    )
                kind = b"x" if stat.st_mode & 0o111 else b"f"
                content = path.read_bytes()
        except OSError as exc:
            raise ContractError(
                f"cannot hash untracked review path {relative}: {exc}"
            ) from exc
        tree.update(len(raw_path).to_bytes(8, "big"))
        tree.update(raw_path)
        tree.update(kind)
        tree.update(len(content).to_bytes(8, "big"))
        tree.update(content)
    return hashlib.sha256(diff).hexdigest(), tree.hexdigest()


def cmd_accept(args: argparse.Namespace) -> int:
    run_dir = validate_run_dir(args.run_dir)
    supplied_context: TaskContext | None = None
    if args.task_file is not None or args.project_cwd is not None:
        if args.task_file is None or args.project_cwd is None:
            raise ContractError("accept requires both --task-file and --project-cwd")
        supplied_context = validate_task_context(
            run_dir_value=run_dir,
            task_id=args.task_id,
            task_file_value=args.task_file,
            project_cwd_value=args.project_cwd,
            create_artifact=False,
        )
        task_id = supplied_context.task_id
    else:
        if args.task_id is None:
            raise ContractError(
                "accept requires --task-id or --task-file with --project-cwd"
            )
        task_id = validate_name(args.task_id, "task id")
    artifact = artifact_dir_for(run_dir, task_id)
    with locked_file(safe_child_file(artifact, ".lifecycle.lock")):
        state = load_task_state(artifact)
        if state is None:
            raise ContractError("accept requires a schema_version 2 state.json")
        context = supplied_context or context_from_state(run_dir, task_id, state)
        require_immutable_task(context, state)
        _, run_contract = context_schema_version(context)
        assert run_contract is not None
        current = task_status(run_dir, task_id)
        state = read_json(state_path_for(artifact))
        require_immutable_task(context, state)
        attempt = state.get("current_attempt", state.get("attempt"))
        if not isinstance(attempt, int) or attempt < 1:
            raise ContractError("state.json current_attempt is invalid")
        if current["running"] or current["exit_code"] != 0:
            raise ContractError("accept requires current provider exit code 0")

        _, control = load_control_for(run_dir, task_id)
        report_evidence = trusted_provider_report(
            artifact, state, task_id, control=control
        )
        if not report_evidence.get("trusted"):
            raise ContractError(
                "accept requires the current trusted provider report: "
                f"{report_evidence.get('reason', 'untrusted')}"
            )
        if report_evidence.get("status") != "complete":
            raise ContractError("accept requires root report.md STATUS: complete")

        owns_path = safe_child_file(artifact, "owns-check.json")
        owns = read_json(owns_path)
        if (
            owns.get("schema_version") != 2
            or owns.get("status") != "passed"
            or owns.get("exit_code") != 0
        ):
            raise ContractError("accept requires owns-check.json status passed")
        if owns.get("task_sha256") != state.get("task_sha256"):
            raise ContractError("owns-check.json task_sha256 does not match state")
        if Path(str(owns.get("cwd", ""))).resolve() != context.project_cwd:
            raise ContractError("owns-check.json cwd does not match project_cwd")
        owns_scope = owns.get("scope")
        scope_task_ids = owns.get("scope_task_ids")
        if (
            owns_scope not in {"task", "run"}
            or not isinstance(scope_task_ids, list)
            or not all(isinstance(item, str) for item in scope_task_ids)
            or len(scope_task_ids) != len(set(scope_task_ids))
        ):
            raise ContractError("owns-check.json scope fields are invalid")
        if owns_scope == "task":
            expected_scope_task_ids = [task_id]
        else:
            expected_scope_task_ids = []
            for candidate in sorted((context.run_dir / "tasks").glob("*.yaml")):
                candidate_task, _ = load_task_yaml(candidate)
                candidate_id = str(candidate_task.get("id", ""))
                validate_name(candidate_id, "run task id")
                expected_scope_task_ids.append(candidate_id)
        if scope_task_ids != expected_scope_task_ids:
            raise ContractError(
                "owns-check.json scope_task_ids do not match the accepted task scope"
            )

        attempt_dir = current_attempt_dir(artifact, state)
        verification_path = safe_child_file(attempt_dir, "verification.json")
        verification = read_json(verification_path)
        if (
            not v2_verification_receipt_trusted(state, task_id, verification)
            or verification.get("status") != "passed"
        ):
            raise ContractError(
                "accept requires current verification passed for the immutable task"
            )

        if review_is_required(context.task, run_contract):
            review_path = safe_child_file(artifact, "review.json")
            review = read_json(review_path)
            require_review_receipt_identity(
                review,
                task_id=task_id,
                task_sha256=state["task_sha256"],
                attempt=attempt,
                project_cwd=context.project_cwd,
            )
            diff_sha256, tree_sha256 = reviewed_worktree_digests(
                context.project_cwd, context.run_dir, review["base_ref"]
            )
            if (
                review["reviewed_diff_sha256"] != diff_sha256
                or review["reviewed_tree_sha256"] != tree_sha256
            ):
                raise ContractError(
                    "reviewed worktree digest does not match current diff/tree state"
                )
            review_status = "passed"
        else:
            review_status = "not_required"

        accepted_at = utc_now()
        receipt = {
            "schema_version": 2,
            "task_id": task_id,
            "task_sha256": state.get("task_sha256"),
            "attempt": attempt,
            "provider_exit": 0,
            "provider": report_evidence["runtime"]["provider"],
            "model": report_evidence["runtime"]["model"],
            "report": "complete",
            "report_sha256": report_evidence["sha256"],
            "owns_check": "passed",
            "verification": "passed",
            "review": review_status,
            "accepted": True,
            "accepted_at": accepted_at,
        }
        write_json(safe_child_file(artifact, "acceptance.json"), receipt)
        state["status"] = "accepted"
        state["accepted"] = True
        state["accepted_at"] = accepted_at
        state["updated_at"] = accepted_at
        write_task_state(artifact, state)
        append_event(
            run_dir,
            "accepted",
            task_id,
            attempt=attempt,
            task_sha256=state.get("task_sha256"),
        )
    print(json.dumps(receipt, indent=2, sort_keys=True))
    return 0


def add_run_selector(parser: argparse.ArgumentParser, *, task_required: bool = True) -> None:
    parser.add_argument("--run-dir", required=True)
    parser.add_argument("--task-id", required=task_required)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Typed lifecycle control for detached AGY/Grok lanes"
    )
    sub = parser.add_subparsers(dest="command", required=True)

    start = sub.add_parser("start", help="validate and detach one AGY/Grok lane")
    add_run_selector(start, task_required=False)
    start.add_argument("--task-file", required=True)
    start.add_argument("--project-cwd", required=True)
    start.add_argument("--provider", choices=tuple(PRIMARY_MODELS), default="qwen")
    start.add_argument("--binary", help="provider binary override for tests")
    start.add_argument("--model", type=validate_model)
    start.add_argument(
        "--reasoning-effort", choices=("low", "medium", "high"), default="medium"
    )
    start.add_argument(
        "--idle",
        type=lambda value: bounded_int(
            value, minimum=5, maximum=3600, label="idle"
        ),
        default=900,
    )
    start.add_argument(
        "--max-runtime",
        "--max",
        dest="max_runtime",
        type=lambda value: bounded_int(
            value, minimum=10, maximum=86400, label="max-runtime"
        ),
        default=7200,
    )
    start.add_argument(
        "--pool-size",
        type=lambda value: bounded_int(
            value, minimum=1, maximum=HARD_PROVIDER_POOL, label="pool-size"
        ),
        default=configured_default(
            "LANE_SESSION_POOL_SIZE", 5, maximum=HARD_PROVIDER_POOL
        ),
    )
    start.add_argument(
        "--max-tasks",
        type=lambda value: bounded_int(
            value, minimum=1, maximum=HARD_MAX_TASKS, label="max-tasks"
        ),
        default=7,
    )
    start.set_defaults(handler=cmd_start)

    status = sub.add_parser("status", help="reconcile one lane's artifact state")
    add_run_selector(status)
    status.add_argument("--json", action="store_true")
    status.set_defaults(handler=cmd_status)

    tail = sub.add_parser("tail", help="read a bounded known artifact log")
    add_run_selector(tail)
    tail.add_argument("--source", choices=tuple(TAIL_SOURCES), default="supervisor")
    tail.add_argument(
        "--lines",
        type=lambda value: bounded_int(
            value, minimum=1, maximum=HARD_TAIL_LINES, label="lines"
        ),
        default=80,
    )
    tail.set_defaults(handler=cmd_tail)

    events = sub.add_parser("events", help="read the append-only lifecycle journal")
    add_run_selector(events, task_required=False)
    events.add_argument(
        "--limit",
        type=lambda value: bounded_int(
            value, minimum=1, maximum=HARD_TAIL_LINES, label="limit"
        ),
        default=100,
    )
    events.add_argument("--json", action="store_true")
    events.set_defaults(handler=cmd_events)

    cancel = sub.add_parser("cancel", help="terminate the recorded lane process tree")
    add_run_selector(cancel)
    cancel.set_defaults(handler=cmd_cancel)

    retry = sub.add_parser("retry", help="replay a validated recorded argv vector")
    add_run_selector(retry)
    retry.set_defaults(handler=cmd_retry)

    fallback = sub.add_parser(
        "fallback",
        help="replace a second eligible Grok failure with Codex Sol high",
    )
    add_run_selector(fallback)
    fallback.add_argument("--binary", help="Codex binary override for tests")
    fallback.set_defaults(handler=cmd_fallback)

    verify = sub.add_parser(
        "verify", help="run only verification commands from the task contract"
    )
    add_run_selector(verify, task_required=False)
    verify.add_argument("--task-file", required=True)
    verify.add_argument("--project-cwd", required=True)
    verify.add_argument(
        "--verify-pool-size",
        "--pool-size",
        dest="verify_pool_size",
        type=lambda value: bounded_int(
            value, minimum=1, maximum=HARD_VERIFY_POOL, label="verify-pool-size"
        ),
        default=configured_default(
            "LANE_VERIFY_POOL_SIZE", 2, maximum=HARD_VERIFY_POOL
        ),
    )
    verify.add_argument(
        "--command-timeout",
        type=lambda value: bounded_int(
            value,
            minimum=1,
            maximum=HARD_VERIFY_TIMEOUT,
            label="command-timeout",
        ),
        default=1800,
        help="maximum seconds for each verification command (default: 1800)",
    )
    verify.set_defaults(handler=cmd_verify)

    accept = sub.add_parser("accept", help="apply the schema v2 acceptance gate")
    add_run_selector(accept, task_required=False)
    accept.add_argument("--task-file")
    accept.add_argument("--project-cwd")
    accept.set_defaults(handler=cmd_accept)
    return parser


def main() -> int:
    try:
        parser = build_parser()
        args = parser.parse_args()
        return int(args.handler(args))
    except ContractError as exc:
        print(f"lane-ctl: {exc}", file=sys.stderr)
        return 2
    except OperationError as exc:
        print(f"lane-ctl: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
