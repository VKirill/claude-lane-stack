#!/usr/bin/env python3
"""Detect Claude + optional write/review CLIs; write routing profile.

PM is always Claude. Qwen, AGY, and Grok are switchable write providers.
Review/onboard/docs may use Codex. Claude-only fallback if neither present.
"""
from __future__ import annotations

import argparse
import json
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

PROFILES = {
    "full": {
        "fast_write": "qwen",
        "main_write": "qwen",
        "review": "codex",
        "emergency_write": "codex",
    },
    "claude-qwen": {
        "fast_write": "qwen",
        "main_write": "qwen",
        "review": "claude-reviewer",
        "emergency_write": "qwen",
    },
    "claude-agy": {
        "fast_write": "agy",
        "main_write": "agy",
        "review": "claude-reviewer",
        "emergency_write": "agy",
    },
    "claude-codex": {
        "fast_write": "codex",
        "main_write": "codex",
        "review": "codex",
        "emergency_write": "codex",
    },
    "claude-grok": {
        "fast_write": "grok",
        "main_write": "grok",
        "review": "claude-reviewer",
        "emergency_write": "grok",
    },
    "claude-grok-codex": {
        "fast_write": "grok",
        "main_write": "grok",
        "review": "codex",
        "emergency_write": "codex",
    },
    "claude-only": {
        "fast_write": "claude-worker",
        "main_write": "claude-worker",
        "review": "claude-reviewer",
        "emergency_write": "claude-worker",
    },
}

AGENT_MAP = {
    "agy": "run-supervisor",
    "grok": "run-supervisor",
    "qwen": "run-supervisor",
    "codex": "codex-implementer",
    "claude-worker": "general-purpose",
    "claude-reviewer": "codex-reviewer",
}


def which(cmd: str) -> str | None:
    return shutil.which(cmd)


def run_version(cmd: list[str], timeout: float = 8.0) -> str:
    try:
        out = subprocess.check_output(
            cmd, stderr=subprocess.STDOUT, text=True, timeout=timeout
        )
        return (out or "").strip().splitlines()[0][:120]
    except Exception as e:
        return f"error: {e.__class__.__name__}"


def command_lines(cmd: list[str], timeout: float = 8.0) -> list[str]:
    try:
        return subprocess.check_output(
            cmd, stderr=subprocess.STDOUT, text=True, timeout=timeout
        ).splitlines()
    except Exception:
        return []


def bubblewrap_operational(binary: str | None) -> bool:
    if not binary:
        return False
    try:
        result = subprocess.run(
            [
                binary,
                "--ro-bind",
                "/",
                "/",
                "--dev",
                "/dev",
                "--unshare-pid",
                "--proc",
                "/proc",
                "--tmpfs",
                "/tmp",
                "--",
                "/bin/true",
            ],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=8,
            check=False,
        )
    except (OSError, subprocess.SubprocessError):
        return False
    return result.returncode == 0


def resolver_mount_args() -> list[str]:
    try:
        resolver_target = Path("/etc/resolv.conf").resolve(strict=True)
    except OSError:
        return []
    runtime_root = Path("/run")
    if not resolver_target.is_file() or not resolver_target.is_relative_to(
        runtime_root
    ):
        return []

    mounts: list[str] = []
    parent = runtime_root
    for part in resolver_target.parent.relative_to(runtime_root).parts:
        parent /= part
        mounts.extend(("--dir", str(parent)))
    mounts.extend(("--ro-bind", str(resolver_target), str(resolver_target)))
    return mounts


def bubblewrap_resolver_operational(binary: str | None) -> bool:
    if not binary:
        return False
    command = [
        binary,
        "--die-with-parent",
        "--ro-bind",
        "/",
        "/",
        "--dev",
        "/dev",
        "--unshare-pid",
        "--unshare-ipc",
        "--proc",
        "/proc",
        "--tmpfs",
        "/run",
        "--tmpfs",
        "/tmp",
        "--tmpfs",
        "/var/tmp",
    ]
    command.extend(resolver_mount_args())
    command.extend(
        (
            "--",
            sys.executable,
            "-c",
            (
                "from pathlib import Path; "
                "p=Path('/etc/resolv.conf').resolve(strict=True); "
                "lines=p.read_text(encoding='utf-8').splitlines(); "
                "raise SystemExit(0 if any(line.strip().startswith('nameserver ') "
                "for line in lines) else 1)"
            ),
        )
    )
    try:
        result = subprocess.run(
            command,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=8,
            check=False,
        )
    except (OSError, subprocess.SubprocessError):
        return False
    return result.returncode == 0


def detect() -> dict:
    tools = {}
    p = which("claude")
    tools["claude"] = {
        "present": bool(p),
        "path": p,
        "version": run_version(["claude", "--version"]) if p else None,
        "required": True,
    }
    bwrap = which("bwrap")
    bwrap_ready = bubblewrap_operational(bwrap)
    resolver_ready = bubblewrap_resolver_operational(bwrap) if bwrap_ready else False
    p = which("agy")
    agy_models = command_lines(["agy", "models"]) if p else []
    agy_agents = command_lines(["agy", "agents"]) if p else []
    agy_model_ready = "gemini-3.6-flash-high" in agy_models
    agy_agent_ready = any(line.strip() == "agy-writer" for line in agy_agents)
    tools["agy"] = {
        "present": bool(
            p
            and agy_model_ready
            and agy_agent_ready
            and bwrap_ready
            and resolver_ready
        ),
        "binary_present": bool(p),
        "model_present": agy_model_ready,
        "agent_present": agy_agent_ready,
        "path": p,
        "version": run_version(["agy", "--version"]) if p else None,
        "required": False,
        "unavailable_reason": (
            "gemini-3.6-flash-high unavailable"
            if p and not agy_model_ready
            else "agy-writer agent unavailable"
            if p and not agy_agent_ready
            else "bubblewrap missing"
            if p and not bwrap
            else "bubblewrap probe failed"
            if p and not bwrap_ready
            else "bubblewrap resolver unavailable"
            if p and not resolver_ready
            else None
        ),
    }
    p = which("grok")
    tools["grok"] = {
        "present": bool(p and bwrap_ready and resolver_ready),
        "binary_present": bool(p),
        "path": p,
        "version": run_version(["grok", "--version"]) if p else None,
        "required": False,
        "unavailable_reason": (
            "bubblewrap missing"
            if p and not bwrap
            else "bubblewrap probe failed"
            if p and not bwrap_ready
            else "bubblewrap resolver unavailable"
            if p and not resolver_ready
            else None
        ),
    }
    p = which("qwen")
    tools["qwen"] = {
        "present": bool(p and bwrap_ready and resolver_ready),
        "binary_present": bool(p),
        "path": p,
        "version": run_version(["qwen", "--version"]) if p else None,
        "required": False,
        "unavailable_reason": (
            "bubblewrap missing"
            if p and not bwrap
            else "bubblewrap probe failed"
            if p and not bwrap_ready
            else "bubblewrap resolver unavailable"
            if p and not resolver_ready
            else None
        ),
    }
    tools["bubblewrap"] = {
        "present": bool(bwrap),
        "operational": bwrap_ready,
        "resolver_operational": resolver_ready,
        "path": bwrap,
        "version": None,
        "required": False,
    }
    p = which("codex")
    tools["codex"] = {
        "present": bool(p),
        "path": p,
        "version": run_version(["codex", "--version"]) if p else None,
        "required": False,
    }
    return tools


def pick_profile(
    tools: dict, writer_provider: str = "auto"
) -> tuple[str, dict, list[str]]:
    notes: list[str] = []
    has = {k: tools[k]["present"] for k in ("claude", "agy", "grok", "codex", "qwen")}
    writer = (
        writer_provider
        if writer_provider != "auto" and has[writer_provider]
        else "qwen"
        if has["qwen"]
        else "grok"
        if has["grok"]
        else "agy"
        if has["agy"]
        else None
    )
    if writer_provider != "auto" and not has[writer_provider]:
        notes.append(f"Requested writer {writer_provider} unavailable; using {writer or 'fallback'}")
    if tools["agy"].get("binary_present") and not has["agy"]:
        reason = tools["agy"].get("unavailable_reason") or "unavailable"
        notes.append(f"AGY disabled ({reason})")
    if tools["grok"].get("binary_present") and not has["grok"]:
        reason = tools["grok"].get("unavailable_reason") or "bubblewrap unavailable"
        notes.append(
            "Grok disabled — bubblewrap is required for safe writer lanes "
            f"({reason})"
        )
    if tools["qwen"].get("binary_present") and not has["qwen"]:
        reason = tools["qwen"].get("unavailable_reason") or "bubblewrap unavailable"
        notes.append(
            "Qwen disabled — bubblewrap is required for safe writer lanes "
            f"({reason})"
        )
    if not has["claude"]:
        notes.append("Claude Code missing — install required for PM")
        return "none", {}, notes

    if writer and has["codex"]:
        name = "full"
        lanes = dict(PROFILES[name])
        lanes["fast_write"] = writer
        lanes["main_write"] = writer
    elif writer:
        name = f"claude-{writer}"
        lanes = dict(PROFILES[name])
        notes.append("Codex missing → review falls back to Claude reviewer")
    elif has["codex"]:
        name = "claude-codex"
        lanes = dict(PROFILES[name])
        notes.append("Qwen/AGY/Grok missing — write + review via Codex")
    else:
        name = "claude-only"
        lanes = dict(PROFILES[name])
        notes.append("No Qwen/AGY/Grok/Codex — Claude subagents only")

    return name, lanes, notes


def write_outputs(
    repo: Path, tools: dict, profile: str, lanes: dict, notes: list[str]
) -> None:
    agents = repo / ".agents"
    agents.mkdir(parents=True, exist_ok=True)
    caps = {
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "tools": tools,
        "profile": profile,
        "lanes": lanes,
        "notes": notes,
        "pm": "claude",
    }
    (agents / "capabilities.json").write_text(
        json.dumps(caps, indent=2) + "\n", encoding="utf-8"
    )

    lines = [
        "# routing.profile.yaml — generated by agents-doctor",
        f"# {caps['generated_at']}",
        "pm: claude  # fixed — Claude Lane Stack requires Claude Code as orchestrator",
        f"profile: {profile}",
        "lanes:",
    ]
    for k, v in lanes.items():
        agent = AGENT_MAP.get(v, v)
        if k == "review" and v == "codex":
            agent = "codex-reviewer"
        lines.append(f"  {k}: {v}  # agent: {agent}")
    lines.append("notes:")
    if notes:
        for n in notes:
            lines.append(f"  - {json.dumps(n)}")
    else:
        lines.append("  - []")
    lines.append("")
    (agents / "routing.profile.yaml").write_text("\n".join(lines), encoding="utf-8")
    print(f"Wrote {agents / 'capabilities.json'}")
    print(f"Wrote {agents / 'routing.profile.yaml'}")


def main() -> int:
    ap = argparse.ArgumentParser(description="Claude Lane Stack doctor")
    ap.add_argument("repo", nargs="?", default=".")
    ap.add_argument("--json", action="store_true")
    ap.add_argument(
        "--apply",
        action="store_true",
        help="write .agents/capabilities.json + routing.profile.yaml",
    )
    ap.add_argument(
        "--writer-provider",
        choices=("auto", "qwen", "agy", "grok"),
        default="auto",
        help="preferred writer provider (default: auto, Qwen before Grok before AGY)",
    )
    args = ap.parse_args()

    tools = detect()
    profile, lanes, notes = pick_profile(tools, args.writer_provider)

    if args.json:
        print(
            json.dumps(
                {
                    "pm": "claude",
                    "tools": tools,
                    "profile": profile,
                    "lanes": lanes,
                    "notes": notes,
                },
                indent=2,
            )
        )
    else:
        print("Claude Lane Stack — agents-doctor\n")
        for name, info in tools.items():
            mark = "✓" if info["present"] else "✗"
            req = " (required)" if info.get("required") else ""
            ver = info.get("version") or ""
            print(f"  {mark} {name:8} {ver}{req}")
        print(f"\nProfile: {profile}")
        if lanes:
            print("Lanes:")
            for k, v in lanes.items():
                print(f"  {k:16} → {v}")
        if notes:
            print("Notes:")
            for n in notes:
                print(f"  - {n}")

    if not tools["claude"]["present"]:
        print("\nERROR: Claude Code is required as PM.", file=sys.stderr)
        return 1

    if args.apply:
        write_outputs(Path(args.repo).resolve(), tools, profile, lanes, notes)

    return 0


if __name__ == "__main__":
    sys.exit(main())
