#!/usr/bin/env bash
# Start a long lane under nohup so Claude Bash foreground (~2 min) cannot kill it.
# Usage:
#   lane-bg --dir ARTIFACT_DIR --label NAME -- lane-exec ... -- cmd
# Writes: ARTIFACT_DIR/lane-bg.pid, lane-bg.meta, appends to lane-bg.supervisor.log
set -euo pipefail

DIR=""
LABEL="lane"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dir) DIR="$2"; shift 2 ;;
    --label) LABEL="$2"; shift 2 ;;
    --) shift; break ;;
    -h|--help)
      echo "Usage: lane-bg --dir ARTIFACT_DIR [--label NAME] -- <command...>"
      exit 0
      ;;
    *)
      # allow: lane-bg ARTIFACT_DIR -- cmd
      if [[ -z "$DIR" && "$1" != --* ]]; then DIR="$1"; shift; continue; fi
      echo "Unknown arg: $1" >&2; exit 2
      ;;
  esac
done

if [[ -z "$DIR" || $# -lt 1 ]]; then
  echo "Usage: lane-bg --dir ARTIFACT_DIR -- <command...>" >&2
  exit 2
fi

mkdir -p "$DIR"
PID_FILE="$DIR/lane-bg.pid"
META="$DIR/lane-bg.meta"
SUP_LOG="$DIR/lane-bg.supervisor.log"
CMD_FILE="$DIR/lane-bg.cmd"
BACKEND="${LANE_BG_BACKEND:-auto}"

case "$BACKEND" in
  auto|systemd|nohup) ;;
  *) echo "LANE_BG_BACKEND must be auto, systemd, or nohup" >&2; exit 2 ;;
esac

# already running?
if [[ -f "$PID_FILE" ]]; then
  old=$(cat "$PID_FILE" 2>/dev/null || true)
  if [[ -n "${old:-}" ]] && kill -0 "$old" 2>/dev/null; then
    echo "LANE_BG_ALREADY_RUNNING pid=$old dir=$DIR"
    exit 0
  fi
fi
# A completed attempt leaves its PID as history. Remove it before dispatch so
# the startup wait and caller observe the new supervisor PID, not stale state.
rm -f "$PID_FILE"

printf '%s\n' "$@" > "$CMD_FILE"
{
  echo "started_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "label=$LABEL"
  echo "cwd=$(pwd)"
  echo "cmd=$*"
} > "$META"

WORKER_SCRIPT='
  set +e
  DIR="$1"; shift
  SUP_LOG="$DIR/lane-bg.supervisor.log"
  PID_FILE="$DIR/lane-bg.pid"
  echo "$$" > "$PID_FILE"
  echo "[lane-bg] pid=$$ start $(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$SUP_LOG"
  "$@" >> "$SUP_LOG" 2>&1
  ec=$?
  echo "[lane-bg] exit=$ec end $(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$SUP_LOG"
  echo "exit_code=$ec" >> "$DIR/lane-bg.meta"
  echo "ended_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$DIR/lane-bg.meta"
  # leave pid file for lane-wait to see exit; mark done
  echo "$ec" > "$DIR/lane-bg.exit"
  exit $ec
'

launch_nohup() {
  nohup /bin/bash -c "$WORKER_SCRIPT" _ "$DIR" "$@" >/dev/null 2>&1 &
}

launch_systemd() {
  command -v systemd-run >/dev/null 2>&1 || return 1
  systemctl --user show-environment >/dev/null 2>&1 || return 1
  systemd-run --user --collect --no-block --quiet --expand-environment=no \
    --property=KillMode=control-group \
    --working-directory="$(pwd)" \
    --setenv="HOME=${HOME}" \
    --setenv="PATH=${PATH}" \
    /bin/bash -c "$WORKER_SCRIPT" _ "$DIR" "$@"
}

SELECTED_BACKEND="$BACKEND"
if [[ "$BACKEND" == "auto" ]]; then
  if launch_systemd "$@"; then
    SELECTED_BACKEND="systemd"
  else
    SELECTED_BACKEND="nohup"
    launch_nohup "$@"
  fi
elif [[ "$BACKEND" == "systemd" ]]; then
  if ! launch_systemd "$@"; then
    echo "lane-bg: user systemd backend unavailable" >&2
    exit 1
  fi
else
  launch_nohup "$@"
fi
echo "backend=$SELECTED_BACKEND" >> "$META"

# The transient service may need a moment to write its authoritative PID.
for _ in {1..20}; do
  [[ -f "$PID_FILE" ]] && break
  sleep 0.05
done
if [[ -f "$PID_FILE" ]]; then
  echo "LANE_BG_STARTED pid=$(cat "$PID_FILE") dir=$DIR label=$LABEL backend=$SELECTED_BACKEND log=$SUP_LOG"
else
  echo "LANE_BG_STARTED pid=unknown dir=$DIR label=$LABEL backend=$SELECTED_BACKEND log=$SUP_LOG"
fi
exit 0
